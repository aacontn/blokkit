---
<footer class="site-footer">
  <div class="footer-gradient"></div>
  
  <div class="max-w-7xl mx-auto layout-shell">
    <!-- Main Footer Content -->
    <div class="footer-main">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/images/Logo-Blokkit-white.png" alt="BloKKit" class="h-8" />
        </a>
        <p class="footer-tagline">
          Ambientes libres de distracciones para instituciones que buscan el enfoque real.
        </p>
        
        <!-- Social Links -->
        <div class="footer-social">
          <a href="https://www.instagram.com/blokkit.cl" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r="1"></circle>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/blokkit/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://x.com/blokkit_cl" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Links Columns -->
      <div class="footer-links-grid">
        <div class="footer-links-column">
          <h4>Producto</h4>
          <ul>
            <li><a href="/producto">Cómo funciona</a></li>
            <li><a href="/beneficios">Beneficios</a></li>
            <li><a href="/evidencia">Evidencia</a></li>
          </ul>
        </div>
        
        <div class="footer-links-column">
          <h4>Soluciones</h4>
          <ul>
            <li><a href="/soluciones#educacion">Educación</a></li>
            <li><a href="/soluciones#empresas">Empresas</a></li>
            <li><a href="/soluciones#eventos">Eventos</a></li>
          </ul>
        </div>
        
        <div class="footer-links-column">
          <h4>Empresa</h4>
          <ul>
            <li><a href="/ley-celulares-2026">Ley Celulares 2026</a></li>
            <li><a href="/prensa">Prensa</a></li>
            <li><a href="/contacto">Contacto</a></li>
            <li><a href="/login">Mi Portal</a></li>
          </ul>
        </div>
      </div>
      
      <!-- CTA Column -->
      <div class="footer-cta">
        <p>¿Listo para probar BloKKit?</p>
        <a href="/contacto" class="footer-cta-button">
          Agendar Demo
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
    
    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        © 2026 BloKKit. Todos los derechos reservados.
      </p>
      <div class="footer-legal">
        <a href="/privacidad">Privacidad</a>
        <a href="/terminos">Términos</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    padding-top: 4rem;
    padding-bottom: 2rem;
    margin-top: 0;
    background:
      linear-gradient(rgba(0, 194, 209, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 194, 209, 0.04) 1px, transparent 1px),
      radial-gradient(1000px 440px at 14% -12%, rgba(0, 194, 209, 0.2), transparent 60%),
      radial-gradient(860px 360px at 86% 8%, rgba(0, 194, 209, 0.12), transparent 62%),
      linear-gradient(180deg, #121212 0%, #0b0b0b 52%, #070707 100%);
    background-size: 64px 64px, 64px 64px, auto, auto, auto;
    overflow: hidden;
  }
  
  .footer-gradient {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 800px;
    height: 200px;
    background: radial-gradient(ellipse at top, rgba(0, 194, 209, 0.14) 0%, transparent 70%);
    pointer-events: none;
  }
  
  .footer-main {
    display: grid;
    grid-template-columns: 1.5fr 2fr 1fr;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  
  /* Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
  }
  
  .footer-logo {
    display: inline-block;
    margin-bottom: 1rem;
  }
  
  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.5rem;
  }
  
  .footer-social {
    display: flex;
    gap: 0.75rem;
  }
  
  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    color: rgba(255, 255, 255, 0.5);
    transition: all 0.2s ease;
  }
  
  .footer-social a:hover {
    background: rgba(0, 194, 209, 0.1);
    border-color: rgba(0, 194, 209, 0.3);
    color: var(--color-accent);
    transform: translateY(-2px);
  }
  
  /* Links Grid */
  .footer-links-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  
  .footer-links-column h4 {
    font-size: 0.8125rem;
    font-weight: 600;
    color: white;
    margin-bottom: 1rem;
    text-transform: none;
  }
  
  .footer-links-column ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .footer-links-column a {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.4);
    transition: color 0.2s ease;
  }
  
  .footer-links-column a:hover {
    color: var(--color-accent);
  }
  
  /* CTA */
  .footer-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
  }
  
  .footer-cta p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
  }
  
  .footer-cta-button {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #ffffff;
    background: linear-gradient(135deg, #00C2D1 0%, #00A8B5 100%);
    border-radius: 100px;
    transition: all 0.3s ease;
  }
  
  .footer-cta-button:hover {
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(0, 194, 209, 0.4);
  }
  
  /* Bottom */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
  }
  
  .footer-copyright {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
  }
  
  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }
  
  .footer-legal a {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    transition: color 0.2s ease;
  }
  
  .footer-legal a:hover {
    color: rgba(255, 255, 255, 0.6);
  }
  
  @media (max-width: 1024px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    
    .footer-cta {
      grid-column: span 2;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding-top: 2rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }
    
    .footer-cta p {
      margin-bottom: 0;
    }
  }
  
  @media (max-width: 768px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    
    .footer-links-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    
    .footer-cta {
      grid-column: 1;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer-cta p {
      margin-bottom: 0.9rem;
    }
    
    .footer-cta-button {
      justify-content: center;
      width: auto;
    }
    
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
