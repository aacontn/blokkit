---
const currentYear = new Date().getFullYear();

const productLinks = [
  { label: "Cómo funciona", href: "/#como-funciona" },
  { label: "Beneficios", href: "/beneficios" },
  { label: "Evidencia", href: "/evidencia" },
];

const solutionLinks = [
  { label: "Educación", href: "/soluciones#educacion" },
  { label: "Empresas", href: "/soluciones#empresas" },
  { label: "Eventos", href: "/soluciones#eventos" },
];

const companyLinks = [
  { label: "Ley 21.801 — Celulares", href: "/ley-celulares-2026" },
  { label: "Prensa", href: "/prensa" },
  { label: "Contacto", href: "/contacto" },
  { label: "Mi Portal", href: "https://app.blokkit.cl", external: true },
];

const legalLinks = [
  { label: "Privacidad", href: "/privacidad" },
  { label: "Términos", href: "/terminos" },
];
---

<footer class="footer has-bg-effect">
  <!-- Light abstract bg -->
  <div class="footer__inner container" style="position: relative; z-index: 1;">
    <div class="footer__grid">
      <!-- Brand column -->
      <div class="footer__brand">
        <a href="/" aria-label="BloKKit">
          <img src="/images/Logo-Blokkit-white.webp" alt="BloKKit" width="140" height="42" loading="lazy" class="footer__logo" />
        </a>
        <p class="footer__tagline">
          Ambientes libres de distracciones para instituciones que buscan el enfoque real.
        </p>
        <div class="footer__socials">
          <a href="#" class="footer__social-btn" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="#" class="footer__social-btn" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
          <a href="#" class="footer__social-btn" aria-label="X (Twitter)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"></path><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path></svg>
          </a>
        </div>
      </div>

      <!-- Links Columns (3) -->
      <div class="footer__col">
        <h3 class="footer__col-title">Producto</h3>
        <ul class="footer__list">
          {productLinks.map(({ label, href }) => (
            <li><a href={href} class="footer__list-link link-reveal">{label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__col-title">Soluciones</h3>
        <ul class="footer__list">
          {solutionLinks.map(({ label, href }) => (
            <li><a href={href} class="footer__list-link link-reveal">{label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__col-title">Empresa</h3>
        <ul class="footer__list">
          {companyLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class="footer__list-link link-reveal" 
                {...(link.external ? { target: "_blank", rel: "noopener" } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA Column -->
      <div class="footer__cta-col">
        <h3 class="footer__cta-title">¿Listo para probar BloKKit?</h3>
        <a href="https://wa.me/56996472784?text=Hola%2C%20estoy%20interesado%20en%20BloKKit" class="btn btn--primary btn--wa" target="_blank" rel="noopener noreferrer">
          Hablemos
          <span class="btn-wa-icon">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.81 11.81 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413Z"/>
            </svg>
          </span>
        </a>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">
        © {currentYear} BloKKit. Todos los derechos reservados.
      </p>
      <nav class="footer__legal" aria-label="Enlaces legales">
        {legalLinks.map(({ label, href }) => (
          <a href={href} class="footer__legal-link">{label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    /* Dark liquid-glass footer — coherent with the rest of the site */
    background:
      radial-gradient(900px 420px at 85% -10%, rgba(127, 206, 236, 0.08), transparent 60%),
      var(--bg-dark-deep);
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-20);
    padding-bottom: var(--space-8);
    position: relative;
    overflow: hidden;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  /* ── 5-Column Flex Layout on Desktop ── */
  .footer__grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 768px) {
    .footer__grid {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: var(--space-8);
    }
    
    .footer__brand {
      flex: 1 1 30%;
      min-width: 250px;
    }

    .footer__col {
      flex: 1 1 12%;
      min-width: 120px;
    }

    .footer__cta-col {
      flex: 1 1 20%;
      min-width: 200px;
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      flex-wrap: nowrap;
      gap: var(--space-12);
    }

    .footer__brand {
      flex: 0 0 300px;
    }

    .footer__col {
      flex: 1;
    }

    .footer__cta-col {
      flex: 0 0 250px;
    }
  }

  /* ── Brand Column ── */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .footer__logo {
    height: 32px;
    width: auto;
    display: block;
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .footer__socials {
    display: flex;
    gap: var(--space-3);
  }

  .footer__social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-full);
    /* glass chip */
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: var(--glass-backdrop-subtle);
    -webkit-backdrop-filter: var(--glass-backdrop-subtle);
    box-shadow: var(--glass-highlight);
    color: var(--text-secondary);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .footer__social-btn:hover {
    color: var(--accent);
    background: var(--glass-bg-hover);
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }

  /* ── Link Columns ── */
  .footer__col-title {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 var(--space-5) 0;
  }

  .footer__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__list-link {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    transition: color var(--duration-fast) var(--ease-out);
    text-decoration: none;
  }

  .footer__list-link:hover {
    color: var(--text-primary);
  }

  /* ── CTA Column — clean, no box ── */
  .footer__cta-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .footer__cta-title {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
  }

  /* ── Bottom Bar ── */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-subtle);
  }

  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer__copy {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  .footer__legal {
    display: flex;
    gap: var(--space-6);
  }

  .footer__legal-link {
    font-size: var(--text-xs);
    color: var(--text-muted);
    transition: color var(--duration-fast) var(--ease-out);
    text-decoration: none;
  }

  .footer__legal-link:hover {
    color: var(--text-secondary);
  }

  /* WhatsApp CTA button — replaces arrow circle with WA icon */
  :global(.btn--wa) {
    padding-block: 6px;
  }

  :global(.btn--wa::after) {
    display: none;
  }

  :global(.btn-wa-icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: #111827;
    color: #ffffff;
    margin-left: var(--space-3);
    flex-shrink: 0;
    transition: background-color 0.4s ease;
  }

  :global(.btn--wa:hover) {
    transform: none;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.05);
  }

  /* Cancelar el translateX que btn aplica a svgs en hover */
  :global(.btn--wa:hover svg) {
    transform: none !important;
  }

  /* Solo cambia el fondo del ícono WSP a verde */
  :global(.btn--wa:hover .btn-wa-icon) {
    background-color: #25D366;
  }
</style>
