---
/**
 * ArchitectureFlow — the BloKKit system map: three product cards
 * (Funda → Dock → Plataforma) with animated vignettes and flowing
 * connector arrows. Single source of truth used on the index and
 * the producto page. Vignette micro-animations live in global.css
 * (.arch-card__icon .vig-*) because set:html content is unscoped.
 */
import ScrollReveal from "./ui/ScrollReveal.tsx";

interface Props {
  /** "dark" (glass cards, default) for dark/slate sections;
      "light" (solid white cards) for cream sections */
  tone?: "dark" | "light";
  /** optional per-card anchors (e.g. ["#funda", "#dock", "#plataforma"]) —
      cards become links with a "Ver capa 0N" affordance and numbered badges */
  links?: string[];
}

const { tone = "dark", links } = Astro.props;
const light = tone === "light";
const linked = Array.isArray(links) && links.length === 3;

const PIECES = [
  {
    icon: `<svg viewBox="0 0 48 48" fill="none"><rect x="15" y="5" width="18" height="38" rx="7" fill="#26272A" stroke="#4A4B4E" stroke-width="2"/><line x1="18.5" y1="17" x2="29.5" y2="17" stroke="#55565A" stroke-width="1" stroke-dasharray="2.5 2"/><circle cx="24" cy="11.5" r="2.6" fill="#101113"/><circle class="vig-pin-ring" cx="24" cy="11.5" r="5.5" stroke="#7FCEEC" stroke-width="1.2"/><g stroke="#E9E9E9" stroke-width="1.3"><circle cx="24" cy="31" r="3.2"/><path d="M22.9 30.2v-.9a1.1 1.1 0 0 1 2.2 0v.9"/></g></svg>`,
    pill: "Bloqueo físico",
    title: "Funda BloKKit",
    desc: "Malla de polímeros de cobre y níquel con bloqueo certificado de señales 3G, 4G, 5G, WiFi 2.4/5GHz y Bluetooth.",
    specs: ["99.9% efectividad de bloqueo", "50.000+ cierres garantizados"],
  },
  {
    icon: `<svg viewBox="0 0 48 48" fill="none"><ellipse cx="13" cy="28" rx="5" ry="2.2" fill="#2E2F32"/><ellipse cx="13" cy="28" rx="1.8" ry="0.8" fill="#0F1012"/><ellipse cx="26" cy="35" rx="16" ry="5.5" fill="#141517"/><ellipse cx="26" cy="32" rx="16" ry="5.5" fill="#D8CEB5"/><ellipse cx="26" cy="29" rx="16" ry="5.5" fill="#232425"/><rect x="21" y="15" width="10" height="13.5" fill="#B9BCC0"/><ellipse cx="26" cy="28.5" rx="5" ry="1.9" fill="#8E9196"/><ellipse cx="26" cy="15" rx="5" ry="1.9" fill="#D9DCDF"/><ellipse class="vig-wave" cx="26" cy="15" rx="8" ry="3.2" stroke="#3FA8E0" stroke-width="1.2"/></svg>`,
    pill: "Control de apertura",
    title: "Dock de Desbloqueo",
    desc: "Apertura magnética controlada en menos de 3 segundos. Disponible en versión estándar y Smart con registro digital.",
    specs: ["Dock Estándar: operación manual", "Dock Smart: trazabilidad completa"],
    featured: true,
  },
  {
    icon: `<svg viewBox="0 0 48 48" fill="none"><rect x="7" y="9" width="34" height="30" rx="3" fill="#1B1C1E" stroke="#4A4B4E" stroke-width="1.6"/><line x1="7" y1="15.5" x2="41" y2="15.5" stroke="#4A4B4E" stroke-width="1.2"/><circle cx="11" cy="12.2" r="1" fill="#55565A"/><circle cx="14.4" cy="12.2" r="1" fill="#55565A"/><circle cx="17.8" cy="12.2" r="1" fill="#55565A"/><rect class="vig-bar vig-b1" x="13" y="24" width="4" height="10" rx="1" fill="#3FA8E0"/><rect class="vig-bar vig-b2" x="20" y="20" width="4" height="14" rx="1" fill="#7FCEEC"/><rect class="vig-bar vig-b3" x="27" y="26" width="4" height="8" rx="1" fill="#3FA8E0"/><rect class="vig-bar vig-b4" x="34" y="22" width="4" height="12" rx="1" fill="#7FCEEC"/></svg>`,
    pill: "Trazabilidad",
    title: "Plataforma de Gestión",
    desc: "Panel web con registro de uso por persona: cada funda se asigna por QR y todo su ciclo queda trazado.",
    specs: ["Asignación por QR a cada usuario", "KPIs y reportes exportables"],
  },
];
---

<div class="arch__grid">
  {PIECES.map((card, i) => (
    <Fragment>
      <ScrollReveal client:visible delay={i * 0.12}>
        {linked ? (
          <a href={links[i]} class="arch-card__linkwrap">
            <div class={`arch-card ${card.featured ? "arch-card--featured" : ""} ${light ? "arch-card--light" : ""}`}>
              <div class="arch-card__header">
                <div class="arch-card__icon" set:html={card.icon} />
                <span class="arch-card__badge">Capa 0{i + 1} · {card.pill}</span>
              </div>
              <h3 class="arch-card__title">{card.title}</h3>
              <p class="arch-card__desc">{card.desc}</p>
              <div class="arch-card__divider"></div>
              <ul class="arch-card__list">
                {card.specs.map((s) => <li>{s}</li>)}
              </ul>
              <span class="arch-card__go">
                Ver capa 0{i + 1}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14m0 0l-6-6m6 6l6-6"/></svg>
              </span>
            </div>
          </a>
        ) : (
          <div class={`arch-card ${card.featured ? "arch-card--featured" : ""} ${light ? "arch-card--light" : ""}`}>
            <div class="arch-card__header">
              <div class="arch-card__icon" set:html={card.icon} />
              <span class="arch-card__badge">{card.pill}</span>
            </div>
            <h3 class="arch-card__title">{card.title}</h3>
            <p class="arch-card__desc">{card.desc}</p>
            <div class="arch-card__divider"></div>
            <ul class="arch-card__list">
              {card.specs.map((s) => <li>{s}</li>)}
            </ul>
          </div>
        )}
      </ScrollReveal>
      {i < 2 && (
        <div class="arch__connector" aria-hidden="true">
          <svg viewBox="0 0 40 24" fill="none">
            <path class="arch__flow-line" d="M2 12 H29" stroke="currentColor" stroke-width="1.6" stroke-dasharray="5 5" stroke-linecap="round"/>
            <path d="M30 6.5 L38 12 L30 17.5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/>
          </svg>
        </div>
      )}
    </Fragment>
  ))}
</div>

<script>
  // Lenis swallows native hash jumps — route linked-card clicks through it
  document.addEventListener("click", (e) => {
    const wrap = (e.target as Element | null)?.closest?.(".arch-card__linkwrap");
    if (!wrap) return;
    const hash = wrap.getAttribute("href");
    if (!hash || !hash.startsWith("#")) return;
    const target = document.querySelector(hash);
    if (!target) return;
    e.preventDefault();
    const lenis = (window as any).lenis;
    if (lenis?.scrollTo) {
      lenis.scrollTo(target, { offset: -72 });
    } else {
      target.scrollIntoView({ behavior: "smooth" });
    }
    history.pushState(null, "", hash);
  });
</script>

<style>
  .arch__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-4);
  }

  /* desktop: cards with flow connectors between them */
  @media (min-width: 1024px) {
    .arch__grid {
      grid-template-columns: minmax(0, 1fr) 44px minmax(0, 1fr) 44px minmax(0, 1fr);
      gap: var(--space-3);
      align-items: stretch;
    }
  }

  .arch__connector {
    display: none;
  }

  @media (min-width: 1024px) {
    .arch__connector {
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent-strong);
    }

    .arch__connector svg {
      width: 40px;
      height: 24px;
    }
  }

  .arch__flow-line {
    animation: arch-dash 1.4s linear infinite;
  }

  @keyframes arch-dash {
    to { stroke-dashoffset: -10; }
  }

  @media (prefers-reduced-motion: reduce) {
    .arch__flow-line { animation: none; }
  }

  /* ── Cards: liquid glass on dark/slate sections ── */
  .arch-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8) var(--space-6);
    backdrop-filter: var(--glass-backdrop);
    -webkit-backdrop-filter: var(--glass-backdrop);
    box-shadow: var(--glass-highlight), var(--glass-shadow);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    height: 100%;
  }

  .arch-card:hover {
    transform: translateY(-4px);
    background: var(--glass-bg-hover);
    box-shadow: var(--glass-highlight-strong), 0 20px 48px rgba(0, 0, 0, 0.45);
  }

  .arch-card--featured {
    background: linear-gradient(180deg, rgba(127, 206, 236, 0.10) 0%, rgba(127, 206, 236, 0.04) 100%);
    border: 1px solid var(--border-accent);
    box-shadow: var(--glass-highlight), 0 16px 40px rgba(127, 206, 236, 0.12);
  }

  .arch-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-6);
    gap: var(--space-3);
  }

  .arch-card__icon {
    width: 68px;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-subtle);
    flex-shrink: 0;
  }

  .arch-card--featured .arch-card__icon {
    background: var(--accent-muted);
    border: 1px solid var(--border-accent);
  }

  .arch-card__badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-accent);
    color: var(--accent);
    margin-top: 4px;
  }

  .arch-card__title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 var(--space-3) 0;
    letter-spacing: -0.01em;
  }

  .arch-card__desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .arch-card__divider {
    height: 1px;
    background: var(--border-subtle);
    margin: var(--space-5) 0;
    width: 100%;
  }

  .arch-card--featured .arch-card__divider {
    background: rgba(127, 206, 236, 0.2);
  }

  .arch-card__list {
    list-style: none;
    padding: 0;
    margin: auto 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .arch-card__list li {
    font-size: 0.8rem;
    color: var(--text-secondary);
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.4;
  }

  .arch-card__list li::before {
    content: "•";
    color: var(--accent);
    font-weight: bold;
    display: block;
    margin-top: -1px;
  }

  /* ── Linked cards (page-index mode) ── */
  .arch-card__linkwrap {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .arch-card__go {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--space-5);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    transition: gap 0.25s ease;
  }

  .arch-card__go svg {
    transition: transform 0.25s ease;
  }

  .arch-card__linkwrap:hover .arch-card__go {
    gap: 10px;
  }

  .arch-card__linkwrap:hover .arch-card__go svg {
    transform: translateY(3px);
  }

  .arch-card--light .arch-card__go {
    color: var(--accent-dark);
  }

  /* ── Light tone: solid white cards on cream sections ── */
  .arch-card--light {
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: var(--shadow-card);
  }

  .arch-card--light:hover {
    background: var(--bg-white);
    box-shadow: var(--shadow-card-hover);
    border-color: rgba(63, 168, 224, 0.35);
  }

  .arch-card--light.arch-card--featured {
    background: linear-gradient(180deg, rgba(127, 206, 236, 0.10) 0%, rgba(255, 255, 255, 1) 60%);
    border: 1px solid rgba(63, 168, 224, 0.4);
    box-shadow: 0 16px 32px rgba(63, 168, 224, 0.12);
  }

  .arch-card--light .arch-card__icon {
    background: rgba(31, 31, 31, 0.04);
    border-color: var(--border-light);
  }

  .arch-card--light.arch-card--featured .arch-card__icon {
    background: rgba(63, 168, 224, 0.08);
    border-color: rgba(63, 168, 224, 0.3);
  }

  .arch-card--light .arch-card__badge {
    color: var(--accent-dark);
    border-color: rgba(63, 168, 224, 0.35);
  }

  .arch-card--light .arch-card__title {
    color: var(--text-dark);
  }

  .arch-card--light .arch-card__desc,
  .arch-card--light .arch-card__list li {
    color: var(--text-dark-secondary);
  }

  .arch-card--light .arch-card__list li::before {
    color: var(--accent-strong);
  }

  .arch-card--light .arch-card__divider {
    background: var(--border-light);
  }
</style>
