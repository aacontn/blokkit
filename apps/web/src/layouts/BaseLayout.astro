---
import {
  DEFAULT_OG_IMAGE,
  ORG_LOGO,
  SITE_LANGUAGE,
  SITE_LOCALE,
  SITE_NAME,
  SITE_TWITTER_HANDLE,
  SITE_URL,
  getRouteSeoByPath,
  toAbsoluteUrl,
  type PageType,
} from "../lib/seo";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  type?: PageType;
  noindex?: boolean;
  keywords?: string[];
  llmSummary?: string;
  publishedTime?: string;
  modifiedTime?: string;
}

const routeSeo = getRouteSeoByPath(Astro.url.pathname);

const {
  title = routeSeo?.title ?? `${SITE_NAME} | Control de celulares`,
  description = routeSeo?.description ?? "BloKKit crea ambientes libres de distracciones con bloqueo Faraday real.",
  canonicalPath = routeSeo?.path ?? Astro.url.pathname,
  image = routeSeo?.image ?? DEFAULT_OG_IMAGE,
  type = routeSeo?.type ?? "website",
  noindex = routeSeo?.noindex ?? false,
  keywords = routeSeo?.keywords ?? [],
  llmSummary = routeSeo?.llmSummary ?? description,
  publishedTime = routeSeo?.publishedTime,
  modifiedTime = routeSeo?.modifiedTime,
} = Astro.props as Props;

const siteBase = Astro.site?.toString() ?? SITE_URL;
const canonicalUrl = toAbsoluteUrl(canonicalPath, siteBase);
const imageUrl = toAbsoluteUrl(image, siteBase);
const robotsContent = noindex
  ? "noindex, nofollow, max-image-preview:large"
  : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1";
const keywordsContent = keywords.join(", ");
const llmsUrl = toAbsoluteUrl("/llms.txt", siteBase);
const llmsFullUrl = toAbsoluteUrl("/llms-full.txt", siteBase);
const isHome = canonicalPath === "/";
const twitterHandle = SITE_TWITTER_HANDLE;
const gtmIdRaw = import.meta.env.PUBLIC_GTM_ID?.trim() ?? "";
const gaIdRaw = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim() ?? "";
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION?.trim() ?? "";
const bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION?.trim() ?? "";
const facebookDomainVerification = import.meta.env.PUBLIC_FACEBOOK_DOMAIN_VERIFICATION?.trim() ?? "";
const hasGtm = /^GTM-[A-Z0-9]+$/.test(gtmIdRaw);
const hasGa = !hasGtm && /^G-[A-Z0-9]+$/.test(gaIdRaw);
const ogImageType = imageUrl.endsWith(".png")
  ? "image/png"
  : imageUrl.endsWith(".webp")
    ? "image/webp"
    : imageUrl.endsWith(".svg")
      ? "image/svg+xml"
      : "image/jpeg";
const ogImageWidth = 1200;
const ogImageHeight = 630;
const organizationProfiles = [
  "https://www.instagram.com/blokkit.cl",
  "https://www.linkedin.com/company/blokkit/",
  "https://x.com/blokkit_cl",
];

const organizationSchema = {
  "@type": "Organization",
  "@id": `${toAbsoluteUrl("/", siteBase)}#organization`,
  name: SITE_NAME,
  url: toAbsoluteUrl("/", siteBase),
  logo: {
    "@type": "ImageObject",
    url: toAbsoluteUrl(ORG_LOGO, siteBase),
  },
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "sales",
      email: "hola@blokkit.cl",
      telephone: "+56 9 9039 9130",
      availableLanguage: ["Spanish"],
    },
  ],
  sameAs: organizationProfiles,
};

const websiteSchema = {
  "@type": "WebSite",
  "@id": `${toAbsoluteUrl("/", siteBase)}#website`,
  url: toAbsoluteUrl("/", siteBase),
  name: SITE_NAME,
  inLanguage: SITE_LANGUAGE,
  publisher: { "@id": `${toAbsoluteUrl("/", siteBase)}#organization` },
};

const webPageSchema: Record<string, unknown> = {
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: title,
  description,
  abstract: llmSummary,
  inLanguage: SITE_LANGUAGE,
  isPartOf: { "@id": `${toAbsoluteUrl("/", siteBase)}#website` },
  about: keywords.map((keyword) => ({ "@type": "Thing", name: keyword })),
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: imageUrl,
  },
};

if (modifiedTime) {
  webPageSchema.dateModified = modifiedTime;
}

const schemaGraph: Record<string, unknown>[] = [organizationSchema, websiteSchema, webPageSchema];

if (type === "article") {
  const articleSchema: Record<string, unknown> = {
    "@type": "Article",
    "@id": `${canonicalUrl}#article`,
    headline: title,
    description,
    abstract: llmSummary,
    url: canonicalUrl,
    image: [imageUrl],
    inLanguage: SITE_LANGUAGE,
    author: { "@id": `${toAbsoluteUrl("/", siteBase)}#organization` },
    publisher: { "@id": `${toAbsoluteUrl("/", siteBase)}#organization` },
    mainEntityOfPage: { "@id": `${canonicalUrl}#webpage` },
    keywords: keywords.join(", "),
  };

  if (publishedTime) {
    articleSchema.datePublished = publishedTime;
  }

  if (modifiedTime) {
    articleSchema.dateModified = modifiedTime;
  }

  schemaGraph.push(articleSchema);
}

const structuredData = {
  "@context": "https://schema.org",
  "@graph": schemaGraph,
};
---
<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={SITE_NAME} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="bingbot" content={robotsContent} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#0D0D0D" />
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    {bingSiteVerification && (
      <meta name="msvalidate.01" content={bingSiteVerification} />
    )}
    {facebookDomainVerification && (
      <meta name="facebook-domain-verification" content={facebookDomainVerification} />
    )}
    {keywordsContent && <meta name="keywords" content={keywordsContent} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es-CL" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={SITE_LOCALE} />
    <meta property="og:type" content={type === "article" ? "article" : "website"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={`${SITE_NAME} - ${title}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:url" content={canonicalUrl} />
    {type === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {type === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {type === "article" && <meta property="article:author" content={SITE_NAME} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    {isHome && (
      <link
        rel="preload"
        as="image"
        href="/images/blokkit-fundas.webp"
        fetchpriority="high"
      />
    )}
    <link rel="alternate" type="text/plain" href={llmsUrl} title="LLM Context" />
    <link rel="alternate" type="text/plain" href={llmsFullUrl} title="LLM Extended Context" />
    {hasGtm && (
      <script is:inline define:vars={{ gtmIdRaw }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f?.parentNode?.insertBefore(j,f);})(window,document,'script','dataLayer',gtmIdRaw);
      </script>
    )}
    {hasGa && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaIdRaw}`}></script>
        <script is:inline define:vars={{ gaIdRaw }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = window.gtag || function(){ window.dataLayer.push(arguments); };
          window.gtag('js', new Date());
          window.gtag('config', gaIdRaw, { anonymize_ip: true, send_page_view: false });
        </script>
      </>
    )}
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <slot name="head" />
    <title>{title}</title>
  </head>
  <body class="antialiased bg-bg-dark text-white overflow-x-hidden">
    {hasGtm && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmIdRaw}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
          title="Google Tag Manager"
        ></iframe>
      </noscript>
    )}
    <slot />
    {(hasGtm || hasGa) && (
      <script is:inline>
        const trackPageView = () => {
          const pageData = {
            page_path: `${window.location.pathname}${window.location.search}`,
            page_location: window.location.href,
            page_title: document.title,
          };

          if (typeof window.gtag === "function") {
            window.gtag("event", "page_view", pageData);
          }

          if (Array.isArray(window.dataLayer)) {
            window.dataLayer.push({
              event: "astro_page_view",
              ...pageData,
            });
          }
        };

        trackPageView();
        document.addEventListener("astro:page-load", trackPageView);
      </script>
    )}
    
    <script>
      const initHeaderScrollState = () => {
        const header = document.getElementById('main-header');
        const headerInner = document.getElementById('header-inner');

        if (!header || !headerInner) {
          return;
        }

        const updateHeader = () => {
          const isScrolled = window.scrollY > 50;
          header.classList.toggle('scrolled', isScrolled);
          headerInner.classList.toggle('scrolled', isScrolled);
        };

        if (header.dataset.scrollBound === 'true') {
          updateHeader();
          return;
        }

        let ticking = false;
        const onScroll = () => {
          if (ticking) {
            return;
          }
          ticking = true;
          requestAnimationFrame(() => {
            updateHeader();
            ticking = false;
          });
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        header.dataset.scrollBound = 'true';
        updateHeader();
      };

      const initProblemStageReveal = () => {
        const problemStage = document.querySelector('.problem-stage[data-reveal]');
        if (!problemStage || problemStage.dataset.revealBound === 'true') {
          return;
        }

        const reveal = () => {
          problemStage.classList.add('revealed');
        };

        if (problemStage.getBoundingClientRect().top <= window.innerHeight * 0.92) {
          reveal();
        }

        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  reveal();
                  observer.unobserve(problemStage);
                }
              });
            },
            { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
          );

          observer.observe(problemStage);
          problemStage.dataset.revealBound = 'true';
          return;
        }

        reveal();
        problemStage.dataset.revealBound = 'true';
      };

      const initPage = () => {
        initHeaderScrollState();
        initProblemStageReveal();
      };

      if (document.readyState !== 'loading') {
        initPage();
      } else {
        document.addEventListener('DOMContentLoaded', initPage, { once: true });
      }

      document.addEventListener('astro:page-load', initPage);
    </script>
    <slot name="scripts" />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  
  /* Smooth scrolling */
  html {
    scroll-behavior: smooth;
  }

  @media (max-width: 768px) {
    html {
      scroll-behavior: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>
