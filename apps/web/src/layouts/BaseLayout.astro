---
import {
  DEFAULT_OG_IMAGE,
  ORG_LOGO,
  SITE_LANGUAGE,
  SITE_LOCALE,
  SITE_NAME,
  SITE_TWITTER_HANDLE,
  SITE_URL,
  getRouteSeoByPath,
  toAbsoluteUrl,
  type PageType,
} from "../lib/seo";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  type?: PageType;
  noindex?: boolean;
  keywords?: string[];
  llmSummary?: string;
  publishedTime?: string;
  modifiedTime?: string;
}

const currentPath = Astro.url.pathname;
const routeSeo = getRouteSeoByPath(currentPath);

const title = Astro.props.title ?? routeSeo?.title ?? SITE_NAME;
const description = Astro.props.description ?? routeSeo?.description ?? "";
const canonicalPath = Astro.props.canonicalPath ?? currentPath;
const image = Astro.props.image ?? routeSeo?.image ?? DEFAULT_OG_IMAGE;
const pageType = Astro.props.type ?? routeSeo?.type ?? "website";
const noindex = Astro.props.noindex ?? routeSeo?.noindex ?? false;
const keywords = Astro.props.keywords ?? routeSeo?.keywords ?? [];
const llmSummary = Astro.props.llmSummary ?? routeSeo?.llmSummary ?? "";
const publishedTime = Astro.props.publishedTime ?? routeSeo?.publishedTime;
const modifiedTime = Astro.props.modifiedTime ?? routeSeo?.modifiedTime;

const canonicalUrl = toAbsoluteUrl(canonicalPath);
const ogImageUrl = toAbsoluteUrl(image);
const gtmId = import.meta.env.PUBLIC_GTM_ID ?? "";
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION ?? "";

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE_NAME,
  url: SITE_URL,
  logo: toAbsoluteUrl(ORG_LOGO),
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+56-9-9039-9130",
    email: "hola@blokkit.cl",
    contactType: "sales",
    areaServed: "CL",
    availableLanguage: "Spanish",
  },
};

const pageSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": pageType === "article" ? "Article" : "WebPage",
  name: title,
  description,
  url: canonicalUrl,
  inLanguage: SITE_LANGUAGE,
  isPartOf: { "@type": "WebSite", name: SITE_NAME, url: SITE_URL },
  ...(publishedTime && { datePublished: publishedTime }),
  ...(modifiedTime && { dateModified: modifiedTime }),
  ...(pageType === "article" && {
    publisher: { "@type": "Organization", name: SITE_NAME, logo: { "@type": "ImageObject", url: toAbsoluteUrl(ORG_LOGO) } },
  }),
};
---

<!doctype html>
<html lang={SITE_LANGUAGE} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="author" content={SITE_NAME} />
    <link rel="alternate" hreflang="es-CL" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- LLM/GEO -->
    {llmSummary && <meta name="llm-summary" content={llmSummary} />}
    <link rel="llms" href="/llms.txt" type="text/plain" />

    <!-- GSC Verification -->
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}

    <!-- Open Graph -->
    <meta property="og:type" content={pageType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={SITE_LOCALE} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE_TWITTER_HANDLE} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

    <!-- Google Tag Manager -->
    {gtmId && (
      <script set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','${gtmId}');`} />
    )}

    <!-- Styles -->
    <style is:global>
      @import "../styles/tokens.css";
      @import "../styles/reset.css";
      @import "../styles/global.css";
      @import "../styles/animations.css";
    </style>

    <!-- Astro ViewTransitions -->
    <slot name="head" />
  </head>
  <body>
    <!-- GTM noscript -->
    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}

    <!-- Noise texture overlay -->
    <div class="noise-overlay" aria-hidden="true"></div>

    <!-- Scroll progress bar -->
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>

    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />

    <!-- Scroll progress + Lenis -->
    <script>
      import Lenis from "lenis";

      // Lenis smooth scroll
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        touchMultiplier: 1.5,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Scroll progress bar
      const progressBar = document.getElementById("scroll-progress");
      if (progressBar) {
        window.addEventListener("scroll", () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          progressBar.style.width = `${progress}%`;
        }, { passive: true });
      }

      // Cleanup on page transitions
      document.addEventListener("astro:before-swap", () => {
        lenis.destroy();
      });
    </script>

    <!-- Cal element-click embed code begins -->
    <script type="text/javascript">
      (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
    Cal("init", "30min", {origin:"https://app.cal.com"});

      Cal.ns["30min"]("ui", {
        "hideEventTypeDetails": false,
        "layout": "month_view",
        "styles": {
          "branding": { "brandColor": "#3CC8D0" }
        },
        "cssVarsPerTheme": {
          "light": {
            "cal-border-booker": "1px solid #e5e7eb",
            "cal-border-booker-width": "1px"
          }
        }
      });
    </script>
    <style>
      /* Cal.com modal overrides */
      :root {
        --cal-brand-color: #3CC8D0;
      }
      /* Hide Cal.com branding watermark */
      [data-cal-namespace] a[href*="cal.com"],
      .powered-by-cal,
      div[class*="poweredBy"],
      a[data-testid="powered-by-cal"] {
        display: none !important;
      }
      /* Give the modal more inner padding and rounded corners */
      cal-modal-box,
      [data-cal-namespace="30min"] > div {
        border-radius: 20px !important;
        overflow: hidden;
      }
    </style>
    <!-- Cal element-click embed code ends -->
  </body>
</html>
