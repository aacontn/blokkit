---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import PageHero from "../components/PageHero.astro";

const sections = [
  {
    title: "1. Aceptación de los términos",
    paragraphs: [
      'Al acceder y utilizar el sitio web de BloKKit SpA ("BloKKit"), usted acepta estos términos y condiciones en su totalidad. Si no está de acuerdo con alguno de estos términos, le solicitamos no utilizar nuestro sitio web ni nuestros servicios.',
    ],
  },
  {
    title: "2. Descripción del servicio",
    paragraphs: ["BloKKit ofrece un ecosistema de control de dispositivos móviles compuesto por:"],
    list: [
      { bold: "Funda BloKKit:", text: "dispositivo de bloqueo físico para teléfonos celulares" },
      { bold: "Dock de Desbloqueo:", text: "estación autorizada para apertura controlada" },
      { bold: "Plataforma Digital:", text: "software de gestión, monitoreo y reportería" },
    ],
    after: "Los servicios se proveen bajo modalidad de contrato institucional, sujeto a propuesta específica según el contexto de cada cliente.",
  },
  {
    title: "3. Uso del sitio web",
    paragraphs: ["El contenido de este sitio web es de carácter informativo y comercial. Queda prohibido:"],
    list: [
      { text: "Reproducir, distribuir o modificar el contenido sin autorización" },
      { text: "Utilizar el sitio para fines ilegales o no autorizados" },
      { text: "Intentar acceder a áreas restringidas del sitio o sus sistemas" },
      { text: "Enviar información falsa a través de nuestros formularios" },
    ],
  },
  {
    title: "4. Propiedad intelectual",
    paragraphs: [
      "Todos los contenidos del sitio web —incluyendo pero no limitados a textos, gráficos, logotipos, íconos, imágenes, clips de audio, descargas digitales y compilaciones de datos— son propiedad de BloKKit SpA o de sus proveedores de contenido y están protegidos por las leyes chilenas e internacionales de propiedad intelectual.",
    ],
  },
  {
    title: "5. Limitación de responsabilidad",
    paragraphs: [
      'BloKKit no será responsable por daños directos, indirectos, incidentales, especiales o consecuentes que resulten del uso o la imposibilidad de uso del sitio web o los servicios. La información proporcionada en el sitio web se ofrece "tal cual" sin garantías de ningún tipo.',
    ],
  },
  {
    title: "6. Relaciones contractuales",
    paragraphs: [
      "La contratación de servicios BloKKit se formaliza mediante acuerdos específicos entre BloKKit SpA y cada institución cliente. Estos términos y condiciones no constituyen un contrato de servicio y no reemplazan los acuerdos contractuales específicos.",
    ],
  },
  {
    title: "7. Modificaciones",
    paragraphs: [
      "BloKKit se reserva el derecho de modificar estos términos y condiciones en cualquier momento. Las modificaciones entrarán en vigor inmediatamente después de su publicación en el sitio web. El uso continuado del sitio después de la publicación de cambios constituirá la aceptación de dichos cambios.",
    ],
  },
  {
    title: "8. Ley aplicable y jurisdicción",
    paragraphs: [
      "Estos términos y condiciones se rigen por las leyes de la República de Chile. Cualquier disputa relacionada con estos términos será sometida a la jurisdicción de los tribunales ordinarios de Santiago de Chile.",
    ],
  },
  {
    title: "9. Contacto",
    paragraphs: ["Para consultas sobre estos términos y condiciones:"],
    afterHtml: '<strong>BloKKit SpA</strong><br/>Email: <a href="mailto:contacto@blokkit.cl">contacto@blokkit.cl</a><br/>Santiago, Chile',
  },
];
---

<BaseLayout>
  <Header slot="header" />

  <PageHero
    label="Legal"
    title="Términos y"
    accent="Condiciones"
    subtitle="Última actualización: enero 2025"
  />

  <section class="section--lg section--light-alt">
    <div class="container legal-container">
      {sections.map((s, i) => (
        <ScrollReveal client:visible delay={i * 0.05}>
          <div class="legal-card">
            <h2 class="legal-card__title">{s.title}</h2>
            {s.paragraphs?.map((p) => <p class="legal-card__text">{p}</p>)}
            {s.list && (
              <ul class="legal-card__list">
                {s.list.map((item) => (
                  <li>
                    {item.bold && <strong>{item.bold}</strong>} {item.text}
                  </li>
                ))}
              </ul>
            )}
            {s.after && <p class="legal-card__text">{s.after}</p>}
            {s.afterHtml && <p class="legal-card__text" set:html={s.afterHtml} />}
          </div>
        </ScrollReveal>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .legal-container { max-width: 820px; margin-inline: auto; display: flex; flex-direction: column; gap: var(--space-6); }

  .legal-card {
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .legal-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .legal-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-4);
  }

  .legal-card__text {
    color: var(--text-dark-secondary);
    line-height: 1.75;
    font-size: var(--text-base);
    margin-bottom: var(--space-3);
  }
  .legal-card__text:last-child { margin-bottom: 0; }

  .legal-card__text :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }
  .legal-card__text :global(a:hover) { opacity: 0.8; }

  .legal-card__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
  }
  .legal-card__list li {
    color: var(--text-dark-secondary);
    line-height: 1.7;
    font-size: var(--text-base);
  }
  .legal-card__list li::marker {
    color: var(--accent);
  }
  .legal-card__list li :global(strong) {
    color: var(--text-dark);
  }
</style>
