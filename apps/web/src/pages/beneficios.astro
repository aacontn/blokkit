---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const pageTitle = "Beneficios | BloKKit - Ventajas por Sector";
const pageDescription = "Descubre los beneficios de BloKKit para colegios, universidades, empresas, gobierno, policías, justicia y eventos. Mejora el enfoque y productividad en tu organización.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header />
  
  <main>
    <!-- PAGE HERO -->
    <section class="page-hero section-tone-dark">
      <div class="page-hero-bg">
        <div class="gradient-orb orb-1"></div>
        <div class="gradient-orb orb-2"></div>
      </div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
        <span class="page-label" data-reveal>Beneficios</span>
        <h1 class="page-title" data-reveal style="--delay: 100ms;">
          Beneficios para<br />
          <span class="text-accent">Cada Sector</span>
        </h1>
        <p class="page-subtitle" data-reveal style="--delay: 200ms;">
          Cada institución tiene necesidades únicas. Descubre cómo BloKKit
          se adapta a tu contexto específico.
        </p>
      </div>
    </section>

    <!-- EDUCATION BENEFITS -->
    <section class="benefit-section section-tone-slate" id="educacion">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="benefit-grid">
          <div class="benefit-content" data-reveal>
            <span class="benefit-label">Educación</span>
            <h2 class="benefit-title">
              Colegios y<br />
              <span class="text-accent">Universidades</span>
            </h2>
            <p class="benefit-description">
              Las distracciones digitales son el mayor obstáculo para el aprendizaje efectivo. 
              BloKKit permite crear ambientes de estudio óptimos sin generar conflictos por 
              la confiscación de dispositivos.
            </p>
            
            <ul class="benefit-list">
              <li>
                <span class="benefit-icon">📈</span>
                <div>
                  <strong>ROI administrativo medible</strong>
                  <span>Menos tiempo dedicado a gestionar incidentes con teléfonos y conflictos digitales.</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">🧘</span>
                <div>
                  <strong>Reducción del tiempo administrativo</strong>
                  <span>Menor carga en convivencia, inspección y equipos directivos por casos de ciberacoso.</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">⏱️</span>
                <div>
                  <strong>ROI operacional</strong>
                  <span>Reducción del 33% en suspensiones estudiantiles con implementación institucional.</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">👨‍👩‍👧</span>
                <div>
                  <strong>ROI académico</strong>
                  <span>Más horas pedagógicas recuperadas y mejor continuidad del aprendizaje por curso.</span>
                </div>
              </li>
            </ul>
          </div>
          
          <div class="benefit-visual" data-reveal style="--delay: 150ms;">
            <div class="stat-card">
              <span class="stat-big">211h</span>
              <span class="stat-desc">horas pedagógicas recuperadas por curso (8-10 min por clase)</span>
            </div>
            <div class="stat-card">
              <span class="stat-big">-33%</span>
              <span class="stat-desc">en suspensiones estudiantiles con estándar operativo</span>
            </div>
            <div class="stat-card highlight">
              <span class="stat-big">-43-46%</span>
              <span class="stat-desc">en incidentes de bullying en entornos con protocolo institucional</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BUSINESS BENEFITS -->
    <section class="benefit-section alt section-tone-dark" id="empresas">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="benefit-grid reverse">
          <div class="benefit-visual" data-reveal>
            <div class="stat-card">
              <span class="stat-big">8-12 min</span>
              <span class="stat-desc">de pérdida efectiva en reuniones de 60 minutos cuando no hay protocolo digital</span>
            </div>
            <div class="stat-card">
              <span class="stat-big">-15-25%</span>
              <span class="stat-desc">menos interrupciones en bloques críticos al aplicar estándar de resguardo</span>
            </div>
            <div class="stat-card highlight">
              <span class="stat-big">&lt;1%</span>
              <span class="stat-desc">del presupuesto operativo anual estimado para implementar el sistema en equipos medianos</span>
            </div>
          </div>
          
          <div class="benefit-content" data-reveal style="--delay: 150ms;">
            <span class="benefit-label">Corporativo</span>
            <h2 class="benefit-title">
              Empresas y<br />
              <span class="text-accent">Oficinas</span>
            </h2>
            <p class="benefit-description">
              Las reuniones productivas y los espacios de trabajo enfocado 
              son esenciales para el rendimiento empresarial. BloKKit crea 
              zonas libres de distracciones para momentos críticos.
            </p>
            
            <ul class="benefit-list">
              <li>
                <span class="benefit-icon">🎯</span>
                <div>
                  <strong>Reuniones con foco real</strong>
                  <span>Menos desvíos y mayor calidad de decisión en comités, directorios y sesiones clave.</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">🔒</span>
                <div>
                  <strong>Resguardo de información sensible</strong>
                  <span>Protocolos claros para salas críticas, visitas externas y conversaciones confidenciales.</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">💰</span>
                <div>
                  <strong>ROI operacional visible</strong>
                  <span>Menos fricción de coordinación y mejor continuidad en ejecución de tareas críticas.</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">🏢</span>
                <div>
                  <strong>Operación estándar por área</strong>
                  <span>Un mismo criterio para liderazgo, operaciones, RR.HH. y áreas de soporte.</span>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- GOVERNMENT & POLICE BENEFITS -->
    <section class="benefit-section section-tone-slate" id="gobierno-policias">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="benefit-grid">
          <div class="benefit-content" data-reveal>
            <span class="benefit-label">Gobierno, Policías y Justicia</span>
            <h2 class="benefit-title">
              Congreso, juzgados y<br />
              <span class="text-accent">cadena de custodia</span>
            </h2>
            <p class="benefit-description">
              En reuniones sensibles y procedimientos legales, la custodia de dispositivos no puede quedar al criterio individual.
              BloKKit permite ejecutar protocolos de ingreso, resguardo y devolución con trazabilidad institucional.
            </p>
            
            <ul class="benefit-list">
              <li>
                <span class="benefit-icon">🛡️</span>
                <div>
                  <strong>Cadena de custodia clara</strong>
                  <span>Responsables y etapas definidos de principio a fin</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">🧾</span>
                <div>
                  <strong>Trazabilidad formal</strong>
                  <span>Registro de excepciones, aperturas y devoluciones</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">⚖️</span>
                <div>
                  <strong>Resguardo legal</strong>
                  <span>Menor riesgo en congreso, audiencias y diligencias</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">👮</span>
                <div>
                  <strong>Operación sin fricción</strong>
                  <span>Protocolo ejecutable en recintos, operativos y reuniones sensibles</span>
                </div>
              </li>
            </ul>
          </div>
          
          <div class="benefit-visual" data-reveal style="--delay: 150ms;">
            <div class="stat-card">
              <span class="stat-big">100%</span>
              <span class="stat-desc">trazabilidad de custodia documentada por protocolo</span>
            </div>
            <div class="stat-card">
              <span class="stat-big">&lt;3s</span>
              <span class="stat-desc">desbloqueo con personal autorizado</span>
            </div>
            <div class="stat-card highlight">
              <span class="stat-big">+control</span>
              <span class="stat-desc">menos incidentes por manejo informal en procedimientos sensibles</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- EVENTS BENEFITS -->
    <section class="benefit-section section-tone-dark" id="eventos">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="benefit-grid">
          <div class="benefit-content" data-reveal>
            <span class="benefit-label">Entretenimiento</span>
            <h2 class="benefit-title">
              Eventos y<br />
              <span class="text-accent">Espectáculos</span>
            </h2>
            <p class="benefit-description">
              Protege la propiedad intelectual de artistas y creadores. 
              Crea experiencias inmersivas donde el público está presente 
              de verdad, sin pantallas de por medio.
            </p>
            
            <ul class="benefit-list">
              <li>
                <span class="benefit-icon">🎭</span>
                <div>
                  <strong>Protección de contenido</strong>
                  <span>Sin grabaciones piratas de shows y presentaciones</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">✨</span>
                <div>
                  <strong>Experiencia inmersiva</strong>
                  <span>Público 100% presente en el momento</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">📸</span>
                <div>
                  <strong>Momentos designados</strong>
                  <span>Desbloqueo controlado para fotos oficiales</span>
                </div>
              </li>
              <li>
                <span class="benefit-icon">🎪</span>
                <div>
                  <strong>Diferenciación premium</strong>
                  <span>Experiencia exclusiva que destaca tu evento</span>
                </div>
              </li>
            </ul>
          </div>
          
          <div class="benefit-visual" data-reveal style="--delay: 150ms;">
            <div class="stat-card">
              <span class="stat-big">95%</span>
              <span class="stat-desc">del público usa el celular durante shows</span>
            </div>
            <div class="stat-card">
              <span class="stat-big">72hrs</span>
              <span class="stat-desc">antes de que contenido pirata aparezca online</span>
            </div>
            <div class="stat-card highlight">
              <span class="stat-big">4.8★</span>
              <span class="stat-desc">satisfacción de asistentes en eventos sin celulares</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="benefit-slate-flow">
      <!-- SERVICES BENEFITS -->
      <section class="benefit-section alt section-tone-slate" id="servicios">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
          <div class="benefit-grid reverse">
            <div class="benefit-visual" data-reveal>
              <div class="stat-card">
                <span class="stat-big">-20-35%</span>
                <span class="stat-desc">menos interrupciones en puntos de atención con protocolo activo</span>
              </div>
              <div class="stat-card">
                <span class="stat-big">&lt;3s</span>
                <span class="stat-desc">desbloqueo autorizado cuando el proceso requiere excepción</span>
              </div>
              <div class="stat-card highlight">
                <span class="stat-big">100%</span>
                <span class="stat-desc">trazabilidad de aperturas y devoluciones en cada operación</span>
              </div>
            </div>
            
            <div class="benefit-content" data-reveal style="--delay: 150ms;">
              <span class="benefit-label">Servicios</span>
              <h2 class="benefit-title">
                Atención y<br />
                <span class="text-accent">Servicios Sensibles</span>
              </h2>
              <p class="benefit-description">
                En operaciones de servicio con alta exposición, BloKKit ayuda a
                ejecutar un estándar simple de foco y resguardo sin frenar la
                atención al usuario.
              </p>
              
              <ul class="benefit-list">
                <li>
                  <span class="benefit-icon">🧭</span>
                  <div>
                    <strong>Protocolo claro por punto de atención</strong>
                    <span>Mismo criterio para recepción, atención, caja y soporte en terreno.</span>
                  </div>
                </li>
                <li>
                  <span class="benefit-icon">🧑‍💼</span>
                  <div>
                    <strong>Atención más enfocada y profesional</strong>
                    <span>Menos quiebres de conversación y mayor continuidad con clientes y usuarios.</span>
                  </div>
                </li>
                <li>
                  <span class="benefit-icon">⚡</span>
                  <div>
                    <strong>Excepciones autorizadas sin fricción</strong>
                    <span>Apertura rápida cuando corresponde, con responsable y registro asociado.</span>
                  </div>
                </li>
                <li>
                  <span class="benefit-icon">📋</span>
                  <div>
                    <strong>Escalable por sucursal y turno</strong>
                    <span>Implementación gradual con trazabilidad operativa para supervisión central.</span>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="final-cta section-tone-slate">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
          <div class="final-cta-card text-center" data-reveal>
            <h2 class="final-cta-title">
              ¿Qué sector te<br />
              interesa más?
            </h2>
            <p class="final-cta-subtitle" data-reveal style="--delay: 100ms;">
              Conversemos sobre cómo BloKKit puede adaptarse a las necesidades 
              específicas de tu organización.
            </p>
            <div class="final-cta-buttons" data-reveal style="--delay: 200ms;">
              <a href="/contacto" class="btn-primary-large">
                Agendar Demo Personalizada
              </a>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  /* ==================== HERO OVERRIDES (BLACK + CYAN) ==================== */
  .page-hero.section-tone-dark {
    background-color: #080808;
    background-image:
      linear-gradient(rgba(0, 194, 209, 0.052) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 194, 209, 0.052) 1px, transparent 1px),
      radial-gradient(980px 380px at 14% -10%, rgba(0, 194, 209, 0.24) 0%, transparent 62%),
      radial-gradient(880px 340px at 84% 12%, rgba(0, 194, 209, 0.12) 0%, transparent 64%),
      linear-gradient(180deg, #121212 0%, #090909 56%, #060606 100%);
    background-size: 64px 64px, 64px 64px, auto, auto, auto;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .page-hero.section-tone-dark .orb-1 {
    background: radial-gradient(circle, rgba(0, 194, 209, 0.3) 0%, transparent 72%);
    opacity: 0.52;
  }

  .page-hero.section-tone-dark .orb-2 {
    background: radial-gradient(circle, rgba(0, 194, 209, 0.2) 0%, transparent 72%);
    opacity: 0.44;
  }

  .page-hero.section-tone-dark .page-label {
    border-color: rgba(62, 224, 240, 0.36);
    background: rgba(4, 10, 12, 0.7);
    color: #67e8f9;
  }

  .page-hero.section-tone-dark .page-subtitle {
    color: rgba(226, 232, 240, 0.82) !important;
  }

  /* ==================== BENEFIT SECTIONS ==================== */
  .benefit-section {
    padding: 8rem 0;
  }
  
  .benefit-section.alt {
    background: transparent;
  }

  .benefit-section.alt.section-tone-dark {
    background-color: #090909;
    background-image:
      linear-gradient(rgba(0, 194, 209, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 194, 209, 0.055) 1px, transparent 1px),
      radial-gradient(980px 420px at 14% -12%, rgba(0, 194, 209, 0.24), transparent 60%),
      radial-gradient(820px 340px at 86% 10%, rgba(0, 194, 209, 0.14), transparent 62%),
      linear-gradient(180deg, #121212 0%, #0b0b0b 52%, #070707 100%);
    background-size: 64px 64px, 64px 64px, auto, auto, auto;
    background-position: 0 0, 0 0, center, center, center;
  }

  .benefit-section.section-tone-slate {
    background-color: #dce5ef;
    background-image:
      radial-gradient(820px 300px at 20% 16%, rgba(8, 145, 178, 0.12) 0%, transparent 68%),
      radial-gradient(760px 280px at 84% 86%, rgba(14, 116, 144, 0.1) 0%, transparent 70%),
      linear-gradient(180deg, #dce5ef 0%, #e6edf5 100%);
    border-top: 1px solid rgba(148, 163, 184, 0.2);
    border-bottom: 1px solid rgba(148, 163, 184, 0.2);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22), inset 0 -1px 0 rgba(255, 255, 255, 0.22);
  }

  .benefit-section.section-tone-dark {
    position: relative;
    background-color: #090909;
    background-image:
      linear-gradient(rgba(0, 194, 209, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 194, 209, 0.055) 1px, transparent 1px),
      radial-gradient(980px 420px at 14% -12%, rgba(0, 194, 209, 0.24), transparent 60%),
      radial-gradient(820px 340px at 86% 10%, rgba(0, 194, 209, 0.14), transparent 62%),
      linear-gradient(180deg, #121212 0%, #0b0b0b 52%, #070707 100%);
    background-size: 64px 64px, 64px 64px, auto, auto, auto;
    background-position: 0 0, 0 0, center, center, center;
  }

  .benefit-section.section-tone-dark::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(700px 260px at 16% 8%, rgba(0, 194, 209, 0.12) 0%, transparent 72%),
      radial-gradient(620px 220px at 84% 92%, rgba(0, 194, 209, 0.08) 0%, transparent 74%);
    z-index: 0;
  }

  .benefit-section .max-w-7xl {
    position: relative;
    z-index: 1;
  }
  
  .benefit-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .benefit-grid.reverse {
    grid-template-columns: 1fr 1.2fr;
  }

  .benefit-slate-flow {
    background-color: #dce5ef;
    background-image:
      radial-gradient(820px 300px at 20% 16%, rgba(8, 145, 178, 0.12) 0%, transparent 68%),
      radial-gradient(760px 280px at 84% 86%, rgba(14, 116, 144, 0.1) 0%, transparent 70%),
      linear-gradient(180deg, #dce5ef 0%, #e6edf5 100%);
    border-top: 1px solid rgba(148, 163, 184, 0.2);
    border-bottom: 1px solid rgba(148, 163, 184, 0.2);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22), inset 0 -1px 0 rgba(255, 255, 255, 0.22);
  }

  .benefit-slate-flow > .section-tone-slate {
    background: transparent !important;
    border-top: 0 !important;
    border-bottom: 0 !important;
    box-shadow: none !important;
  }
  
  .benefit-label {
    display: inline-flex;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #67e8f9;
    padding: 0.48rem 0.92rem;
    background: rgba(0, 194, 209, 0.12);
    border: 1px solid rgba(34, 211, 238, 0.28);
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }
  
  .benefit-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3.5rem;
    line-height: 1;
    margin-bottom: 1.5rem;
  }
  
  .benefit-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(226, 232, 240, 0.8);
    margin-bottom: 2rem;
    max-width: 64ch;
  }
  
  .benefit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  
  .benefit-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 0.88rem 0.92rem;
    border-radius: 0.92rem;
    border: 1px solid rgba(34, 211, 238, 0.12);
    background: linear-gradient(160deg, rgba(18, 18, 18, 0.56) 0%, rgba(10, 10, 10, 0.4) 100%);
    transition: transform 0.24s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.2s ease, background 0.2s ease;
  }

  .benefit-list li:hover {
    transform: translateX(4px);
    border-color: rgba(34, 211, 238, 0.26);
    background: linear-gradient(160deg, rgba(24, 24, 24, 0.66) 0%, rgba(12, 12, 12, 0.5) 100%);
  }
  
  .benefit-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
    width: 2.05rem;
    height: 2.05rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.68rem;
    background: rgba(0, 194, 209, 0.14);
    border: 1px solid rgba(34, 211, 238, 0.24);
  }
  
  .benefit-list li div {
    display: flex;
    flex-direction: column;
  }
  
  .benefit-list li strong {
    font-size: 1rem;
    font-weight: 700;
    color: #f8fafc;
    margin-bottom: 0.25rem;
  }
  
  .benefit-list li span {
    font-size: 0.875rem;
    color: rgba(226, 232, 240, 0.72);
  }
  
  /* Stats Cards */
  .benefit-visual {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .stat-card {
    padding: 1.5rem 2rem;
    background: linear-gradient(160deg, rgba(16, 16, 16, 0.92) 0%, rgba(8, 8, 8, 0.88) 100%);
    border: 1px solid rgba(34, 211, 238, 0.16);
    border-radius: 16px;
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.24s ease, box-shadow 0.24s ease, background 0.24s ease;
    box-shadow: 0 12px 26px rgba(0, 0, 0, 0.24);
  }
  
  .stat-card:hover {
    background: linear-gradient(160deg, rgba(20, 20, 20, 0.94) 0%, rgba(10, 10, 10, 0.9) 100%);
    border-color: rgba(34, 211, 238, 0.34);
    transform: translateX(8px);
    box-shadow: 0 16px 30px rgba(0, 0, 0, 0.3);
  }
  
  .stat-card.highlight {
    background:
      radial-gradient(220px 110px at 16% 10%, rgba(0, 194, 209, 0.14) 0%, transparent 72%),
      linear-gradient(160deg, rgba(16, 16, 16, 0.94) 0%, rgba(8, 8, 8, 0.9) 100%);
    border-color: rgba(0, 194, 209, 0.34);
  }
  
  .stat-big {
    display: block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
