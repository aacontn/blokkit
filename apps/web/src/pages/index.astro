    padding-top: 0.2rem;
    padding-left: 0.1rem;
  }

  .ley-brief-row-points {
    grid-area: points;
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.58rem;
    padding-top: 0.18rem;
    padding-left: 1.05rem;
    margin-left: 0.18rem;
    border-left: 1px solid rgba(148, 163, 184, 0.18);
  }

  .ley-brief-row-points li {
    margin: 0;
    color: rgba(226, 232, 240, 0.9);
    font-size: 0.88rem;
    line-height: 1.38;
    padding-left: 1.18rem;
    position: relative;
  }

  .ley-brief-row-points li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.28rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: #34d6e6;
    box-shadow: 0 0 0 2px rgba(52, 214, 230, 0.16);
  }

  .ley-brief-footer {
    border-top: 0;
    padding-top: 1.65rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    max-width: 1080px;
    margin: 0 auto;
    width: 100%;
    margin-bottom: 0;
  }

  .ley-brief-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.95rem;
    flex-wrap: wrap;
  }

  .ley-brief-switch {
    width: min(720px, 100%);
  }

  .ley-brief-switch .pill-option {
    padding: 1rem 1.2rem;
  }

  .ley-brief-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    white-space: nowrap;
    line-height: 1.05;
