    min-width: 270px;
  }

  .ley-brief-btn:hover {
    transform: translateY(-1px) scale(1.01);
    box-shadow: 0 14px 28px rgba(2, 6, 23, 0.34);
  }

  .ley-sources {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgba(226, 232, 240, 0.8);
