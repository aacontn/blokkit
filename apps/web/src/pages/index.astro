    color: #8ee8f1;
    font-weight: 500;
  }

  .ley-brief-alert-sub {
    margin: 0;
    font-size: 0.91rem;
    line-height: 1.4;
    color: rgba(226, 232, 240, 0.9);
  }

  .ley-brief-track {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    position: relative;
    padding-top: 0.75rem;
    max-width: 1080px;
    margin: 0 auto;
    border-top: 1px solid rgba(148, 163, 184, 0.18);
    border-bottom: 1px solid rgba(148, 163, 184, 0.18);
  }

  .ley-brief-row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(260px, 0.9fr) minmax(300px, 1.25fr) minmax(250px, 0.95fr);
    grid-template-areas: "main desc points";
    gap: 1.15rem;
    align-items: start;
    padding: 1.2rem 0.1rem;
    border-top: 1px solid rgba(148, 163, 184, 0.16);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.26s ease, background 0.26s ease, box-shadow 0.26s ease;
    will-change: transform;
  }

  .ley-brief-row:first-child {
    border-top: 0;
  }

  .ley-brief-row:hover {
    transform: translateY(-2px);
    border-color: rgba(148, 163, 184, 0.22);
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
    box-shadow: 0 12px 24px rgba(2, 6, 23, 0.22);
  }

  .ley-brief-row-main {
    grid-area: main;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.92rem;
    align-items: start;
    padding-right: 0.28rem;
  }

  .ley-brief-row-index {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.15rem;
    line-height: 1;
    letter-spacing: 0.06em;
    color: rgba(125, 211, 252, 0.52);
    margin-top: 0.02rem;
  }

  .ley-brief-row-title-wrap {
    display: grid;
    gap: 0.34rem;
    align-content: start;
  }

  .ley-brief-row-title-wrap .ley-brief-item-tag {
    margin-left: 0;
    justify-self: start;
  }

  .ley-brief-item-title {
    margin: 0;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.58rem;
    line-height: 1;
    letter-spacing: 0.01em;
    color: #f8fafc;
  }

  .ley-brief-item-tag {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-radius: 999px;
    padding: 0.21rem 0.52rem;
    border: 1px solid rgba(56, 189, 248, 0.28);
    color: rgba(186, 230, 253, 0.9);
