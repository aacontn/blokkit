    margin-right: auto;
  }

  .ley-brief-alert {
    max-width: 1000px;
    margin: 0.55rem auto 1.05rem;
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.24);
    background: linear-gradient(145deg, rgba(28, 28, 28, 0.78) 0%, rgba(14, 14, 14, 0.72) 100%);
    backdrop-filter: blur(9px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 14px 30px rgba(2, 6, 23, 0.36);
    padding: 1.08rem 1.12rem;
  }

  .ley-brief-alert-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.52rem;
  }

  .ley-brief-alert-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(167, 243, 252, 0.9);
    font-weight: 800;
  }

  .ley-brief-alert-date {
    font-size: 0.75rem;
    border-radius: 999px;
    padding: 0.3rem 0.62rem;
    border: 1px solid rgba(148, 163, 184, 0.3);
    color: rgba(226, 232, 240, 0.9);
    background: rgba(24, 24, 24, 0.62);
    font-weight: 700;
  }

  .ley-brief-alert-main {
    margin: 0 0 0.3rem;
    font-size: 1.08rem;
    line-height: 1.33;
    color: #f8fafc;
    font-weight: 800;
