    font-size: 0.98rem;
    line-height: 1.42;
  }

  .ley-evidencia-section .ley-risk-card {
    margin-top: 0.72rem;
    padding: 0.9rem 1rem;
    border-radius: 0.94rem;
    border: 1px solid rgba(148, 163, 184, 0.24);
