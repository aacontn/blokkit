		  /* ==================== BUTTONS ==================== */
		  .pill-switch {
		    --pill-pad: 4px;
		    --pill-i: 0;
		    --pill-track-bg: rgba(255, 255, 255, 0.08);
		    --pill-track-border: rgba(255, 255, 255, 0.18);
		    --pill-active-bg: linear-gradient(135deg, #00C2D1 0%, #00A8B5 100%);
		    --pill-active-fg: #ffffff;
		    --pill-inactive-fg: rgba(255, 255, 255, 0.82);
		    position: relative;
		    display: grid;
		    grid-template-columns: 1fr 1fr;
		    align-items: stretch;
		    padding: var(--pill-pad);
		    border-radius: 999px;
		    background: var(--pill-track-bg);
		    border: 1px solid var(--pill-track-border);
		    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
		    overflow: hidden;
		  }

		  .pill-switch::before {
		    content: '';
		    position: absolute;
		    top: var(--pill-pad);
		    bottom: var(--pill-pad);
		    left: var(--pill-pad);
		    width: calc((100% - (var(--pill-pad) * 2)) / 2);
		    border-radius: 999px;
		    background: var(--pill-active-bg);
		    box-shadow: 0 18px 45px rgba(0, 194, 209, 0.18);
		    transform: translateX(calc(var(--pill-i) * 100%));
		    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
		  }

		  .pill-option {
		    position: relative;
		    z-index: 1;
		    border: 0;
		    background: transparent;
		    color: var(--pill-inactive-fg);
		    font-weight: 800;
		    font-size: 0.9375rem;
		    padding: 1rem 1.2rem;
		    display: inline-flex;
		    align-items: center;
		    justify-content: center;
		    gap: 0.55rem;
		    border-radius: 999px;
		    cursor: pointer;
		    text-decoration: none;
		    white-space: nowrap;
		    -webkit-tap-highlight-color: transparent;
		  }

		  .pill-option:focus-visible {
		    outline: 3px solid rgba(0, 194, 209, 0.35);
		    outline-offset: 3px;
		  }

		  /* Default: left option is the active one */
		  .pill-switch .pill-option:first-child {
		    color: var(--pill-active-fg);
		  }

		  .pill-switch:has(.pill-option:nth-child(2):hover),
		  .pill-switch:has(.pill-option:nth-child(2):focus-visible) {
		    --pill-i: 1;
		  }

		  .pill-switch:has(.pill-option:nth-child(2):hover) .pill-option:first-child,
		  .pill-switch:has(.pill-option:nth-child(2):focus-visible) .pill-option:first-child {
		    color: var(--pill-inactive-fg);
		  }

		  .pill-switch:has(.pill-option:nth-child(2):hover) .pill-option:nth-child(2),
		  .pill-switch:has(.pill-option:nth-child(2):focus-visible) .pill-option:nth-child(2) {
		    color: var(--pill-active-fg);
		  }

		  .pill-switch--dark {
		    --pill-track-bg: rgba(255, 255, 255, 0.06);
		    --pill-track-border: rgba(255, 255, 255, 0.18);
		    --pill-inactive-fg: rgba(255, 255, 255, 0.82);
		  }

		  .pill-switch--light {
		    --pill-track-bg: rgba(255, 255, 255, 0.92);
		    --pill-track-border: rgba(15, 23, 42, 0.14);
		    --pill-inactive-fg: rgba(15, 23, 42, 0.78);
		    box-shadow: 0 16px 40px rgba(2, 6, 23, 0.10);
		  }

		  .pill-switch--light::before {
		    box-shadow: 0 18px 45px rgba(0, 194, 209, 0.16);
		  }

		  .pill-switch--lg .pill-option {
		    padding: 1.05rem 1.45rem;
		    font-size: 0.95rem;
		  }

		  @media (prefers-reduced-motion: reduce) {
		    .pill-switch::before {
		      transition: none;
		    }
		  }

