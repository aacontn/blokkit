  /* ==================== CÓMO FUNCIONA SECTION ==================== */
  .como-funciona-section {
    padding: 4.25rem 0 5.6rem;
    background: transparent;
    position: relative;
  }

  .como-funciona-section::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 45%;
    width: min(1080px, 92vw);
    height: 420px;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(360px 210px at 20% 72%, rgba(14, 116, 144, 0.12) 0%, transparent 72%),
      radial-gradient(330px 190px at 80% 22%, rgba(8, 145, 178, 0.1) 0%, transparent 72%);
    pointer-events: none;
    z-index: 0;
  }
  
  .como-header {
    text-align: center;
    margin-bottom: 1.45rem;
    max-width: 68ch;
    margin-inline: auto;
    position: relative;
