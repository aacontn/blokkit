  }

  .ley-cta-actions {
    display: flex;
    gap: 0.95rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .ley-btn-secondary {
    border-color: rgba(255, 255, 255, 0.3);
    color: rgba(241, 245, 249, 0.96);
    padding: 1rem 1.4rem;
  }

  .ley-risk-card {
    margin-top: 0.95rem;
    padding: 1rem 0 0.2rem 1rem;
    border-radius: 0;
    border: none;
    border-left: 3px solid rgba(0, 194, 209, 0.84);
    background: transparent;
  }

  .ley-risk-title {
    margin: 0 0 0.45rem;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    line-height: 0.95;
    color: #bae6fd;
  }

  .ley-risk-desc {
    margin: 0;
    color: rgba(226, 232, 240, 0.88);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .home-light-flow {
    background:
      radial-gradient(circle at 14% 9%, rgba(8, 145, 178, 0.14) 0%, transparent 42%),
      radial-gradient(circle at 84% 90%, rgba(14, 116, 144, 0.12) 0%, transparent 46%),
      linear-gradient(180deg, #d8e0e9 0%, #e6edf5 100%);
  }

  .ley-evidencia-section {
    padding: 5rem 0 5.2rem;
    position: relative;
    color: #0f172a;
    scroll-margin-top: 7.2rem;
    background: transparent;
  }

  .ley-evidencia-header {
    margin-bottom: 1rem;
    max-width: 78ch;
  }

  .ley-evidencia-kicker {
    display: inline-flex;
    margin-bottom: 0.62rem;
    padding: 0.34rem 0.86rem;
    border-radius: 999px;
    border: 1px solid rgba(14, 116, 144, 0.26);
    background: rgba(224, 242, 254, 0.82);
    color: #075985;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .ley-evidencia-main-title {
    margin: 0 0 0.64rem;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.05rem, 4vw, 3.15rem);
