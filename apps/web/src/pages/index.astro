    color: #0f172a;
  }

  .ley-evidencia-main-title .text-accent {
    color: #00b8c9;
  }

  .ley-evidencia-main-lead {
    margin: 0;
    color: rgba(30, 41, 59, 0.88);
    font-size: 1.04rem;
    line-height: 1.56;
    max-width: 70ch;
  }

  .ley-compare-board {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    align-items: stretch;
    margin-top: 0.95rem;
  }

  .ley-compare-column {
    padding: 1.05rem 1rem 0.92rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(148, 163, 184, 0.28);
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.76) 0%, rgba(241, 245, 249, 0.62) 100%);
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    position: relative;
    overflow: hidden;
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.24s ease, box-shadow 0.24s ease;
  }

  .ley-compare-column::after {
    content: '';
    position: absolute;
    inset: auto -50px -120px auto;
    width: 180px;
    height: 180px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(8, 145, 178, 0.16) 0%, transparent 72%);
    opacity: 0;
    transition: opacity 0.24s ease;
    pointer-events: none;
  }

  .ley-compare-column:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 30px rgba(15, 23, 42, 0.12);
  }

  .ley-compare-column:hover::after {
    opacity: 1;
  }

  .ley-compare-column--weak {
    border-top: 3px solid rgba(148, 163, 184, 0.44);
  }

  .ley-compare-column--strong {
    border-top: 3px solid rgba(8, 145, 178, 0.48);
    background: linear-gradient(160deg, rgba(236, 254, 255, 0.74) 0%, rgba(224, 242, 254, 0.58) 100%);
  }

  .ley-compare-column--strong:hover {
    border-color: rgba(8, 145, 178, 0.34);
  }

  .ley-compare-column--weak:hover {
    border-color: rgba(100, 116, 139, 0.34);
  }

  .ley-compare-versus {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 999px;
    border: 1px solid rgba(14, 116, 144, 0.32);
    background: rgba(241, 245, 249, 0.94);
    color: #0e7490;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
