  .ley-compare-head {
    margin-bottom: 0.75rem;
  }

  .ley-compare-chip {
    display: inline-flex;
    align-items: center;
    margin-bottom: 0.5rem;
    padding: 0.28rem 0.72rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.3);
    background: rgba(241, 245, 249, 0.85);
    color: #334155;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .ley-compare-title {
    margin: 0;
