  }

  .problem-metrics {
    position: absolute;
    z-index: 2;
    top: 50%;
    right: 2.2rem;
    transform: translateY(-50%);
    width: min(24rem, calc(40% - 2.2rem));
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
