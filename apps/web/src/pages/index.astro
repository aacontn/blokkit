    height: 3px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(14, 116, 144, 0.2) 0%, rgba(8, 145, 178, 0.46) 48%, rgba(34, 197, 94, 0.34) 100%);
    z-index: 0;
  }

  .como-steps::after {
    content: none;
    position: absolute;
    left: 12%;
    right: 12%;
    top: 0.84rem;
    height: 14px;
    transform: translateY(-41%);
    background: radial-gradient(ellipse at center, rgba(8, 145, 178, 0.14) 0%, rgba(8, 145, 178, 0) 75%);
    pointer-events: none;
    z-index: 0;
  }
  
  .como-step-card {
    position: relative;
    text-align: center;
    overflow: visible;
    border-radius: 1.18rem;
    border: 1px solid rgba(148, 163, 184, 0.34);
    background: linear-gradient(165deg, rgba(255, 255, 255, 0.78) 0%, rgba(248, 250, 252, 0.56) 100%);
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.45);
    padding: 1.32rem 0.98rem 1.06rem;
    backdrop-filter: blur(8px);
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.24s ease, box-shadow 0.24s ease;
  }

  .como-step-card::before {
    content: '';
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, rgba(8, 145, 178, 0.2) 0%, rgba(8, 145, 178, 0.55) 48%, rgba(8, 145, 178, 0.16) 100%);
    opacity: 0.88;
  }

  .como-step-card::after {
    content: '';
    position: absolute;
    right: -20px;
    top: -20px;
    width: 96px;
    height: 96px;
    border-radius: 999px;
    background: radial-gradient(circle at center, rgba(14, 116, 144, 0.15) 0%, transparent 75%);
    pointer-events: none;
  }

  .como-step-card:hover {
    transform: translateY(-6px);
    border-color: rgba(8, 145, 178, 0.5);
    box-shadow: 0 24px 40px rgba(15, 23, 42, 0.12), 0 0 0 1px rgba(8, 145, 178, 0.16);
  }
  
  .como-step-card--success {
    border-color: rgba(34, 197, 94, 0.34);
    background: linear-gradient(165deg, rgba(240, 253, 244, 0.78) 0%, rgba(248, 250, 252, 0.58) 100%);
