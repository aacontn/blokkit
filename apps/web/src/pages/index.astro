  /* ==================== PROBLEM SECTION ==================== */
  .problem-preview {
    padding: 8rem 0;
    position: relative;
    background:
      radial-gradient(760px 300px at 18% 16%, rgba(0, 194, 209, 0.14) 0%, transparent 64%),
      radial-gradient(680px 280px at 82% 86%, rgba(0, 194, 209, 0.1) 0%, transparent 66%),
      linear-gradient(180deg, #f1f5f9 0%, #e2e8f0 100%);
    color: #0f172a;
  }

  .problem-stage {
    position: relative;
    min-height: 680px;
    border-radius: 32px;
    overflow: hidden;
    isolation: isolate;
    box-shadow: 0 24px 64px rgba(2, 6, 23, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.46);
  }

  .problem-stage[data-reveal] {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }

  .problem-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url('/images/problem-students-bg.png');
    background-size: cover;
    background-position: center 38%;
    transform: scale(1.045);
    transition: transform 900ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .problem-stage.revealed::before {
    transform: scale(1);
  }

  .problem-stage-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(2, 6, 23, 0.82) 0%, rgba(2, 6, 23, 0.6) 40%, rgba(2, 6, 23, 0.42) 58%, rgba(2, 6, 23, 0.52) 100%),
      linear-gradient(180deg, rgba(2, 6, 23, 0.2) 0%, rgba(2, 6, 23, 0.55) 100%);
    pointer-events: none;
  }

  .problem-stage-overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(2, 6, 23, 0.18);
    opacity: 1;
    transition: opacity 800ms ease;
  }

  .problem-stage.revealed .problem-stage-overlay::after {
    opacity: 0;
  }

  .problem-content {
    position: relative;
    z-index: 2;
    width: 60%;
    max-width: 60%;
    padding: 3.1rem 2.6rem 2.1rem;
