---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import TextSplitReveal from "../components/ui/TextSplitReveal.tsx";
import StaggeredReveal from "../components/ui/StaggeredReveal.tsx";
import AnimatedCounter from "../components/ui/AnimatedCounter.tsx";
import MagneticButton from "../components/ui/MagneticButton.tsx";
import HowItWorksScroll from "../components/ui/HowItWorksScroll.tsx";
import HowItWorksModal from "../components/ui/HowItWorksModal.tsx";
import FinalCta from "../components/FinalCta.astro";
import ArchitectureFlow from "../components/ArchitectureFlow.astro";

// Page Metadata
const pageTitle = "Fundas con Bloqueo de Señal para Celulares en Colegios y Empresas | BloKKit";
const pageDescription = "Implementación rápida y sin confrontación de la Ley 2026. Sistema integral de fundas inteligentes para recuperar el foco en el aula.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header slot="header" />

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero section--dark hero-mesh-bg">
    <div class="hero__split container">
      <!-- Left: Text -->
      <div class="hero__text">
        <div class="hero__eyebrow fade-in-up">
          <h1 class="hero__h1">Fundas Bloqueadoras de Señal</h1>
          <span class="arrow-down-right" aria-hidden="true"></span>
        </div>

        <p class="hero__title" aria-hidden="true">
          <span class="hero__title-row">
            <TextSplitReveal
              client:load
              text="Creamos"
              as="span"
              splitBy="word"
              delay={0.15}
            />
          </span>
          <span class="hero__title-row hero__title-row--accent">
            <TextSplitReveal
              client:load
              text="ambientes libres"
              as="span"
              splitBy="word"
              delay={0.3}
            />
          </span>
          <span class="hero__title-row">
            <TextSplitReveal
              client:load
              text="de distracciones."
              as="span"
              splitBy="word"
              delay={0.45}
            />
          </span>
        </p>

        <ScrollReveal client:load delay={0.55}>
          <p class="hero__subtitle body-lg">
            Sistema de custodia inteligente que crea zonas libres de celulares. Ideal para colegios, universidades y espacios que requieren concentración, privacidad o desconexión total.
          </p>
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.7} className="hero__ctas">
          <button
            type="button"
            class="btn btn--primary"
            data-cal-link="blokkit/30min"
            data-cal-namespace="30min"
            data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
          >
            Agendar reunión
          </button>
          <a href="/producto" class="btn btn--ghost" data-how-modal-trigger>
            Ver cómo funciona
          </a>
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.85}>
          <ul class="hero__sectors tabular" aria-label="Sectores">
            <li>Colegios</li>
            <li>Universidades</li>
            <li>Eventos</li>
            <li>Organizaciones y empresas</li>
          </ul>
        </ScrollReveal>
      </div>

      <!-- Right: Product Visual -->
      <div class="hero__visual fade-in-up" style="animation-delay: 0.6s">
        <img
          src="/images/blokkit-fundas.webp"
          alt="Fundas BloKKit Faraday"
          class="hero__product-img"
          width="480"
          height="520"
          loading="eager"
        />
        <!-- Floating glass stat card — bottom-left -->
        <div class="hero__glass-card hero__glass-card--bl">
          <div class="hero__glass-icons">
            <!-- GSM / Signal Off -->
            <svg class="hero__glass-icon" fill="currentColor" viewBox="0 0 24 24">
              <!-- Signal Bars (Universal) -->
              <path d="M2 20h20V2L2 20zm11.17-6.83L12 14.34V20h1.17v-6.83zM15 20h2v-8h-2v8zm4 0h2v-5h-2v5z" style="opacity: 0.5" />
              <path d="M16 11V20h3V11h-3zm-6 5V20h3v-4h-3zm-6 4h3v-1h-3v1z" fill="currentColor" />
              <!-- Red Strikethrough (Translucent) -->
              <line x1="3" y1="3" x2="21" y2="21" stroke="#FF4444" stroke-width="2" stroke-linecap="round" stroke-opacity="0.7" />
            </svg>
            <!-- Bluetooth Off -->
            <svg class="hero__glass-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7L12 2V22L17 17L7 7" />
               <!-- Red Strikethrough (Translucent) -->
              <line x1="4" y1="4" x2="20" y2="20" stroke="#FF4444" stroke-width="2" stroke-linecap="round" stroke-opacity="0.7" />
            </svg>
            <!-- Wifi Off -->
            <svg class="hero__glass-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
               <path stroke-linecap="round" stroke-linejoin="round" d="M5 12.55a11 11 0 0114.08 0M1.42 9a16 16 0 0121.16 0M8.53 16.11a6 6 0 016.95 0M12 20h.01" />
               <!-- Red Strikethrough (Translucent) -->
               <line x1="3" y1="3" x2="21" y2="21" stroke="#FF4444" stroke-width="2" stroke-linecap="round" stroke-opacity="0.7" />
            </svg>
          </div>
          <div class="hero__glass-info">
            <span class="hero__glass-value">GSM · BT · WIFI</span>
            <span class="hero__glass-label">BLOQUEO EFECTIVO</span>
          </div>
        </div>
        <!-- Floating glass card — top-right -->
        <div class="hero__glass-card hero__glass-card--tr">
          <div class="hero__glass-icons">
             <svg class="hero__glass-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <div class="hero__glass-info">
            <span class="hero__glass-value">PLATAFORMA</span>
            <span class="hero__glass-label">MEDICIÓN Y TRAZABILIDAD</span>
          </div>
        </div>
        <!-- Floating glass card — bottom-right -->
        <div class="hero__glass-card hero__glass-card--br">
          <div class="hero__glass-icons">
             <svg class="hero__glass-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
             <svg class="hero__glass-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
          </div>
          <div class="hero__glass-info">
            <span class="hero__glass-value">DESBLOQUEO</span>
            <span class="hero__glass-label">MANUAL O SMART</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust Strip (Logo Marquee) -->
    <div class="hero__trust">
      <div class="logo-marquee">
        <div class="logo-marquee__track">
          {/* Real Set — BloKKit interleaved between gov logos */}
          <img src="/images/logo-chilecompra-original-white-marquee.png" alt="Mercado Público" class="marquee-logo marquee-logo--lg" width="236" height="52" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/Logo-Blokkit-white.png" alt="BloKKit" class="marquee-logo" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/logo-chilecompra-52-white-marquee.png" alt="ChileCompra" class="marquee-logo marquee-logo--lg" width="236" height="52" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/Logo-Blokkit-white.png" alt="BloKKit" class="marquee-logo" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/logo-chilecompra-original-white-marquee.png" alt="Mercado Público" class="marquee-logo marquee-logo--lg" width="236" height="52" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/Logo-Blokkit-white.png" alt="BloKKit" class="marquee-logo" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/logo-chilecompra-52-white-marquee.png" alt="ChileCompra" class="marquee-logo marquee-logo--lg" width="236" height="52" />
          <span class="marquee-dot" aria-hidden="true">·</span>

          {/* Clone Set for infinite scroll */}
          <img src="/images/logo-chilecompra-original-white-marquee.png" alt="" class="marquee-logo marquee-logo--lg" aria-hidden="true" width="236" height="52" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/Logo-Blokkit-white.png" alt="" class="marquee-logo" aria-hidden="true" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/logo-chilecompra-52-white-marquee.png" alt="" class="marquee-logo marquee-logo--lg" aria-hidden="true" width="236" height="52" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/Logo-Blokkit-white.png" alt="" class="marquee-logo" aria-hidden="true" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/logo-chilecompra-original-white-marquee.png" alt="" class="marquee-logo marquee-logo--lg" aria-hidden="true" width="236" height="52" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/Logo-Blokkit-white.png" alt="" class="marquee-logo" aria-hidden="true" />
          <span class="marquee-dot" aria-hidden="true">·</span>
          <img src="/images/logo-chilecompra-52-white-marquee.png" alt="" class="marquee-logo marquee-logo--lg" aria-hidden="true" width="236" height="52" />
          <span class="marquee-dot" aria-hidden="true">·</span>
        </div>
      </div>
    </div>

  </section>

  <!-- ═══════════════ PROBLEMA ═══════════════ -->
  <section class="problem section--lg section--slate section-photo-bg" id="problema" style="--photo-bg: url('/images/problem-students-bg.webp');">
    <!-- Problem light bg -->
    <div class="container problem__split" style="position: relative; z-index: 1;">
      <!-- Left: Text Content -->
      <div class="problem__text">
        <ScrollReveal client:visible>
          <span class="label">El costo invisible del celular en clase</span>
          <TextSplitReveal client:visible text="El Problema es Más Grande de lo que Crees" className="heading-2 problem__title" splitBy="word" delay={0.1} />
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.15}>
          <p class="problem__lead body-lg">
            No es solo "uso de pantalla". Cuando el teléfono está presente,
            la atención se fragmenta y cae la capacidad de aprendizaje del curso completo.
          </p>
          <p class="problem__body">
            Las distracciones digitales reducen la capacidad cognitiva en un <strong>11.2%</strong>
            solo por tener el teléfono presente. En un aula de 30 estudiantes, eso equivale a perder
            <strong>3 mentes completas</strong> por jornada.
          </p>
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.2} className="problem__signal">
          <span class="problem__signal-dot"></span>
          Menos foco, más interrupciones y más desgaste docente cada día.
        </ScrollReveal>

        <ScrollReveal client:visible delay={0.3} className="problem__ctas">
          <div class="pill-switch pill-switch--light" role="group" aria-label="Acciones">
            <a href="/evidencia" class="pill-option">Ver Evidencia</a>
            <button type="button" class="pill-option" data-cal-link="blokkit/30min" data-cal-namespace="30min" data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'>
              Agendar Reunión
            </button>
          </div>
        </ScrollReveal>
      </div>

      <!-- Right: Metric Cards -->
      <div class="problem__metrics">
        <ScrollReveal client:visible delay={0.1} className="problem__metric">
          <div class="problem__metric-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="animate-pulse" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <AnimatedCounter client:visible value={87} suffix="%" className="problem__metric-value heading-3 text-accent" />
          <span class="problem__metric-label body-sm">de estudiantes (9-17) con celular propio</span>
        </ScrollReveal>
        
        <ScrollReveal client:visible delay={0.2} className="problem__metric">
          <div class="problem__metric-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="animate-bounce-slow" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </div>
          <AnimatedCounter client:visible value={237} className="problem__metric-value heading-3 text-accent" />
          <span class="problem__metric-label body-sm">notificaciones diarias promedio</span>
        </ScrollReveal>
        
        <ScrollReveal client:visible delay={0.3} className="problem__metric">
          <div class="problem__metric-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="animate-spin-slow" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <span class="problem__metric-value heading-3 text-accent">23 min</span>
          <span class="problem__metric-label body-sm">para recuperar foco tras interrupción</span>
        </ScrollReveal>
        
        <ScrollReveal client:visible delay={0.4} className="problem__metric">
          <div class="problem__metric-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="animate-pulse" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <span class="problem__metric-value heading-3 text-accent">8-10 min</span>
          <span class="problem__metric-label body-sm">por clase se pierden por distracciones</span>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CÓMO FUNCIONA ═══════════════ -->
  <!-- overflow: clip (NOT hidden) — hidden would break the sticky pin inside -->
  <section class="how-it-works section--light-alt section-ambient section-ambient--light" id="como-funciona" style="position: relative; overflow: clip; padding-block: var(--space-16);">
    <div style="position: relative; z-index: 1;">
      <HowItWorksScroll client:visible />

      <ScrollReveal client:visible delay={0.2}>
        <div class="container" style="margin-top: var(--space-10); text-align: center;">
          <a href="/producto" class="btn btn--primary btn--lg">
            Ver Sistema Completo
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════════ ¿ESTÁ TU COLEGIO LISTO? ═══════════════ -->
  <section class="ley section--dark section-ambient" id="ley-2026" style="position: relative; overflow: hidden; padding-block: var(--space-20);">
    <!-- Mesh Gradient -->
    <!-- Light overlay -->

    <div class="container" style="position: relative; z-index: 1;">

      <!-- Header -->
      <div class="section-head section-head--center">
        <ScrollReveal client:visible>
          <span class="label">Ley N° 21.801 · En vigencia desde marzo 2026</span>
          <h2 class="heading-2">
            La ley ya rige.
            <span class="heading-accent" style="display: block;">¿Tu colegio ya tiene sistema?</span>
          </h2>
          <p class="body-lg" style="max-width: 560px; margin: var(--space-4) auto 0;">
            Cumplir la Ley 21.801 no es solo prohibir. La diferencia está en tener un <strong>sistema operativo claro</strong> para que el aula funcione todos los días.
          </p>
        </ScrollReveal>
      </div>

      <!-- ── Typographic banner: outlined 100% + "policía del aula" ── -->
      <ScrollReveal client:visible>
        <div class="ley__banner">
          <div class="ley__stat-block">
            <span class="ley__giant" aria-hidden="true">100<em>%</em></span>
            <p class="ley__giant-label">de los establecimientos del país deben cumplirla</p>
            <span class="ley__giant-sub">Desde kínder a 4° medio · Ley N° 21.801</span>
          </div>
          <div class="ley__banner-content">
            <h3 class="ley__banner-headline">
              Sin sistema institucional, el profesor termina siendo <span class="ley__accent-text">"policía del aula"</span>.
            </h3>
            <p class="ley__banner-sub">
              La norma ya está vigente. Lo que falta en la mayoría de los colegios es el <strong>cómo</strong>: quién guarda, dónde, qué pasa con las excepciones y quién responde.
            </p>
            <a href="/ley-celulares-2026" class="btn btn--primary btn--lg">
              Conocer los alcances de la Ley 21.801
            </a>
          </div>
        </div>
      </ScrollReveal>

      <!-- ── 3 obligations → how BloKKit solves each ── -->
      <ScrollReveal client:visible delay={0.1}>
        <p class="ley__cards-intro">
          <strong>3 obligaciones</strong> que tu colegio debe estar cumpliendo hoy — y cómo se resuelven:
        </p>
      </ScrollReveal>

      <div class="ley__rows">
        {[
          {
            num: "01",
            title: "Implementación real de la prohibición",
            desc: "El colegio debe velar por cómo se cumple la regla en sala. Sin un flujo institucional, la presión recae en cada docente.",
            points: ["Rutina común de entrada y salida de clase.", "Supervisión institucional, no control individual docente."],
            solve: "Rutina de entrada y salida resuelta con fundas + dock. El flujo institucional viene hecho — no lo improvisa cada docente."
          },
          {
            num: "02",
            title: "Excepciones definidas y trazables",
            desc: "Las excepciones deben estar formalizadas con el mismo criterio para todos: salud acreditada, emergencia, uso pedagógico planificado y solicitud fundada.",
            points: ["Matriz simple de decisión para inspectoría y docentes.", "Registro mínimo por caso: motivo, responsable y fecha."],
            solve: "Cada caso queda registrado en la plataforma — motivo, responsable y fecha — listo para inspectoría y auditoría."
          },
          {
            num: "03",
            title: "RICE + Protocolo operativo diario",
            desc: "Actualiza el reglamento interno y define un flujo único de cumplimiento para dirección, inspectoría, docentes y apoderados.",
            points: ["Roles y responsables definidos por etapa.", "Procedimiento estándar para todo el establecimiento."],
            solve: "Protocolo operativo estándar incluido en la implementación, listo para anexar a tu RICE."
          },
        ].map((req, i) => (
          <ScrollReveal client:visible delay={i * 0.1 + 0.15}>
            <div class="ley__row">
              <div class="ley__row-left">
                <span class="ley__row-num">{req.num}</span>
                <div>
                  <span class="ley__row-label">Exige la ley</span>
                  <h3 class="ley__row-title">{req.title}</h3>
                </div>
              </div>
              <div class="ley__row-mid">
                <p class="ley__row-desc">{req.desc}</p>
                <ul class="ley__row-points">
                  {req.points.map(p => (
                    <li>
                      <span class="ley__row-dot"></span>
                      {p}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="ley__row-solve">
                <span class="ley__solve-tag">Con BloKKit</span>
                <p>{req.solve}</p>
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════ POR QUÉ IMPORTA ═══════════════ -->
  <section class="why-matters section--slate section-ambient" style="position: relative; overflow: hidden; padding-block: var(--space-20);">
    <!-- Clean bg -->
    <div class="container" style="position: relative; z-index: 1;">
      <!-- Header -->
      <div class="section-head">
        <ScrollReveal client:visible>
          <span class="label">Intención vs Implementación</span>
          <h2 class="heading-2">
            ¿Por qué esto importa?
            <span class="heading-accent" style="display: block;">Prohibir por sí solo no cambia conducta.</span>
          </h2>
          <p class="body-lg">
            El objetivo puede ser correcto, pero el resultado depende de la ejecución diaria. La diferencia está en tener un estándar operativo y no solo una regla escrita.
          </p>
        </ScrollReveal>
      </div>

      <!-- Comparison + proof photo -->
      <div class="why-matters__layout">
        <div class="why-matters__compare">
          <ScrollReveal client:visible delay={0.1}>
            <div class="why-matters__card why-matters__card--bad">
              <span class="why-matters__tag">Solo prohibición</span>
              <div class="why-matters__card-header">
                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" style="color: #8a8d93;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <h3 class="heading-5">LA NORMA EXISTE, PERO NO EL SISTEMA</h3>
              </div>
              <ul class="why-matters__list">
                <li>La aplicación varía entre equipos y turnos.</li>
                <li>El control recae en personas, no en un proceso.</li>
                <li>Sube la fricción por criterios distintos.</li>
              </ul>
              <div class="why-matters__result">
                <strong>Resultado:</strong> cumplimiento irregular y desgaste operativo. La investigación lo confirma: cuando la regla existe solo en el papel, no hay diferencias medibles.
              </div>
              <a href="/evidencia#paradoja" class="why-matters__source">U. de Birmingham · The Lancet 2025</a>
            </div>
          </ScrollReveal>

          <div class="why-matters__vs" aria-hidden="true"><span>vs</span></div>

          <ScrollReveal client:visible delay={0.2}>
            <div class="why-matters__card why-matters__card--good">
              <span class="why-matters__tag why-matters__tag--good">Implementación real</span>
              <div class="why-matters__card-header">
                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" style="color: var(--accent);"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <h3 class="heading-5">LA LEY SE TRANSFORMA EN OPERACIÓN DIARIA</h3>
              </div>
              <ul class="why-matters__list">
                <li>Existe protocolo común, roles claros y excepciones trazables.</li>
