    transition: transform 0.26s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.22s ease, background 0.22s ease, box-shadow 0.22s ease;
  }

  .ley-brief-btn--primary {
    background: linear-gradient(135deg, #00C2D1 0%, #00A8B5 100%);
    border-color: rgba(0, 194, 209, 0.6);
    color: #ffffff;
    min-width: 340px;
    font-size: 0.99rem;
    box-shadow: 0 14px 34px rgba(0, 194, 209, 0.32);
  }

  .ley-brief-actions .ley-brief-btn:not(.ley-brief-btn--primary) {
    background: rgba(24, 24, 24, 0.72);
    border-color: rgba(148, 163, 184, 0.28);
