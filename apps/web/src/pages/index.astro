---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroMotionVisual from "../components/HeroMotionVisual.astro";
import "../styles/index-page.css";

const pageTitle = "BloKKit | Solución de Control de Celulares para Colegios y Empresas";
const pageDescription = "Sistema de bloqueo Faraday que crea zonas libres de distracciones sin confiscar teléfonos. Ideal para colegios, universidades y empresas en Chile y Latinoamérica.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header />
  
  <main>
    <!-- HERO SECTION -->
    <section class="hero-section">
      <!-- Background Effects -->
      <div class="hero-bg">
        <div class="gradient-orb orb-1"></div>
        <div class="gradient-orb orb-2"></div>
        <div class="gradient-orb orb-3"></div>
        <div class="grid-overlay"></div>
        <div class="center-glow"></div>
      </div>
      
	      <!-- Hero Content - Centered -->
	      <div class="hero-content">
	        <div class="max-w-7xl mx-auto layout-shell">
	          <div class="hero-grid">
	            <div class="hero-text" data-reveal>
	              <span class="hero-kicker">Zonas libres de celular</span>

	              <!-- Main Headline -->
	              <h1 class="hero-title">
	                <span class="title-line">Creamos</span>
	                <span class="title-line title-accent">Ambientes Libres</span>
	                <span class="title-line">de Distracciones</span>
	              </h1>
	              
	              <!-- Subtitle -->
	              <p class="hero-subtitle" data-reveal style="--delay: 100ms;">
	                Sistema de custodia inteligente que crea zonas libres de celulares.
	                <span class="text-white/90">Ideal para colegios, universidades y espacios que requieren concentración, privacidad o desconexión total.</span>
	              </p>
	              
	              <!-- CTAs -->
	              <div class="hero-ctas" data-reveal style="--delay: 200ms;">
	                <div class="pill-switch pill-switch--dark pill-switch--lg" role="group" aria-label="Acciones">
	                  <a href="/contacto" class="pill-option">
	                    Agendar Demo
	                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
	                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
	                    </svg>
	                  </a>
	                  <button type="button" class="pill-option" id="open-how-it-works-modal">
	                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
	                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
	                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
	                    </svg>
	                    Ver Cómo Funciona
	                  </button>
	                </div>
	              </div>
	            </div>

		            <div class="hero-product" data-reveal style="--delay: 150ms;">
		              <div class="hero-product-stage">
                    <div class="hero-remotion-shell">
                      <HeroMotionVisual />
                    </div>
	              </div>
	            </div>
	          </div>
	        </div>
	      </div>
      
      <!-- Scroll indicator -->
      <div class="scroll-indicator" data-reveal style="--delay: 400ms;">
        <span>Scroll</span>
        <div class="scroll-line">
          <div class="scroll-dot"></div>
        </div>
      </div>
    </section>

    <!-- PROBLEM SECTION (Preview) -->
    <section id="problema" class="problem-preview">
      <div class="max-w-7xl mx-auto layout-shell">
        <div class="problem-stage" data-reveal>
          <div class="problem-stage-overlay"></div>

          <div class="problem-content">
            <span class="problem-kicker">El costo invisible del celular en clase</span>
            <h2 class="section-title problem-title">
              <span class="problem-title-line">
                <span>El Problema es</span>
              </span>
              <span class="problem-title-line">
                <span><span class="text-accent">Más Grande</span> de lo que Crees</span>
              </span>
            </h2>
            <p class="problem-subtitle">
              No es solo “uso de pantalla”. Cuando el teléfono está presente,
              la atención se fragmenta y cae la capacidad de aprendizaje del curso completo.
            </p>
            <div class="problem-copy">
              <p class="problem-lede">
                Las distracciones digitales reducen la capacidad cognitiva en un <strong>11.2%</strong>
                solo por tener el teléfono presente.
              </p>
              <p class="problem-body">
                En un aula de 30 estudiantes, eso equivale a perder <strong>3 mentes completas</strong>
                por jornada.
              </p>
            </div>
            <div class="problem-signal">
              <span class="problem-signal-dot"></span>
              Menos foco, más interrupciones y más desgaste docente cada día.
            </div>
            <div class="problem-ctas">
              <div class="pill-switch pill-switch--light" role="group" aria-label="Acciones">
                <a href="/evidencia" class="pill-option">Ver evidencia</a>
                <a href="/contacto" class="pill-option">Agendar demo</a>
              </div>
            </div>
          </div>

          <div class="problem-metrics">
            <div class="problem-metric">
              <span class="problem-metric-value">87%</span>
              <span class="problem-metric-label">de estudiantes (9-17) con celular propio</span>
            </div>
            <div class="problem-metric">
              <span class="problem-metric-value">237</span>
              <span class="problem-metric-label">notificaciones diarias promedio</span>
            </div>
            <div class="problem-metric">
              <span class="problem-metric-value">23 min</span>
              <span class="problem-metric-label">para recuperar foco tras interrupción</span>
            </div>
            <div class="problem-metric">
              <span class="problem-metric-value">8-10 min</span>
              <span class="problem-metric-label">por clase se pierden por distracciones de teléfonos</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LEY: PREPARACION INSTITUCIONAL -->
    <section id="ley-realidad" class="ley-colegio-section">
      <div class="max-w-7xl mx-auto layout-shell">
          <div class="ley-brief" data-reveal>
            <header class="ley-brief-head">
              <span class="ley-brief-kicker">Vigente desde marzo 2026</span>
              <h2 class="ley-brief-title">
                ¿Está tu colegio <span>listo para la nueva ley?</span>
              </h2>
              <p class="ley-brief-lead">
                Cumplir no es solo prohibir. La diferencia está en tener un <strong>sistema operativo claro</strong> para que el aula funcione todos los días.
              </p>
            </header>

            <aside class="ley-brief-alert">
              <div class="ley-brief-alert-top">
                <span class="ley-brief-alert-label">Decisión clave</span>
                <span class="ley-brief-alert-date">Normativa escolar</span>
              </div>
              <p class="ley-brief-alert-main">
                Sin sistema institucional, el profesor termina siendo <span>“policía del aula”</span>.
              </p>
              <p class="ley-brief-alert-sub">
                El objetivo del colegio es devolver foco a la enseñanza y sacar la fiscalización del docente.
              </p>
            </aside>

            <div class="ley-brief-track" data-reveal style="--delay: 110ms;">
              <article class="ley-brief-row">
                <div class="ley-brief-row-main">
                  <span class="ley-brief-row-index">01</span>
                  <div class="ley-brief-row-title-wrap">
                    <span class="ley-brief-item-tag">Obligatorio</span>
                    <h3 class="ley-brief-item-title">Implementación real de la prohibición</h3>
                  </div>
                </div>
                <p class="ley-brief-item-desc">
                  El colegio debe velar por cómo se cumple la regla en sala. Sin un flujo institucional, la presión recae en cada docente.
                </p>
                <ul class="ley-brief-row-points">
                  <li>Rutina común de entrada y salida de clase.</li>
                  <li>Supervisión institucional, no control individual docente.</li>
                </ul>
              </article>

              <article class="ley-brief-row">
                <div class="ley-brief-row-main">
                  <span class="ley-brief-row-index">02</span>
                  <div class="ley-brief-row-title-wrap">
                    <span class="ley-brief-item-tag">Obligatorio</span>
                    <h3 class="ley-brief-item-title">Excepciones definidas y trazables</h3>
                  </div>
                </div>
                <p class="ley-brief-item-desc">
                  Las excepciones deben estar formalizadas con el mismo criterio para todos: salud acreditada, emergencia, uso pedagógico planificado y solicitud fundada.
                </p>
                <ul class="ley-brief-row-points">
                  <li>Matriz simple de decisión para inspectoría y docentes.</li>
                  <li>Registro mínimo por caso: motivo, responsable y fecha.</li>
                </ul>
              </article>

              <article class="ley-brief-row">
                <div class="ley-brief-row-main">
                  <span class="ley-brief-row-index">03</span>
                  <div class="ley-brief-row-title-wrap">
                    <span class="ley-brief-item-tag">Obligatorio</span>
                    <h3 class="ley-brief-item-title">RICE + protocolo operativo diario</h3>
                  </div>
                </div>
                <p class="ley-brief-item-desc">
                  Actualiza el reglamento interno y define un flujo único de cumplimiento para dirección, inspectoría, docentes y apoderados.
                </p>
                <ul class="ley-brief-row-points">
                  <li>Roles y responsables definidos por etapa.</li>
                  <li>Procedimiento estándar para todo el establecimiento.</li>
                </ul>
              </article>
            </div>

            <footer class="ley-brief-footer" data-reveal style="--delay: 180ms;">
              <div class="ley-brief-actions">
                <div class="pill-switch pill-switch--dark pill-switch--lg ley-brief-switch" role="group" aria-label="Acciones de preparación">
                  <a href="/contacto" class="pill-option" title="Ir a la página de Contacto">
                    Agendar Diagnóstico
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </a>
                  <a href="/ley-celulares-2026" class="pill-option" title="Ir a la página de alcances de la ley">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                    Ver alcances de la ley
                  </a>
                </div>
              </div>
            </footer>
          </div>
      </div>
    </section>

    <div class="home-light-flow">
      <!-- LEY: PROHIBIR NO BASTA -->
      <section id="prohibicion-no-basta" class="ley-evidencia-section">
        <div class="max-w-7xl mx-auto layout-shell">
        <div class="ley-evidencia-header" data-reveal>
          <span class="ley-evidencia-kicker">Intención vs implementación</span>
          <h2 class="ley-evidencia-main-title">
            ¿Por qué esto importa?<br />
            <span class="text-accent">Prohibir por sí solo no cambia conducta.</span>
          </h2>
          <p class="ley-evidencia-main-lead">
            El objetivo puede ser correcto, pero el resultado depende de la ejecución diaria.
            La diferencia está en tener un estándar operativo y no solo una regla escrita.
          </p>
        </div>

        <div class="ley-compare-board" data-reveal style="--delay: 110ms;">
          <span class="ley-compare-versus" aria-hidden="true">VS</span>
          <article class="ley-compare-column ley-compare-column--weak">
            <header class="ley-compare-head">
              <span class="ley-compare-chip">Solo prohibición</span>
              <h3 class="ley-compare-title">
                <span class="ley-compare-symbol" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </span>
                La norma existe, pero no el sistema
              </h3>
            </header>
            <ul class="ley-compare-list">
              <li>La aplicación varía entre equipos y turnos.</li>
              <li>El control recae en personas, no en un proceso.</li>
              <li>Sube la fricción por criterios distintos.</li>
            </ul>
            <p class="ley-compare-result"><strong>Resultado:</strong> cumplimiento irregular y desgaste operativo.</p>
          </article>

          <article class="ley-compare-column ley-compare-column--strong">
            <header class="ley-compare-head">
              <span class="ley-compare-chip">Implementación real</span>
              <h3 class="ley-compare-title">
                <span class="ley-compare-symbol" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </span>
                La ley se transforma en operación diaria
              </h3>
            </header>
            <ul class="ley-compare-list">
              <li>Existe protocolo común, roles claros y excepciones trazables.</li>
              <li>El mismo estándar se ejecuta en toda la organización.</li>
              <li>La supervisión es institucional, no individual.</li>
            </ul>
            <p class="ley-compare-result"><strong>Resultado:</strong> operación estable y cumplimiento sostenible.</p>
          </article>
        </div>

        <div class="ley-evidencia-summary" data-reveal style="--delay: 160ms;">
          <p><strong>Conclusión práctica:</strong> la diferencia no está en prohibir; está en implementar un sistema que se ejecute igual en cada operación.</p>
        </div>

        <article class="ley-risk-card" data-reveal style="--delay: 185ms;">
          <h3 class="ley-risk-title">Riesgo de no implementar</h3>
          <p class="ley-risk-desc">
            Sin protocolo operativo, aumenta la carga de supervisión, baja la consistencia y crecen los conflictos por interpretación.
          </p>
        </article>

        <div class="ley-evidencia-footer" data-reveal style="--delay: 210ms;">
          <div class="ley-cta-actions">
            <a href="/ley-celulares-2026" class="btn-outline-accent ley-btn-secondary">
              Ver marco legal completo
            </a>
          </div>
        </div>
        </div>
      </section>

      <!-- CÓMO FUNCIONA EN 30 SEGUNDOS -->
      <section class="como-funciona-section">
        <div class="max-w-7xl mx-auto layout-shell">
        <div class="como-header" data-reveal>
          <span class="section-label">Operación Simple</span>
          <h2 class="section-title">
            Cómo Funciona en<br />
            <span class="text-accent">30 Segundos</span>
          </h2>
          <p class="como-lead">
            Un flujo único para cada organización: rápido, visible y fácil de supervisar.
          </p>
        </div>
        
        <div class="como-steps" data-reveal style="--delay: 150ms;">
          <article class="como-step-card">
            <span class="como-step-number">01</span>
            <div class="como-step-icon">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <p class="como-step-owner">Responsable: usuario</p>
            <h4 class="como-step-title">Guarda</h4>
            <p class="como-step-desc">Al iniciar la actividad, el usuario guarda su teléfono dentro de la funda BloKKit.</p>
          </article>

          <article class="como-step-card">
            <span class="como-step-number">02</span>
            <div class="como-step-icon">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <p class="como-step-owner">Responsable: sistema</p>
            <h4 class="como-step-title">Cierra</h4>
            <p class="como-step-desc">El cierre magnético se activa automáticamente y la funda queda sellada.</p>
          </article>

          <article class="como-step-card">
            <span class="como-step-number">03</span>
            <div class="como-step-icon">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
              </svg>
            </div>
            <p class="como-step-owner">Responsable: usuario</p>
            <h4 class="como-step-title">Mantiene</h4>
            <p class="como-step-desc">Durante el proceso, la funda permanece visible y bajo resguardo.</p>
          </article>

          <article class="como-step-card como-step-card--success">
            <span class="como-step-number">04</span>
            <div class="como-step-icon como-step-icon--success">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
              </svg>
            </div>
            <p class="como-step-owner">Responsable: personal autorizado</p>
            <h4 class="como-step-title">Abre</h4>
            <p class="como-step-desc">Al finalizar la actividad, se abre con el dock y se retira el teléfono.</p>
          </article>
        </div>

        <p class="como-footnote" data-reveal style="--delay: 220ms;">
          Tiempo operativo por usuario: guardado en <strong>~5 segundos</strong> y desbloqueo en <strong>menos de 3 segundos</strong>.
        </p>
        </div>
      </section>
    </div>

    <!-- PARA QUIÉN SECTION -->
    <section class="para-quien-section">
      <div class="max-w-7xl mx-auto layout-shell">
        <div class="para-quien-header" data-reveal>
          <span class="section-label">Dónde aplica BloKKit</span>
          <h2 class="section-title">
            Una operación clara<br />
            para cada <span class="text-accent">tipo de organización</span>
          </h2>
          <p class="section-description">
            Podemos implementar en educación y universidades, en empresas e instituciones,
            en espacios restringidos y en operaciones de eventos, salud y servicios.
          </p>
        </div>
        
        <div class="segment-list" data-reveal style="--delay: 150ms;">
          <article class="segment-row segment-row--primary">
            <div class="segment-row-meta">
              <span class="segment-row-priority">Área 1</span>
              <span class="segment-row-tag">Educación</span>
            </div>
            <div class="segment-row-content">
              <h3 class="segment-title">Colegios y universidades</h3>
              <p class="segment-line"><strong>Desafío principal:</strong> distracción digital y presión de cumplimiento regulatorio.</p>
              <p class="segment-line"><strong>Resultado:</strong> estándar institucional trazable por jornada y por nivel.</p>
            </div>
            <ul class="segment-points">
              <li>Protocolo operativo común con excepciones definidas.</li>
              <li>Menos carga de fiscalización para equipos académicos.</li>
            </ul>
            <a href="/soluciones#educacion" class="segment-link">Ver solución en Educación</a>
          </article>

          <article class="segment-row">
            <div class="segment-row-meta">
              <span class="segment-row-priority">Área 2</span>
              <span class="segment-row-tag">Empresas e instituciones</span>
            </div>
            <div class="segment-row-content">
              <h3 class="segment-title">Equipos y operaciones</h3>
              <p class="segment-line"><strong>Desafío principal:</strong> interrupciones y exposición de información en procesos críticos.</p>
              <p class="segment-line"><strong>Resultado:</strong> reuniones y turnos con mayor foco bajo política común.</p>
            </div>
            <ul class="segment-points">
              <li>Implementación por área, operación y nivel de riesgo.</li>
              <li>Norma consistente para reuniones, capacitación y zonas sensibles.</li>
            </ul>
            <a href="/soluciones#empresas" class="segment-link">Ver solución para Empresas</a>
          </article>

          <article class="segment-row">
            <div class="segment-row-meta">
              <span class="segment-row-priority">Área 3</span>
              <span class="segment-row-tag">Gobierno, policías y justicia</span>
            </div>
            <div class="segment-row-content">
              <h3 class="segment-title">Congreso, juzgados y cadena de custodia</h3>
              <p class="segment-line"><strong>Desafío principal:</strong> resguardar dispositivos en reuniones sensibles y procedimientos legales.</p>
              <p class="segment-line"><strong>Resultado:</strong> custodia trazable con protocolo formal de ingreso y devolución.</p>
            </div>
            <ul class="segment-points">
              <li>Aplicable en Congreso, audiencias, diligencias y salas de control.</li>
              <li>Excepciones bajo autorización y registro de responsable.</li>
            </ul>
            <a href="/soluciones#gobierno-policias" class="segment-link">Ver solución para Gobierno y justicia</a>
          </article>

          <article class="segment-row">
            <div class="segment-row-meta">
              <span class="segment-row-priority">Área 4</span>
              <span class="segment-row-tag">Eventos, salud y servicios</span>
            </div>
            <div class="segment-row-content">
              <h3 class="segment-title">Operaciones de alta sensibilidad</h3>
              <p class="segment-line"><strong>Desafío principal:</strong> una distracción afecta experiencia, privacidad o continuidad de atención.</p>
              <p class="segment-line"><strong>Resultado:</strong> estándar operativo simple, adaptable y visible para todo el equipo.</p>
            </div>
            <ul class="segment-points">
              <li>Implementación ajustada al flujo real de cada operación.</li>
              <li>Activación inicial con acompañamiento operativo.</li>
            </ul>
            <a href="/soluciones#eventos" class="segment-link">Ver solución para Eventos y servicios</a>
          </article>
        </div>

        <p class="segment-note" data-reveal style="--delay: 220ms;">
          BloKKit no impone una receta única: adapta el estándar para que el cumplimiento sea real en tu contexto.
        </p>
      </div>
    </section>

    <div class="home-slate-flow">
      <!-- SOLUTION SECTION (Preview) -->
      <section class="solution-preview">
        <div class="max-w-7xl mx-auto layout-shell">
        <div class="solution-header" data-reveal>
          <span class="solution-kicker">Sistema BloKKit</span>
          <h2 class="section-title-center">
            Arquitectura <span class="text-accent">Integral</span><br />
            para operación sin fricción
          </h2>
          <p class="solution-intro">
            Tres piezas conectadas que convierten una política en cumplimiento diario, medible y escalable.
          </p>
        </div>
        
        <div class="solution-cards" data-reveal style="--delay: 150ms;">
          <div class="solution-card">
            <div class="solution-card-head">
              <div class="card-icon">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
