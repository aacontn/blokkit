    padding: 0.9rem 1rem;
    border-radius: 14px;
    background: rgba(2, 6, 23, 0.52);
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(7px);
    box-shadow: 0 12px 24px rgba(2, 6, 23, 0.3);
  }

  .problem-kicker,
  .problem-subtitle,
  .problem-copy,
  .problem-signal,
  .problem-ctas {
    transition: opacity 620ms cubic-bezier(0.16, 1, 0.3, 1),
                transform 760ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  .problem-metric {
    transition: opacity 560ms cubic-bezier(0.16, 1, 0.3, 1),
                transform 740ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  .problem-stage:not(.revealed) .problem-kicker,
  .problem-stage:not(.revealed) .problem-subtitle,
  .problem-stage:not(.revealed) .problem-copy,
  .problem-stage:not(.revealed) .problem-signal,
  .problem-stage:not(.revealed) .problem-ctas {
    opacity: 0;
    transform: translateY(18px);
  }

  .problem-stage:not(.revealed) .problem-title-line > span {
    opacity: 0;
    transform: translateY(108%);
  }

  .problem-stage:not(.revealed) .problem-metric {
    opacity: 0;
    transform: translateX(28px) scale(0.98);
  }

  .problem-stage.revealed .problem-kicker {
    transition-delay: 120ms;
  }

  .problem-stage.revealed .problem-title-line:nth-child(1) > span {
    transition-delay: 220ms;
  }

  .problem-stage.revealed .problem-title-line:nth-child(2) > span {
    transition-delay: 320ms;
  }

  .problem-stage.revealed .problem-subtitle {
    transition-delay: 390ms;
  }

  .problem-stage.revealed .problem-copy {
    transition-delay: 470ms;
  }

  .problem-stage.revealed .problem-signal {
    transition-delay: 540ms;
  }

  .problem-stage.revealed .problem-ctas {
    transition-delay: 620ms;
  }

  .problem-stage.revealed .problem-metric:nth-child(1) {
    transition-delay: 700ms;
  }

  .problem-stage.revealed .problem-metric:nth-child(2) {
    transition-delay: 780ms;
  }

  .problem-stage.revealed .problem-metric:nth-child(3) {
    transition-delay: 860ms;
  }

  .problem-stage.revealed .problem-metric:nth-child(4) {
    transition-delay: 940ms;
  }

