---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import TextSplitReveal from "../components/ui/TextSplitReveal.tsx";

const noticias = [
  {
    source: "Emol",
    date: "20 feb 2026",
    title: "Lo Barnechea hace balance de inhibidores de celulares en colegios y califica la medida como \"exitosa\"",
    excerpt: "Entre los hallazgos se destaca que un 26,5% de los estudiantes declaró participar más en clases estando sin teléfono.",
    url: "https://www.emol.com/noticias/Nacional/2026/02/20/1192049/celulares-colegios-inhibidores-lo-barnechea.html",
    image: "/images/press/emol-balance.jpg",
  },
  {
    source: "Municipalidad Lo Barnechea",
    date: "feb 2026",
    title: "Piloto en Lo Barnechea revela que 64% de docentes observa mayor foco en clases sin celulares",
    excerpt: "El 82% de los apoderados manifestó estar de acuerdo con generar ambientes libres de distracciones. El plan piloto se desarrolló con 78 estudiantes del Colegio Lo Barnechea.",
    url: "https://lobarnechea.cl/Noticias/piloto-en-lo-barnechea-revela-que-64-de-docentes-observa-mayor-foco-en-clases-sin-celulares/",
    image: "/images/press/lobarnechea.jpg",
  },
  {
    source: "AP News",
    date: "12 sep 2025",
    title: "Sin TikTok ni Instagram: colegio chileno bloquea móviles e insta a jóvenes a rescatar la convivencia",
    excerpt: "En el patio de un colegio en Santiago los adolescentes han cambiado las pantallas por partidos de voleibol, disputas de ping pong, ensayos de coreografías o simplemente charlas con amigos.",
    url: "https://apnews.com/article/chile-educacion-colegios-celulares-adiccion-digital-conexion-07d5772e9843f68cfa8d2ff96e0008ec",
    image: "/images/press/apnews.jpg",
    international: true,
  },
  {
    source: "Korea JoongAng Daily",
    date: "12 sep 2025",
    title: "No TikTok, no Instagram: Chilean school blocks phones as students rediscover real-world connections",
    excerpt: "Dozens of teens are rediscovering how to reconnect in the real world after a school in Santiago implemented a pioneering program that blocks cell phone signals.",
    url: "https://koreajoongangdaily.joins.com/news/2025-09-12/world/world/No-TikTok-no-Instagram-Chilean-school-blocks-phones-as-students-rediscover-realworld-connections/2397713",
    image: "/images/press/korea-joongangdaily.jpg",
    international: true,
  },
  {
    source: "EdexLive",
    date: "sep 2025",
    title: "No more TikTok, Instagram? Chile tests phone-signal blockers in schools",
    excerpt: "A school in Santiago, Chile, has introduced a first-of-its-kind program that blocks cell phone signals, encouraging students to spend more time interacting.",
    url: "https://www.edexlive.com/news/no-more-tiktok-instagram-chile-tests-phone-signal-blockers-in-schools-to-address-screen-addiction",
    image: "/images/press/edexlive.jpg",
    international: true,
  },
  {
    source: "La Tercera",
    date: "27 ago 2025",
    title: "\"Este es el camino correcto\": Lo Barnechea inicia plan piloto de inhibidores de señal de celulares en colegio Bicentenario",
    excerpt: "El alcalde Felipe Alessandri explicó que \"no se trata de demonizar la tecnología, sino de enseñarle a nuestros niños y jóvenes que hay tiempos y espacios donde es necesario desconectarse\".",
    url: "https://www.latercera.com/nacional/noticia/este-es-el-camino-correcto-lo-barnechea-inicia-plan-piloto-de-inhibidores-de-senal-de-celulares-en-colegio-bicentenario/",
    image: "/images/press/latercera.jpg",
  },
  {
    source: "Emol",
    date: "27 ago 2025",
    title: "Lo Barnechea pone en marcha plan piloto de inhibidores de señales en colegios",
    excerpt: "La medida contempla que al inicio de la jornada escolar los alumnos dejen sus dispositivos en una funda bloqueadora de frecuencia móvil.",
    url: "https://www.emol.com/noticias/Nacional/2025/08/27/1176169/inhibidores-senal-celulares-lo-barnechea.html",
    image: "/images/press/emol.jpg",
  },
  {
    source: "Meganoticias",
    date: "27 ago 2025",
    sortDate: "2025-08-27",
    title: "\"Se ven mejoras en la convivencia\": Lo Barnechea evalúa plan de inhibidores de señal",
    excerpt: "La Municipalidad realizó el primer balance de su campaña Espacios libres de teléfonos, que busca regular el uso de celulares en colegios públicos.",
    url: "https://www.meganoticias.cl/nacional/496898-municipalidad-lo-barnechea-evaluacion-plan-piloto-inhibidores-senal-colegio-brk-27-08-2025.html",
    image: "/images/press/meganoticias.jpg",
  },
  {
    source: "Chilevisión",
    date: "ago 2025",
    sortDate: "2025-08-01",
    title: "Lo Barnechea implementará inhibidores de señal de teléfonos en colegios",
    excerpt: "La medida busca que los alumnos mejoren su concentración en clases y no pasen tanto tiempo frente a las pantallas.",
    url: "https://www.chilevision.cl/noticias/nacional/video/lo-barnechea-implementara-inhibidores-de-senal-de-telefonos-en-colegios",
    image: "/images/press/chilevision.jpg",
  },
  {
    source: "24 Horas TVN",
    date: "ago 2025",
    sortDate: "2025-08-01",
    title: "\"Estarán más concentrados, pero tiene que acompañarse de educación\"",
    excerpt: "Macarena Silva, investigadora de la U. de Chile, analizó la implementación de inhibidores en colegios y el rol del acompañamiento pedagógico.",
    url: "https://www.24horas.cl/programas/manana-informativa/experta-inhibidores-celulares-ninos-concentrados",
    image: "/images/press/24horas.jpg",
  },
  {
    source: "Universo",
    date: "2025",
    sortDate: "2025-01-01",
    title: "\"Somos pioneros en implementar inhibidores en colegios\"",
    excerpt: "Entrevista con Makarena Contreras, directora de Innovación de la Municipalidad de Lo Barnechea, sobre la implementación del programa.",
    url: "https://universo.cl/actualidad/makarena-contreras-directora-de-innovacion-de-la-municipalidad-de-lo-barnechea-somos-pioneros-en-implementar-inhibidores-en-colegios/",
    image: "/images/press/universo.jpg",
  },
].map(item => ({ ...item, type: 'noticia' }));

const entrevistas = [
  {
    source: "Meganoticias",
    sortDate: "2025-08-28", // estimated
    title: "Lo Barnechea evalúa plan que regula uso de celulares mediante inhibidores",
    excerpt: "Primer balance de la campaña Espacios libres de teléfonos y su impacto en el ambiente escolar.",
    youtubeId: "n69gHQxt3k8",
  },
  {
    source: "CHV Noticias",
    sortDate: "2025-08-02", // estimated
    title: "Lo Barnechea implementará inhibidores de señal de teléfonos en colegios",
    excerpt: "Desde el segundo semestre, algunos estudiantes contarán con inhibidores de señales para los teléfonos celulares.",
    youtubeId: "XM_TvEgUb3M",
  },
  {
    source: "Tele13 Radio — Doble Click",
    sortDate: "2025-08-03", // estimated
    title: "Regulación del uso de celulares en colegios: es para estar presentes",
    excerpt: "Ramón Ulloa conversa con la directora de educación sobre el plan comunal de inhibidores de señal.",
    youtubeId: "TmYKCgeB8Nw",
  },
  {
    source: "News 3 Now",
    sortDate: "2024-05-01", // estimated early coverage
    title: "Chile: Signal blocking phone-cases help students focus",
    excerpt: "International video coverage on signal-blocking phone cases in Chilean schools.",
    youtubeId: "4viwjpTySHI",
    international: true,
  },
].map(item => ({ ...item, type: 'video' }));

// Merge and sort
const cobertura = [...noticias, ...entrevistas].sort((a, b) => {
  return new Date(b.sortDate).getTime() - new Date(a.sortDate).getTime();
});

const pressKit = {
  company: "BloKKit SpA",
  founded: "2024, Santiago, Chile",
  mission: "Crear ambientes libres de distracciones con tecnología de control no invasivo.",
  contact: "contacto@blokkit.cl",
};
---

<BaseLayout>
  <Header slot="header" />

  <section class="hero hero--sub hero-mesh-bg" style="padding-bottom: 40px; min-height: auto;">
    <div class="mesh-gradient" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero__content container">
      <span class="label fade-in-up" style="display: inline-block; padding: 6px 16px; background: rgba(127, 206, 236, 0.1); border-radius: var(--radius-full); border: 1px solid rgba(127, 206, 236, 0.4); color: var(--accent); letter-spacing: 0.1em; margin-bottom: var(--space-4); font-size: 0.75rem; font-weight: 700;">Cobertura de Medios</span>
      <h1 class="heading-1 hero__title" style="text-transform: uppercase;">
        <TextSplitReveal client:load text="BLOKKIT" as="span" className="text-accent" splitBy="word" delay={0.15} /><br/>
        <TextSplitReveal client:load text="EN LOS MEDIOS" as="span" splitBy="word" delay={0.25} />
      </h1>
      <ScrollReveal client:load delay={0.4}>
        <p class="hero__subtitle body-lg" style="margin-top: var(--space-6);">
          Así cubren los medios nacionales e internacionales el cambio<br/>hacia ambientes libres de celulares en Chile.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════════ COBERTURA UNIFICADA ═══════════════ -->
  <section class="section--lg section--light-alt" style="position: relative; overflow: hidden; padding-block: var(--space-20);">
    <!-- Mesh Gradient from Home Page Ley section -->
    <div class="ley__mesh-gradient" aria-hidden="true"></div>
    <!-- Grid Overlay -->
    <div class="ley__grid-overlay" aria-hidden="true"></div>
    
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="section-header">
          <span class="label" style="display: inline-block; padding: 6px 16px; background: rgba(127, 206, 236, 0.12); border-radius: var(--radius-full); margin-bottom: var(--space-4);">Prensa</span>
          <h2 class="heading-2" style="margin-top: 0; line-height: 1.1;">Reportajes y Entrevistas</h2>
          <p class="body-lg" style="color: var(--text-dark-secondary); margin-top: var(--space-4); max-width: 60ch;">Cobertura en medios periodísticos nacionales e internacionales analizando la implementación de soluciones para regular el uso de celulares.</p>
        </div>
      </ScrollReveal>

      <!-- Unified Grid for both articles and videos -->
      <div class="prensa-grid" style="margin-top: var(--space-12);">
        {cobertura.map((item, i) => (
          <ScrollReveal client:visible delay={(i % 4) * 0.05}>
            {item.type === 'noticia' ? (
              <a href={item.url} target="_blank" rel="noopener" class="prensa-card">
                <div class="prensa-card__image">
                  <img src={item.image} alt={item.title} loading="lazy" />
                  {item.international && <span class="prensa-card__badge">🌎 Internacional</span>}
                </div>
                <div class="prensa-card__body">
                  <div class="prensa-meta">
                    <span class="prensa-source">{item.source}</span>
                    <span class="prensa-date">{item.date}</span>
                  </div>
                  <h3 class="prensa-card__title">{item.title}</h3>
                  <p class="prensa-card__excerpt">{item.excerpt}</p>
                  <span class="prensa-card__link">Leer artículo →</span>
                </div>
              </a>
            ) : (
              <div class="entrevista-card" role="button" tabindex="0" data-modal-type="youtube" data-modal-youtube={item.youtubeId} data-modal-title={item.title} data-modal-source={item.source}>
                <div class="entrevista-card__thumb">
                  <img src={`https://img.youtube.com/vi/${item.youtubeId}/hqdefault.jpg`} alt={item.title} loading="lazy" />
                  <div class="entrevista-card__play">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="var(--accent)"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                  {item.international && <span class="prensa-card__badge" style="position: absolute; top: 8px; right: 8px;">🌎</span>}
                </div>
                <div class="entrevista-card__body">
                  <span class="prensa-source" style="color: var(--accent-dark);">{item.source}</span>
                  <h3 class="entrevista-card__title" style="color: var(--text-dark); margin-top: 8px;">{item.title}</h3>
                  <p class="prensa-card__excerpt" style="color: var(--text-dark-muted); font-size: var(--text-sm); margin-top: 8px; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">{item.excerpt}</p>
                </div>
              </div>
            )}
          </ScrollReveal>
        ))}
      </div>
    </div>

    <!-- ═══════════════ CTA FINAL ═══════════════ -->
    <div class="container" style="position: relative; z-index: 1; margin-top: var(--space-32); padding-bottom: var(--space-24);">
      <div class="final-cta__card">
        <div class="final-cta__glow" aria-hidden="true"></div>
        <div class="final-cta__inner">
          <ScrollReveal client:visible>
            <TextSplitReveal client:visible text="¿Eres periodista o editor?" className="heading-2 final-cta__title" splitBy="word" delay={0.1} />
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.2}>
            <p class="body-lg final-cta__subtitle">
              Contáctanos para entrevistas, datos de implementación o acceso a nuestro media kit.
            </p>
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.3}>
            <a href="mailto:contacto@blokkit.cl" class="btn btn--primary" style="margin-top: var(--space-2);">
              Contactar Prensa
            </a>
          </ScrollReveal>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ MODAL ═══════════════ -->
  <div class="press-modal" id="press-modal" aria-hidden="true">
    <div class="press-modal__backdrop" id="press-modal-backdrop"></div>
    <div class="press-modal__container">
      <div class="press-modal__header">
        <div class="press-modal__meta">
          <span class="press-modal__source" id="modal-source"></span>
          <span class="press-modal__date" id="modal-date"></span>
        </div>
        <button class="press-modal__close" id="press-modal-close" aria-label="Cerrar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="press-modal__content" id="modal-content"></div>
      <div class="press-modal__footer" id="modal-footer"></div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .hero--sub { min-height: 60vh; display: flex; flex-direction: column; justify-content: center; padding-top: 160px; padding-bottom: 60px; position: relative; overflow: hidden; }
  .hero__content { position: relative; z-index: 1; text-align: center; max-width: 900px; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); margin: 0 auto; }
  .hero__subtitle { max-width: 600px; color: var(--text-secondary); }

  .section-header { margin-bottom: var(--space-8); }
  .section-header--center { text-align: center; display: flex; flex-direction: column; align-items: center; }
  .section--dark-grid { position: relative; overflow: hidden; background: var(--bg-dark); }

  /* ── Background Elements Re-used ── */
  .ley__mesh-gradient {
    position: absolute;
    inset: -20% -20% -20% -20%;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 60% at 20% 30%, rgba(127, 206, 236, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 70% 70% at 80% 70%, rgba(15, 45, 85, 0.05) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 50% 50%, rgba(255, 255, 255, 0.8) 0%, transparent 60%);
    background-size: 130% 130%;
    animation: mesh-drift 15s ease-in-out infinite alternate;
  }
  .ley__grid-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: 
      linear-gradient(to right, rgba(15, 45, 85, 0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(15, 45, 85, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  
  @keyframes mesh-drift {
    0% { background-position: 0% 0%, 100% 100%, 50% 50%; }
    50% { background-position: 10% 20%, 90% 80%, 60% 40%; }
    100% { background-position: 0% 100%, 100% 0%, 40% 60%; }
  }

  /* ── News grid — compact cards ── */
  .prensa-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .prensa-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    height: 100%;
  }
  .prensa-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .prensa-card__image {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .prensa-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .prensa-card:hover .prensa-card__image img { transform: scale(1.04); }

  .prensa-card__badge {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 2px 8px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    color: white;
    font-size: 0.6rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    letter-spacing: 0.04em;
  }

  .prensa-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-2);
  }

  .prensa-meta { display: flex; justify-content: space-between; align-items: center; }
  .prensa-source { font-family: var(--font-heading); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent-dark); font-weight: 700; }
  .prensa-date { font-size: 10px; color: var(--text-dark-muted); }

  .prensa-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .prensa-card__excerpt {
    color: var(--text-dark-secondary);
    font-size: var(--text-xs);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .prensa-card__link {
    color: var(--accent-dark);
    font-weight: 600;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: auto;
    transition: color 0.2s ease;
  }
  .prensa-card:hover .prensa-card__link { color: var(--accent); }

  .entrevista-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .entrevista-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
  }

  .entrevista-card__thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #000;
  }
  .entrevista-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    opacity: 0.85;
  }
  .entrevista-card:hover .entrevista-card__thumb img { transform: scale(1.04); opacity: 1; }

  .entrevista-card__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
  }
  .entrevista-card__play svg {
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.5));
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .entrevista-card:hover .entrevista-card__play svg { transform: scale(1.15); }

  .entrevista-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .entrevista-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Press Kit ── */
  .press-kit-row { display: grid; gap: var(--space-8); align-items: start; }
  @media (min-width: 768px) { .press-kit-row { grid-template-columns: 1fr 1fr; gap: var(--space-12); } }

  .press-kit-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    padding: var(--space-6);
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
  }
  @media (max-width: 480px) { .press-kit-details { grid-template-columns: 1fr; } }

  .pk-item { display: flex; flex-direction: column; gap: var(--space-1); }
  .pk-item--full { grid-column: 1 / -1; }
  .pk-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-dark-muted); font-weight: 600; }
  .pk-value { color: var(--text-dark); font-size: var(--text-sm); }
  .pk-link { color: var(--accent-dark); font-weight: 500; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.2s ease; display: inline-block; width: fit-content; font-size: var(--text-sm); }
  .pk-link:hover { border-bottom-color: var(--accent-dark); }

  /* ── Modal ── */
  .press-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
  }
  .press-modal--open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.3s ease, visibility 0s linear 0s;
  }
  .press-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .press-modal__container {
    position: relative;
    z-index: 1;
    width: 95%;
    max-width: 960px;
    background: #0f1219;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transform: translateY(20px);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .press-modal--open .press-modal__container {
    transform: translateY(0);
  }
  .press-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }
  .press-modal__meta { display: flex; align-items: center; gap: var(--space-3); }
  .press-modal__source {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    font-weight: 700;
  }
  .press-modal__date {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .press-modal__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .press-modal__close:hover {
    background: rgba(255, 255, 255, 0.12);
    color: white;
  }
  .press-modal__content {
    overflow: hidden;
  }
  /* YouTube aspect ratio container */
  .press-modal__content .yt-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }
  .press-modal__content .yt-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  /* Article preview fallback */
  .press-modal__article-preview {
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    text-align: center;
    align-items: center;
  }
  .press-modal__article-preview h3 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: white;
    line-height: 1.3;
    max-width: 600px;
  }
  .press-modal__article-preview p {
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 500px;
  }
  .press-modal__footer {
    padding: var(--space-4) var(--space-5);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    text-align: center;
    flex-shrink: 0;
  }
  .press-modal__footer:empty { display: none; }

  .prensa-card, .entrevista-card { cursor: pointer; }
</style>

<!-- Global styles for dynamically injected modal content (innerHTML) -->
<style is:global>
  .press-modal__content .yt-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #000;
  }
  .press-modal__content .yt-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>

<script>
  const modal = document.getElementById('press-modal');
  const modalContent = document.getElementById('modal-content');
  const modalFooter = document.getElementById('modal-footer');
  const modalSource = document.getElementById('modal-source');
  const modalDate = document.getElementById('modal-date');
  const closeBtn = document.getElementById('press-modal-close');
  const backdrop = document.getElementById('press-modal-backdrop');

  function openModal(type: string, data: Record<string, string>) {
    if (!modal || !modalContent || !modalFooter || !modalSource || !modalDate) return;

    modalSource.textContent = data.source || '';
    modalDate.textContent = data.date || '';

    if (type === 'youtube') {
      modalContent.innerHTML = `
        <div class="yt-wrapper">
          <iframe src="https://www.youtube.com/embed/${data.youtube}?autoplay=1&rel=0" 
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                  allowfullscreen></iframe>
        </div>`;
      modalFooter.innerHTML = '';
    } else {
      return; // Articles open in new tab via anchor tag
    }

    modal.classList.add('press-modal--open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal || !modalContent) return;
    modal.classList.remove('press-modal--open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Clear iframes after animation
    setTimeout(() => { if (modalContent) modalContent.innerHTML = ''; }, 300);
  }

  // Card click handlers
  document.querySelectorAll('[data-modal-type]').forEach((card) => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      const type = el.dataset.modalType || '';
      openModal(type, {
        url: el.dataset.modalUrl || '',
        title: el.dataset.modalTitle || '',
        source: el.dataset.modalSource || '',
        date: el.dataset.modalDate || '',
        excerpt: el.dataset.modalExcerpt || '',
        youtube: el.dataset.modalYoutube || '',
      });
    });
  });

  // Close handlers
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
