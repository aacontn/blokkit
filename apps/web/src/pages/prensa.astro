---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import FinalCta from "../components/FinalCta.astro";
import PageHero from "../components/PageHero.astro";

/* Resultados del piloto Lo Barnechea según la propia cobertura de prensa —
   cada cifra enlaza al artículo que la publicó. */
const pilotStats = [
  {
    value: "26,5%",
    claim: "de los estudiantes declaró participar más en clases estando sin teléfono.",
    source: "Emol · feb 2026",
    href: "https://www.emol.com/noticias/Nacional/2026/02/20/1192049/celulares-colegios-inhibidores-lo-barnechea.html",
  },
  {
    value: "64%",
    claim: "de los docentes observa mayor foco en clases sin celulares.",
    source: "Municipalidad de Lo Barnechea · feb 2026",
    href: "https://lobarnechea.cl/Noticias/piloto-en-lo-barnechea-revela-que-64-de-docentes-observa-mayor-foco-en-clases-sin-celulares/",
  },
  {
    value: "82%",
    claim: "de los apoderados está de acuerdo con generar ambientes libres de distracciones.",
    source: "Municipalidad de Lo Barnechea · feb 2026",
    href: "https://lobarnechea.cl/Noticias/piloto-en-lo-barnechea-revela-que-64-de-docentes-observa-mayor-foco-en-clases-sin-celulares/",
  },
];

const noticias = [
  {
    source: "Emol",
    date: "20 feb 2026",
    sortDate: "2026-02-20",
    title: "Lo Barnechea hace balance de inhibidores de celulares en colegios y califica la medida como \"exitosa\"",
    excerpt: "Entre los hallazgos se destaca que un 26,5% de los estudiantes declaró participar más en clases estando sin teléfono.",
    url: "https://www.emol.com/noticias/Nacional/2026/02/20/1192049/celulares-colegios-inhibidores-lo-barnechea.html",
    image: "/images/press/emol-balance.jpg",
    featured: true,
  },
  {
    source: "Municipalidad Lo Barnechea",
    date: "feb 2026",
    sortDate: "2026-02-15",
    title: "Piloto en Lo Barnechea revela que 64% de docentes observa mayor foco en clases sin celulares",
    excerpt: "El 82% de los apoderados manifestó estar de acuerdo con generar ambientes libres de distracciones. El plan piloto se desarrolló con 78 estudiantes del Colegio Lo Barnechea.",
    url: "https://lobarnechea.cl/Noticias/piloto-en-lo-barnechea-revela-que-64-de-docentes-observa-mayor-foco-en-clases-sin-celulares/",
    image: "/images/press/lobarnechea.jpg",
  },
  {
    source: "AP News",
    date: "12 sep 2025",
    sortDate: "2025-09-12",
    title: "Sin TikTok ni Instagram: colegio chileno bloquea móviles e insta a jóvenes a rescatar la convivencia",
    excerpt: "En el patio de un colegio en Santiago los adolescentes han cambiado las pantallas por partidos de voleibol, disputas de ping pong, ensayos de coreografías o simplemente charlas con amigos.",
    url: "https://apnews.com/article/chile-educacion-colegios-celulares-adiccion-digital-conexion-07d5772e9843f68cfa8d2ff96e0008ec",
    image: "/images/press/apnews.jpg",
    international: true,
    featured: true,
  },
  {
    source: "Korea JoongAng Daily",
    date: "12 sep 2025",
    sortDate: "2025-09-12",
    title: "No TikTok, no Instagram: Chilean school blocks phones as students rediscover real-world connections",
    excerpt: "Dozens of teens are rediscovering how to reconnect in the real world after a school in Santiago implemented a pioneering program that blocks cell phone signals.",
    url: "https://koreajoongangdaily.joins.com/news/2025-09-12/world/world/No-TikTok-no-Instagram-Chilean-school-blocks-phones-as-students-rediscover-realworld-connections/2397713",
    image: "/images/press/korea-joongangdaily.jpg",
    international: true,
  },
  {
    source: "EdexLive",
    date: "sep 2025",
    sortDate: "2025-09-10",
    title: "No more TikTok, Instagram? Chile tests phone-signal blockers in schools",
    excerpt: "A school in Santiago, Chile, has introduced a first-of-its-kind program that blocks cell phone signals, encouraging students to spend more time interacting.",
    url: "https://www.edexlive.com/news/no-more-tiktok-instagram-chile-tests-phone-signal-blockers-in-schools-to-address-screen-addiction",
    image: "/images/press/edexlive.jpg",
    international: true,
  },
  {
    source: "La Tercera",
    date: "27 ago 2025",
    sortDate: "2025-08-27",
    title: "\"Este es el camino correcto\": Lo Barnechea inicia plan piloto de inhibidores de señal de celulares en colegio Bicentenario",
    excerpt: "El alcalde Felipe Alessandri explicó que \"no se trata de demonizar la tecnología, sino de enseñarle a nuestros niños y jóvenes que hay tiempos y espacios donde es necesario desconectarse\".",
    url: "https://www.latercera.com/nacional/noticia/este-es-el-camino-correcto-lo-barnechea-inicia-plan-piloto-de-inhibidores-de-senal-de-celulares-en-colegio-bicentenario/",
    image: "/images/press/latercera.jpg",
  },
  {
    source: "Emol",
    date: "27 ago 2025",
    sortDate: "2025-08-27",
    title: "Lo Barnechea pone en marcha plan piloto de inhibidores de señales en colegios",
    excerpt: "La medida contempla que al inicio de la jornada escolar los alumnos dejen sus dispositivos en una funda bloqueadora de frecuencia móvil.",
    url: "https://www.emol.com/noticias/Nacional/2025/08/27/1176169/inhibidores-senal-celulares-lo-barnechea.html",
    image: "/images/press/emol.jpg",
  },
  {
    source: "Meganoticias",
    date: "27 ago 2025",
    sortDate: "2025-08-27",
    title: "\"Se ven mejoras en la convivencia\": Lo Barnechea evalúa plan de inhibidores de señal",
    excerpt: "La Municipalidad realizó el primer balance de su campaña Espacios libres de teléfonos, que busca regular el uso de celulares en colegios públicos.",
    url: "https://www.meganoticias.cl/nacional/496898-municipalidad-lo-barnechea-evaluacion-plan-piloto-inhibidores-senal-colegio-brk-27-08-2025.html",
    image: "/images/press/meganoticias.jpg",
  },
  {
    source: "Chilevisión",
    date: "ago 2025",
    sortDate: "2025-08-01",
    title: "Lo Barnechea implementará inhibidores de señal de teléfonos en colegios",
    excerpt: "La medida busca que los alumnos mejoren su concentración en clases y no pasen tanto tiempo frente a las pantallas.",
    url: "https://www.chilevision.cl/noticias/nacional/video/lo-barnechea-implementara-inhibidores-de-senal-de-telefonos-en-colegios",
    image: "/images/press/chilevision.jpg",
  },
  {
    source: "24 Horas TVN",
    date: "ago 2025",
    sortDate: "2025-08-01",
    title: "\"Estarán más concentrados, pero tiene que acompañarse de educación\"",
    excerpt: "Macarena Silva, investigadora de la U. de Chile, analizó la implementación de inhibidores en colegios y el rol del acompañamiento pedagógico.",
    url: "https://www.24horas.cl/programas/manana-informativa/experta-inhibidores-celulares-ninos-concentrados",
    image: "/images/press/24horas.jpg",
  },
  {
    source: "Universo",
    date: "2025",
    sortDate: "2025-01-01",
    title: "\"Somos pioneros en implementar inhibidores en colegios\"",
    excerpt: "Entrevista con Makarena Contreras, directora de Innovación de la Municipalidad de Lo Barnechea, sobre la implementación del programa.",
    url: "https://universo.cl/actualidad/makarena-contreras-directora-de-innovacion-de-la-municipalidad-de-lo-barnechea-somos-pioneros-en-implementar-inhibidores-en-colegios/",
    image: "/images/press/universo.jpg",
  },
].map((item) => ({ ...item, type: "noticia" }));

const entrevistas = [
  {
    source: "Meganoticias",
    date: "ago 2025",
    sortDate: "2025-08-28",
    title: "Lo Barnechea evalúa plan que regula uso de celulares mediante inhibidores",
    excerpt: "Primer balance de la campaña Espacios libres de teléfonos y su impacto en el ambiente escolar.",
    youtubeId: "n69gHQxt3k8",
  },
  {
    source: "CHV Noticias",
    date: "ago 2025",
    sortDate: "2025-08-02",
    title: "Lo Barnechea implementará inhibidores de señal de teléfonos en colegios",
    excerpt: "Desde el segundo semestre, algunos estudiantes contarán con inhibidores de señales para los teléfonos celulares.",
    youtubeId: "XM_TvEgUb3M",
  },
  {
    source: "Tele13 Radio — Doble Click",
    date: "ago 2025",
    sortDate: "2025-08-03",
    title: "Regulación del uso de celulares en colegios: es para estar presentes",
    excerpt: "Ramón Ulloa conversa con la directora de educación sobre el plan comunal de inhibidores de señal.",
    youtubeId: "TmYKCgeB8Nw",
  },
  {
    source: "News 3 Now",
    date: "2024",
    sortDate: "2024-05-01",
    title: "Chile: Signal blocking phone-cases help students focus",
    excerpt: "International video coverage on signal-blocking phone cases in Chilean schools.",
    youtubeId: "4viwjpTySHI",
    international: true,
  },
].map((item) => ({ ...item, type: "video" }));

const cobertura = [...noticias, ...entrevistas].sort(
  (a, b) => new Date(b.sortDate).getTime() - new Date(a.sortDate).getTime()
);
---

<BaseLayout>
  <Header slot="header" />

  <PageHero
    label="Cobertura de Medios"
    title="BloKKit"
    accent="en los medios"
    subtitle="Así cubren los medios nacionales e internacionales el cambio hacia ambientes libres de celulares en Chile."
  />

  <!-- ═══════════ 01 · EL PILOTO EN LA PRENSA (cream) ═══════════ -->
  <section class="prs section--light-alt section-ambient section-ambient--light" id="piloto">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="prs-head">
          <span class="section-number" aria-hidden="true">01</span>
          <div>
            <span class="label">Lo Barnechea · primer piloto comunal</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              El piloto que la prensa
              <span class="heading-accent">calificó de "exitoso"</span>
            </h2>
            <p class="body-lg" style="margin-top: var(--space-3); max-width: 60ch;">
              78 estudiantes del Colegio Lo Barnechea, fundas bloqueadoras de señal y un balance publicado por los propios medios:
            </p>
          </div>
        </div>
      </ScrollReveal>

      <div class="prs-stats">
        {pilotStats.map((s, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <div class="prs-stat">
              <span class="prs-stat__value">{s.value}</span>
              <p class="prs-stat__claim body-sm">{s.claim}</p>
              <a class="prs-source" href={s.href} target="_blank" rel="noopener">{s.source} ↗</a>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ 02 · COBERTURA COMPLETA (dark) ═══════════ -->
  <section class="prs section--dark section-ambient" id="cobertura">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="prs-head">
          <span class="section-number" aria-hidden="true">02</span>
          <div>
            <span class="label">Reportajes y entrevistas</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              De Santiago
              <span class="heading-accent">al mundo</span>
            </h2>
            <p class="body-lg" style="margin-top: var(--space-3); max-width: 60ch; color: var(--text-secondary);">
              La historia partió en un colegio chileno y la recogió la prensa internacional — de AP News a Corea del Sur.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <div class="prensa-grid">
        {cobertura.map((item, i) => (
          <ScrollReveal client:visible delay={(i % 4) * 0.05} className={item.featured ? "prensa-span2" : ""}>
            {item.type === "noticia" ? (
              <a href={item.url} target="_blank" rel="noopener" class={`prensa-card ${item.featured ? "prensa-card--featured" : ""}`}>
                <div class="prensa-card__image">
                  <img src={item.image} alt={item.title} loading="lazy" />
                  {item.international && <span class="prensa-card__badge">Internacional</span>}
                </div>
                <div class="prensa-card__body">
                  <div class="prensa-meta">
                    <span class="prensa-source">{item.source}</span>
                    <span class="prensa-date">{item.date}</span>
                  </div>
                  <h3 class="prensa-card__title">{item.title}</h3>
                  <p class="prensa-card__excerpt">{item.excerpt}</p>
                  <span class="prensa-card__link">Leer artículo →</span>
                </div>
              </a>
            ) : (
              <div
                class="prensa-card prensa-card--video"
                role="button"
                tabindex="0"
                data-modal-type="youtube"
                data-modal-youtube={item.youtubeId}
                data-modal-title={item.title}
                data-modal-source={item.source}
                data-modal-date={item.date}
              >
                <div class="prensa-card__image prensa-card__image--video">
                  <img src={`https://img.youtube.com/vi/${item.youtubeId}/hqdefault.jpg`} alt={item.title} loading="lazy" />
                  <div class="prensa-card__play" aria-hidden="true">
                    <svg width="46" height="46" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                  {item.international && <span class="prensa-card__badge">Internacional</span>}
                </div>
                <div class="prensa-card__body">
                  <div class="prensa-meta">
                    <span class="prensa-source">{item.source}</span>
                    <span class="prensa-date">Video</span>
                  </div>
                  <h3 class="prensa-card__title">{item.title}</h3>
                  <p class="prensa-card__excerpt">{item.excerpt}</p>
                  <span class="prensa-card__link">Ver entrevista →</span>
                </div>
              </div>
            )}
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <FinalCta
    label="Prensa"
    title="¿Eres periodista o editor?"
    subtitle="Contáctanos para entrevistas, datos de implementación o acceso a nuestro media kit."
    primaryText="Contactar prensa"
    primaryHref="mailto:contacto@blokkit.cl"
    micro="Media kit y datos de implementación disponibles"
  />

  <!-- ═══════════════ MODAL ═══════════════ -->
  <div class="press-modal" id="press-modal" aria-hidden="true">
    <div class="press-modal__backdrop" id="press-modal-backdrop"></div>
    <div class="press-modal__container">
      <div class="press-modal__header">
        <div class="press-modal__meta">
          <span class="press-modal__source" id="modal-source"></span>
          <span class="press-modal__date" id="modal-date"></span>
        </div>
        <button class="press-modal__close" id="press-modal-close" aria-label="Cerrar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="press-modal__content" id="modal-content"></div>
      <div class="press-modal__footer" id="modal-footer"></div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .prs {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-20);
  }

  /* ── Section head: numeral + kicker + title ── */
  .prs-head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .prs-head .section-number {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── Pilot stats ── */
  .prs-stats {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .prs-stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-6);
    }
  }

  .prs-stat {
    height: 100%;
    padding: var(--space-6);
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .prs-stat:hover {
    transform: translateY(-3px);
    border-color: rgba(63, 168, 224, 0.4);
    box-shadow: var(--shadow-card-hover);
  }

  .prs-stat__value {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    line-height: 0.95;
    color: var(--accent-strong);
    letter-spacing: -0.01em;
  }

  .prs-stat__claim {
    margin: var(--space-3) 0 0;
    color: var(--text-dark-secondary);
    flex: 1;
  }

  .prs-source {
    display: inline-block;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dark-muted);
    text-decoration: none;
    border-bottom: 1px dotted transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .prs-source:hover {
    color: var(--accent-dark);
    border-bottom-color: var(--accent-dark);
  }

  /* ── Coverage grid — white cards on charcoal ── */
  .prensa-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-5);
  }

  :global(.prensa-span2) {
    grid-column: span 1;
  }

  @media (min-width: 640px) {
    :global(.prensa-span2) {
      grid-column: span 2;
    }
  }

  .prensa-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    height: 100%;
    cursor: pointer;
  }

  .prensa-card:hover {
    transform: translateY(-3px);
    border-color: rgba(63, 168, 224, 0.45);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
  }

  .prensa-card__image {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-dark-deep);
  }

  .prensa-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .prensa-card:hover .prensa-card__image img {
    transform: scale(1.04);
  }

  .prensa-card__image--video img {
    opacity: 0.85;
  }

  .prensa-card:hover .prensa-card__image--video img {
    opacity: 1;
  }

  .prensa-card__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
  }

  .prensa-card__play svg {
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.55));
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .prensa-card:hover .prensa-card__play svg {
    transform: scale(1.15);
  }

  .prensa-card__badge {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 3px 10px;
    background: rgba(22, 22, 22, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid rgba(127, 206, 236, 0.35);
    border-radius: var(--radius-full);
  }

  .prensa-card__body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-2);
  }

  .prensa-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
  }

  .prensa-source {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-dark);
  }

  .prensa-date {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    color: var(--text-dark-muted);
  }

  .prensa-card__title {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prensa-card--featured .prensa-card__title {
    font-size: var(--text-lg);
    -webkit-line-clamp: 2;
  }

  .prensa-card__excerpt {
    color: var(--text-dark-secondary);
    font-size: var(--text-sm);
    line-height: 1.55;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prensa-card--featured .prensa-card__excerpt {
    -webkit-line-clamp: 3;
  }

  .prensa-card__link {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-dark);
    transition: color 0.2s ease;
  }

  .prensa-card:hover .prensa-card__link {
    color: var(--accent-strong);
  }

  /* ── Modal ── */
  .press-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
  }

  .press-modal--open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.3s ease, visibility 0s linear 0s;
  }

  .press-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .press-modal__container {
    position: relative;
    z-index: 1;
    width: 95%;
    max-width: 960px;
    background: var(--bg-dark-deep);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transform: translateY(20px);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .press-modal--open .press-modal__container {
    transform: translateY(0);
  }

  .press-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-subtle);
    flex-shrink: 0;
  }

  .press-modal__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .press-modal__source {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    font-weight: 500;
  }

  .press-modal__date {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
  }

  .press-modal__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .press-modal__close:hover {
    background: rgba(255, 255, 255, 0.12);
    color: white;
  }

  .press-modal__content {
    overflow: hidden;
  }

  .press-modal__footer {
    padding: var(--space-4) var(--space-5);
    border-top: 1px solid var(--border-subtle);
    text-align: center;
    flex-shrink: 0;
  }

  .press-modal__footer:empty {
    display: none;
  }
</style>

<!-- Global styles for dynamically injected modal content (innerHTML) -->
<style is:global>
  .press-modal__content .yt-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #000;
  }

  .press-modal__content .yt-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>

<script>
  const modal = document.getElementById('press-modal');
  const modalContent = document.getElementById('modal-content');
  const modalFooter = document.getElementById('modal-footer');
  const modalSource = document.getElementById('modal-source');
  const modalDate = document.getElementById('modal-date');
  const closeBtn = document.getElementById('press-modal-close');
  const backdrop = document.getElementById('press-modal-backdrop');

  function openModal(type: string, data: Record<string, string>) {
    if (!modal || !modalContent || !modalFooter || !modalSource || !modalDate) return;

    modalSource.textContent = data.source || '';
    modalDate.textContent = data.date || '';

    if (type === 'youtube') {
      modalContent.innerHTML = `
        <div class="yt-wrapper">
          <iframe src="https://www.youtube.com/embed/${data.youtube}?autoplay=1&rel=0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen></iframe>
        </div>`;
      modalFooter.innerHTML = '';
    } else {
      return; // Articles open in new tab via anchor tag
    }

    modal.classList.add('press-modal--open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal || !modalContent) return;
    modal.classList.remove('press-modal--open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(() => { if (modalContent) modalContent.innerHTML = ''; }, 300);
  }

  document.querySelectorAll('[data-modal-type]').forEach((card) => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      openModal(el.dataset.modalType || '', {
        title: el.dataset.modalTitle || '',
        source: el.dataset.modalSource || '',
        date: el.dataset.modalDate || '',
        youtube: el.dataset.modalYoutube || '',
      });
    });
    card.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'Enter' || ke.key === ' ') {
        ke.preventDefault();
        (card as HTMLElement).click();
      }
    });
  });

  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
