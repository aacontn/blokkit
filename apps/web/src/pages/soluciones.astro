---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import FinalCta from "../components/FinalCta.astro";
import PageHero from "../components/PageHero.astro";

const sectors = [
  {
    id: "educacion", num: "01", kicker: "Educación",
    title: "Cumplimiento pedagógico diario",
    subtitle: "Colegios, liceos y universidades",
    img: "/images/sector_education.png",
    imgAlt: "Sala de clases trabajando concentrada, sin celulares a la vista",
    summary: "BloKKit baja la norma al aula: el estudiante conserva su teléfono, pero sin uso durante la clase, con protocolo visible para docentes y apoderados.",
    challenge: "La prohibición por sí sola genera uso oculto, conflictos de convivencia y alta carga administrativa para el equipo directivo.",
    flow: [
      { title: "Inicio de jornada con cierre validado", detail: "Cada estudiante guarda su teléfono, realiza cierre magnético y parte la clase con el mismo criterio para todos." },
      { title: "Bloqueo durante actividades", detail: "El dispositivo permanece inhabilitado sin confiscación y sin discusiones recurrentes en sala." },
      { title: "Apertura autorizada al cierre", detail: "La liberación se realiza solo en dock autorizado al finalizar la actividad o en contingencias definidas." },
      { title: "Registro de excepciones", detail: "Salud, emergencia o uso pedagógico quedan documentados bajo responsables designados." },
    ],
    modules: ["Funda por estudiante para uso diario", "Dock fijo o portátil para aperturas controladas", "Protocolo institucional alineado al reglamento interno"],
    results: ["Hasta 10 minutos pedagógicos recuperados por bloque", "Menor tensión entre docencia, convivencia y familias", "Evidencia operativa para fiscalización y mejora continua"],
    ctaLabel: "Ver marco Ley 21.801", ctaHref: "/ley-celulares-2026",
  },
  {
    id: "empresas", num: "02", kicker: "Empresas",
    title: "Foco y confidencialidad en operaciones críticas",
    subtitle: "Directorios, comités, training y salas de decisión",
    img: "/images/sector_corporate_1772680270200.png",
    imgAlt: "Directorio reunido en sala de decisión, presentación en curso",
    summary: "Definimos zonas y momentos sin teléfono para reuniones críticas, trabajo profundo y sesiones con información sensible.",
    challenge: "Sin un mecanismo simple, los acuerdos de no uso se rompen rápido y el equipo vuelve a interrupciones constantes.",
    flow: [
      { title: "Diseño por tipo de sesión", detail: "Se establecen espacios y reuniones donde el protocolo BloKKit es obligatorio según riesgo e impacto." },
      { title: "Activación en ingreso", detail: "Cada participante inicia la sesión con bloqueo físico, evitando notificaciones y uso paralelo del teléfono." },
      { title: "Custodia sin fricción", detail: "El teléfono sigue con su dueño, lo que reduce resistencia frente a esquemas de entrega o retiro manual." },
      { title: "Reporte para liderazgo", detail: "Se mide adopción y cumplimiento por área para sostener la práctica en el tiempo." },
    ],
    modules: ["Fundas para comités y equipos clave", "Docks por piso o salas de reunión", "Panel para seguimiento por unidad de negocio"],
    results: ["Menos interrupciones en sesiones de alto costo", "Mayor disciplina de reunión y mejor calidad de decisión", "Control simple de cumplimiento por área"],
    ctaLabel: "Solicitar diseño para mi operación", ctaHref: "/contacto",
  },
  {
    id: "gobierno", num: "03", kicker: "Gobierno, Policías y Justicia",
    title: "Cadena de custodia con trazabilidad",
    subtitle: "Congreso, audiencias, diligencias y recintos sensibles",
    img: "/images/sector_government_1772680286153.png",
    imgAlt: "Sala de sesiones institucional en pleno funcionamiento",
    summary: "BloKKit estandariza ingreso, resguardo y devolución de dispositivos con responsables y trazas claras en entornos de alta sensibilidad.",
    challenge: "El manejo informal de teléfonos en procesos sensibles eleva riesgo legal, operacional y reputacional.",
    flow: [
      { title: "Ingreso bajo protocolo único", detail: "Se define punto de control, responsable y tipo de resguardo según la naturaleza de la diligencia." },
      { title: "Bloqueo verificable", detail: "El dispositivo queda inutilizado para captura o comunicación no autorizada durante el proceso." },
      { title: "Apertura con personal autorizado", detail: "Solo roles habilitados operan los docks para liberar equipos al cierre del procedimiento." },
      { title: "Trazabilidad y respaldo", detail: "Las excepciones, aperturas y devoluciones quedan registradas para auditoría y control interno." },
    ],
    modules: ["Fundas con identificación por usuario o caso", "Dock estándar o Smart según nivel de control", "Registro de incidentes y excepciones"],
    results: ["Operación consistente en sesiones sensibles", "Reducción de incidentes por manejo discrecional", "Soporte documental para compliance y auditoría"],
    ctaLabel: "Hablar con equipo técnico", ctaHref: "/contacto",
  },
  {
    id: "eventos", num: "04", kicker: "Eventos y Espectáculos",
    title: "Control de experiencia y propiedad intelectual",
    subtitle: "Conciertos, lanzamientos, premieres y activaciones",
    img: "/images/sector_events_1772680300324.png",
    imgAlt: "Audiencia presente en un evento en vivo, escenario iluminado",
    summary: "Aplicamos un flujo rápido de ingreso y salida para evitar grabaciones no autorizadas, filtraciones y distracción de audiencia.",
    challenge: "Cuando no existe protocolo de custodia, sube el riesgo de filtraciones y baja la calidad de experiencia en vivo.",
    flow: [
      { title: "Configuración previa por aforo", detail: "Definimos cantidad de fundas, puntos de apertura y staff necesario según tipo de evento." },
      { title: "Ingreso ordenado", detail: "El público bloquea su teléfono en entrada con apoyo de personal entrenado y señalética clara." },
      { title: "Operación durante show", detail: "Se mantiene la experiencia sin pantallas y con procedimientos para contingencias autorizadas." },
      { title: "Salida fluida", detail: "La apertura se ejecuta por estaciones para liberar al público sin cuellos de botella." },
    ],
    modules: ["Kit de fundas por capacidad de evento", "Docks distribuidos por accesos y salida", "Soporte de activación y guion operativo"],
    results: ["Protección efectiva de contenido", "Experiencia inmersiva para audiencia", "Operación escalable para eventos recurrentes"],
    ctaLabel: "Evaluar mi evento", ctaHref: "/contacto",
  },
];
---

<BaseLayout>
  <Header slot="header" />

  <PageHero
    label="Fundas Bloqueadoras de Señal"
    title="Soluciones que"
    accent="sí se implementan"
    subtitle="Convertimos una política interna en operación diaria con protocolo, control de apertura y trazabilidad por contexto."
  />

  {sectors.map((s, idx) => {
    const isLight = idx % 2 === 0;
    const reversed = idx % 2 === 1;

    return (
      <section
        id={s.id}
        class={`sector ${isLight ? "section--light-alt section-ambient section-ambient--light" : "section--dark section-ambient"}`}
      >
        <div class="container" style="position: relative; z-index: 1;">
          <ScrollReveal client:visible>
            <div class="sector-header">
              <span class="section-number sector-num" aria-hidden="true">{s.num}</span>
              <div>
                <span class="label">{s.kicker}</span>
                <h2 class="heading-2" style="margin-top: var(--space-2)">{s.title}</h2>
                <p class="body-sm sector-subtitle">{s.subtitle}</p>
              </div>
            </div>
          </ScrollReveal>

          <!-- Photo + summary lede -->
          <div class={`sector-lede ${reversed ? "sector-lede--reverse" : ""}`}>
            <ScrollReveal client:visible delay={0.1} className="sector-photo-reveal">
              <figure class="sector-photo">
                <img src={s.img} alt={s.imgAlt} width="640" height="640" loading="lazy" />
                <figcaption class="sector-photo__chip">{s.kicker}</figcaption>
              </figure>
            </ScrollReveal>
            <ScrollReveal client:visible delay={0.2} className="sector-lede-text">
              <p class="body-lg sector-summary">{s.summary}</p>
              <div class="sector-challenge">
                <h3 class="sector-h">Desafío que resolvemos</h3>
                <p class="body-sm">{s.challenge}</p>
              </div>
            </ScrollReveal>
          </div>

          <!-- Implementation flow: connected schematic -->
          <ScrollReveal client:visible delay={0.15}>
            <span class="flow-label">Cómo se implementa</span>
            <ol class="flow-line">
              {s.flow.map((step, i) => (
                <li class="flow-node">
                  <span class="flow-node__badge">0{i + 1}</span>
                  <h4 class="sector-h">{step.title}</h4>
                  <p class="body-sm flow-node__detail">{step.detail}</p>
                </li>
              ))}
            </ol>
          </ScrollReveal>

          <!-- Modules / results / CTA strip -->
          <div class="sector-foot">
            <ScrollReveal client:visible delay={0.1}>
              <div class="aside-card">
                <h3 class="sector-h aside-card__title">Módulos activados</h3>
                <ul class="sector-list">
                  {s.modules.map((m) => <li class="body-sm">{m}</li>)}
                </ul>
              </div>
            </ScrollReveal>
            <ScrollReveal client:visible delay={0.2}>
              <div class="aside-card">
                <h3 class="sector-h aside-card__title">Resultado operativo</h3>
                <ul class="sector-list sector-list--dot">
                  {s.results.map((r) => <li class="body-sm">{r}</li>)}
                </ul>
              </div>
            </ScrollReveal>
            <ScrollReveal client:visible delay={0.3} className="sector-cta-reveal">
              <div class="sector-cta">
                <span class="sector-cta__hint">Diseño a medida por contexto</span>
                <a href={s.ctaHref} class="btn btn--primary">
                  {s.ctaLabel}
                </a>
              </div>
            </ScrollReveal>
          </div>
        </div>
      </section>
    );
  })}

  <FinalCta
    title="¿Listo para definir"
    accent="tu solución BloKKit?"
    subtitle="Agendamos una reunión y te proponemos el flujo exacto para tu institución, equipo o evento."
  />

  <Footer slot="footer" />
</BaseLayout>

<style>
  .sector {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-20);
  }

  /* ── Header: outlined numeral + kicker + title ── */
  .sector-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .sector-num {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .sector-subtitle {
    margin-top: var(--space-2);
    color: var(--text-muted);
  }

  .section--light-alt .sector-subtitle {
    color: var(--text-dark-muted);
  }

  /* ── Lede: photo + summary/challenge ── */
  .sector-lede {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-8);
    align-items: center;
    margin-bottom: var(--space-12);
  }

  @media (min-width: 900px) {
    .sector-lede {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      gap: var(--space-12);
    }

    .sector-lede--reverse :global(.sector-photo-reveal) {
      order: 2;
    }
  }

  .sector-photo {
    position: relative;
    margin: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    aspect-ratio: 4 / 3;
  }

  .section--light-alt .sector-photo {
    border-color: var(--border-light);
    box-shadow: var(--shadow-elevated);
  }

  .sector-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sector-photo__chip {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    padding: 5px 12px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-primary);
    background: var(--glass-bg-heavy);
    backdrop-filter: var(--glass-backdrop-subtle);
    -webkit-backdrop-filter: var(--glass-backdrop-subtle);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-full);
  }

  :global(.sector-lede-text) {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .sector-summary {
    margin: 0;
    max-width: 56ch;
  }

  /* ── Small display heading used across the section ── */
  .sector-h {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 1.25;
    color: var(--text-primary);
    margin: 0 0 var(--space-2);
  }

  .section--light-alt .sector-h {
    color: var(--text-dark);
  }

  /* ── Challenge callout ── */
  .sector-challenge {
    padding: var(--space-5);
    border-left: 2px solid var(--accent);
    background: linear-gradient(90deg, rgba(127, 206, 236, 0.06) 0%, transparent 100%);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .section--light-alt .sector-challenge {
    border-left-color: var(--accent-strong);
    background: linear-gradient(90deg, rgba(63, 168, 224, 0.07) 0%, transparent 100%);
  }

  .sector-challenge p {
    margin: 0;
  }

  /* ── Implementation flow: connected schematic ── */
  .flow-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-5);
  }

  .section--light-alt .flow-label {
    color: var(--accent-strong);
  }

  .flow-line {
    position: relative;
    list-style: none;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-6);
    margin: 0 0 var(--space-12);
    padding: 0;
  }

  @media (min-width: 900px) {
    .flow-line {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: var(--space-6);
    }

    /* marching dashed rail behind the badges */
    .flow-line::before {
      content: "";
      position: absolute;
      top: 14px;
      left: 14px;
      right: 14px;
      height: 2px;
      background: repeating-linear-gradient(90deg, var(--accent) 0 6px, transparent 6px 14px);
      opacity: 0.45;
      animation: flow-march 1.2s linear infinite;
    }

    .section--light-alt .flow-line::before {
      background: repeating-linear-gradient(90deg, var(--accent-strong) 0 6px, transparent 6px 14px);
    }
  }

  @keyframes flow-march {
    to { background-position: 14px 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-line::before { animation: none; }
  }

  .flow-node {
    position: relative;
  }

  /* vertical spine on mobile */
  @media (max-width: 899px) {
    .flow-node {
      padding-left: var(--space-10);
    }

    .flow-node:not(:last-child)::after {
      content: "";
      position: absolute;
      left: 14px;
      top: 32px;
      bottom: calc(-1 * var(--space-6));
      width: 2px;
      background: repeating-linear-gradient(180deg, var(--accent) 0 6px, transparent 6px 14px);
      opacity: 0.4;
    }

    .section--light-alt .flow-node:not(:last-child)::after {
      background: repeating-linear-gradient(180deg, var(--accent-strong) 0 6px, transparent 6px 14px);
    }

    .flow-node__badge {
      position: absolute;
      left: 0;
      top: 0;
    }
  }

  .flow-node__badge {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--bg-dark);
    border: 1px solid var(--border-accent);
    margin-bottom: var(--space-3);
  }

  .section--light-alt .flow-node__badge {
    color: var(--accent-dark);
    background: var(--bg-white);
    border-color: rgba(63, 168, 224, 0.45);
  }

  .flow-node__detail {
    margin: 0;
  }

  /* ── Foot strip: modules / results / CTA ── */
  .sector-foot {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-5);
    align-items: stretch;
  }

  @media (min-width: 960px) {
    .sector-foot {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 0.8fr);
    }
  }

  :global(.sector-cta-reveal) {
    display: flex;
  }

  .aside-card {
    height: 100%;
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: var(--glass-backdrop);
    -webkit-backdrop-filter: var(--glass-backdrop);
  }

  .section--light-alt .aside-card {
    background: var(--bg-white);
    border-color: var(--border-light);
    box-shadow: var(--shadow-card);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .aside-card__title {
    margin-bottom: var(--space-4);
  }

  .sector-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
  }

  .sector-list li {
    position: relative;
    padding-left: var(--space-5);
    margin: 0;
  }

  .sector-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .section--light-alt .sector-list li::before {
    color: var(--accent-strong);
  }

  .sector-list--dot li::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    top: 0.5em;
    left: 4px;
  }

  .section--light-alt .sector-list--dot li::before {
    background: var(--accent-strong);
  }

  .sector-cta {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    border: 1px dashed var(--border-accent);
  }

  .section--light-alt .sector-cta {
    border-color: rgba(63, 168, 224, 0.4);
  }

  .sector-cta__hint {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .section--light-alt .sector-cta__hint {
    color: var(--text-dark-muted);
  }
</style>
