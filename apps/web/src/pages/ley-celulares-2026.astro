---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import FinalCta from "../components/FinalCta.astro";
import PageHero from "../components/PageHero.astro";

/* ─────────────────────────────────────────────────────────
   LEY 21.801 — dossier legal con datos verificados.
   Fuente primaria: Biblioteca del Congreso Nacional.
   Publicada 11-feb-2026 · vigente desde marzo 2026 ·
   RICE actualizado antes del 30-jun-2026 · evaluación
   Mineduc marzo 2030. No inventar fechas ni cifras.
   ───────────────────────────────────────────────────────── */

const BCN_URL = "https://www.bcn.cl/leychile/navegar?idNorma=1221284";

const ficha = [
  { k: "Publicación", v: "11 · 02 · 2026", sub: "Diario Oficial" },
  { k: "Vigencia", v: "Marzo 2026", sub: "Desde el año escolar" },
  { k: "Alcance", v: "Kínder a 4° medio", sub: "Todo establecimiento reconocido" },
  { k: "Fiscaliza", v: "Superintendencia", sub: "de Educación", small: true },
];

const niveles = [
  {
    nivel: "Parvularia",
    regla: "Prohibición total",
    tone: "total",
    desc: "Uso prohibido en todo momento y lugar dentro del establecimiento. Sin pantallas personales en el nivel inicial.",
  },
  {
    nivel: "Básica",
    regla: "Prohibición total",
    tone: "total",
    desc: "Uso prohibido durante toda la jornada — clases, recreos y actividades. Solo rigen las excepciones que define la ley.",
  },
  {
    nivel: "Media",
    regla: "Uso regulado por RICE",
    tone: "regulada",
    desc: "Cada establecimiento define en su reglamento interno los espacios y momentos permitidos. La regla la pone el colegio — y debe poder aplicarla.",
  },
];

const excepciones = [
  {
    num: "01",
    title: "Uso pedagógico",
    desc: "Actividades de aprendizaje definidas y supervisadas por el docente, dentro de la planificación.",
  },
  {
    num: "02",
    title: "Salud del estudiante",
    desc: "Condiciones médicas acreditadas que requieren el dispositivo — por ejemplo, monitoreo de glicemia.",
  },
  {
    num: "03",
    title: "Necesidades educativas especiales",
    desc: "Cuando el dispositivo es herramienta de apoyo, accesibilidad o comunicación del estudiante.",
  },
  {
    num: "04",
    title: "Emergencias",
    desc: "Situaciones de emergencia o fuerza mayor que justifiquen contacto inmediato.",
  },
  {
    num: "05",
    title: "Casos calificados en el RICE",
    desc: "Autorizaciones fundadas que cada establecimiento regula en su reglamento interno.",
  },
];

const hitos = [
  {
    date: "11 FEB 2026",
    title: "Publicación en el Diario Oficial",
    desc: "La Ley N° 21.801 se publica y entra al ordenamiento. El plazo de adaptación comienza a correr.",
    state: "past",
  },
  {
    date: "MAR 2026",
    title: "Entrada en vigencia",
    desc: "Rige desde el año escolar 2026: prohibición en parvularia y básica, regulación por RICE en media.",
    state: "past",
  },
  {
    date: "30 JUN 2026",
    title: "Plazo para actualizar el RICE",
    desc: "Los reglamentos internos deben estar actualizados, según las instrucciones de la Superintendencia de Educación.",
    state: "next",
    tag: "Plazo en curso",
  },
  {
    date: "MAR 2030",
    title: "Evaluación de la ley",
    desc: "El Mineduc debe evaluar la implementación y resultados de la norma a cuatro años de su vigencia.",
    state: "future",
  },
];

const brechas = [
  {
    q: "¿Dónde se guardan los teléfonos?",
    gap: "La ley exige cumplir, pero no resuelve la logística: mochilas, casilleros, cajas — ¿quién responde por pérdidas y daños?",
    solve: "Cada teléfono queda sellado en su funda BloKKit y nunca cambia de manos. Sin custodia de terceros, sin inventario que administrar.",
  },
  {
    q: "¿Cómo se evita el uso oculto?",
    gap: "Sin un mecanismo físico, el cumplimiento depende de la vigilancia constante de cada docente — el “policía del aula”.",
    solve: "El cierre magnético hace el trabajo: el dispositivo queda inutilizable hasta el dock de salida. El docente vuelve a enseñar.",
  },
  {
    q: "¿Qué pasa con las excepciones?",
    gap: "Salud, NEE y emergencias necesitan un proceso formal e igual para todos — no el criterio individual de turno.",
    solve: "Protocolo de excepciones incluido: casos definidos, responsables claros y acceso inmediato al dispositivo cuando corresponde.",
  },
  {
    q: "¿Cómo se documenta el cumplimiento?",
    gap: "El RICE exige protocolo escrito, pero la ley no entrega herramientas para demostrar que se aplica día a día.",
    solve: "Asignación por QR y registro de uso por persona: trazabilidad completa, lista para inspectoría y para la Superintendencia.",
  },
];
---

<BaseLayout>
  <Header slot="header" />

  <PageHero
    label="Marco legal · Chile"
    title="Ley N° 21.801:"
    accent="celulares fuera del aula"
    subtitle="Publicada el 11 de febrero de 2026 y vigente desde marzo, la ley restringe el celular en todos los colegios de Chile. Aquí está lo que exige, a quién aplica y los plazos que corren — verificado en la fuente oficial."
  />

  <!-- ═══════════ 01 · LA LEY EN UNA MIRADA (cream) ═══════════ -->
  <section class="l26 section--light-alt section-ambient section-ambient--light" id="ficha">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="l26-head">
          <span class="section-number" aria-hidden="true">01</span>
          <div>
            <span class="label">La ley en una mirada</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              Una norma nacional,
              <span class="heading-accent" style="display: block;">cuatro datos clave</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <div class="l26-ficha">
        <ScrollReveal client:visible delay={0.1} className="l26-ficha-id">
          <div>
            <span class="l26-giant" aria-hidden="true">21.801</span>
            <p class="l26-giant-label">
              La ley que regula el uso de dispositivos móviles en los establecimientos educacionales del país.
            </p>
            <a class="l26-source" href={BCN_URL} target="_blank" rel="noopener">
              Texto oficial · Biblioteca del Congreso Nacional ↗
            </a>
          </div>
        </ScrollReveal>

        <div class="l26-ficha-grid">
          {ficha.map((f, i) => (
            <ScrollReveal client:visible delay={0.15 + i * 0.07}>
              <div class="l26-dato">
                <span class="l26-dato-k">{f.k}</span>
                <span class={`l26-dato-v ${f.small ? "l26-dato-v--sm" : ""}`}>{f.v}</span>
                <span class="l26-dato-sub">{f.sub}</span>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>

      <ScrollReveal client:visible delay={0.2}>
        <div class="l26-deadline">
          <span class="l26-deadline-tag">Plazo RICE · 30 de junio 2026</span>
          <p>
            La vigencia ya corrió. El plazo operativo que sigue abierto es uno:
            <strong>los reglamentos internos deben estar actualizados antes del 30 de junio de 2026</strong>,
            según las instrucciones de la Superintendencia de Educación.
          </p>
          <a href="/contacto" class="btn btn--primary">Poner mi colegio al día</a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════ 02 · ALCANCE POR NIVEL (dark) ═══════════ -->
  <section class="l26 section--dark section-ambient" id="alcance">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="l26-head">
          <span class="section-number" aria-hidden="true">02</span>
          <div>
            <span class="label">Alcance por nivel</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              No es una regla única:
              <span class="heading-accent" style="display: block;">depende del nivel educativo</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <div class="l26-niveles">
        {niveles.map((n, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <article class={`l26-nivel ${n.tone === "regulada" ? "l26-nivel--regulada" : ""}`}>
              <span class={`l26-nivel-tag ${n.tone === "regulada" ? "l26-nivel-tag--regulada" : ""}`}>{n.regla}</span>
              <h3 class="l26-nivel-title">{n.nivel}</h3>
              <p class="l26-nivel-desc">{n.desc}</p>
            </article>
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal client:visible delay={0.25}>
        <p class="l26-niveles-note">
          En los tres niveles el resultado es el mismo: <strong>el establecimiento es responsable de que la regla se cumpla</strong> — <em class="l26-note-hl">y de poder demostrarlo</em>.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════ 03 · LAS 5 EXCEPCIONES (cream) ═══════════ -->
  <section class="l26 section--light-alt" id="excepciones">
    <div class="container">
      <ScrollReveal client:visible>
        <div class="l26-head">
          <span class="section-number" aria-hidden="true">03</span>
          <div>
            <span class="label">Lo que la ley permite</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              Cinco excepciones,
              <span class="heading-accent" style="display: block;">un mismo estándar</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <div class="l26-exc-list">
        {excepciones.map((e, i) => (
          <ScrollReveal client:visible delay={i * 0.07}>
            <div class="l26-exc">
              <span class="l26-exc-num" aria-hidden="true">{e.num}</span>
              <div class="l26-exc-body">
                <h3 class="l26-exc-title">{e.title}</h3>
                <p class="l26-exc-desc">{e.desc}</p>
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal client:visible delay={0.3}>
        <p class="l26-exc-note">
          Las excepciones no son la falla del sistema — son parte de él. Lo que la ley espera es que estén
          <strong> reguladas, documentadas y aplicadas con el mismo criterio para todos</strong>.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════ 04 · CRONOLOGÍA (dark) ═══════════ -->
  <section class="l26 section--dark section-ambient" id="plazos">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="l26-head">
          <span class="section-number" aria-hidden="true">04</span>
          <div>
            <span class="label">Cronología y plazos</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              Las fechas
              <span class="heading-accent">que importan</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <div class="l26-timeline">
        <div class="l26-tl-spine" aria-hidden="true"></div>
        {hitos.map((h, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <div class={`l26-hito l26-hito--${h.state}`}>
              <span class="l26-hito-dot" aria-hidden="true"></span>
              <div class="l26-hito-card">
                <div class="l26-hito-meta">
                  <span class="l26-hito-date">{h.date}</span>
                  {h.tag && <span class="l26-hito-tag">{h.tag}</span>}
                </div>
                <h3 class="l26-hito-title">{h.title}</h3>
                <p class="l26-hito-desc">{h.desc}</p>
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ 05 · QUÉ vs CÓMO (cream) ═══════════ -->
  <section class="l26 section--light-alt" id="implementacion">
    <div class="container">
      <ScrollReveal client:visible>
        <div class="l26-head">
          <span class="section-number" aria-hidden="true">05</span>
          <div>
            <span class="label">De la norma a la sala</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              La ley dice <em class="l26-em">qué</em>.
              <span class="heading-accent" style="display: block;">BloKKit resuelve el cómo.</span>
            </h2>
            <p class="body-lg l26-intro">
              Cuatro preguntas que la norma deja abiertas — y que todo equipo directivo tiene que responder antes de que las responda la rutina.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <div class="l26-brechas">
        {brechas.map((b, i) => (
          <ScrollReveal client:visible delay={i * 0.08}>
            <article class="l26-brecha">
              <div class="l26-brecha-q">
                <span class="l26-brecha-mark" aria-hidden="true">?</span>
                <h3 class="l26-brecha-title">{b.q}</h3>
              </div>
              <p class="l26-brecha-gap">{b.gap}</p>
              <div class="l26-brecha-solve">
                <span class="l26-solve-tag">Con BloKKit</span>
                <p>{b.solve}</p>
              </div>
            </article>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ CTA FINAL ═══════════ -->
  <FinalCta
    title="La ley ya rige."
    accent="Pon tu colegio al día."
    subtitle="Te ayudamos a diseñar el protocolo y la infraestructura para poner tu colegio en cumplimiento desde hoy."
    primaryText="Diseñar mi protocolo"
    primaryHref="/contacto"
    secondaryText="Ver producto →"
    secondaryHref="/producto"
  />

  <Footer slot="footer" />
</BaseLayout>

<style>
  .l26 {
    padding-block: var(--space-20);
  }

  /* ── Section head (number + label + h2), shared rhythm ── */
  .l26-head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    margin-bottom: var(--space-12);
  }

  @media (max-width: 720px) {
    .l26-head {
      flex-direction: column;
      gap: var(--space-3);
    }
  }

  /* ── 01 · Ficha ── */
  .l26-ficha {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
    gap: var(--space-12);
    align-items: center;
  }

  @media (max-width: 880px) {
    .l26-ficha {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .l26-giant {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(4.2rem, 2.4rem + 9vw, 9rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: transparent;
    -webkit-text-stroke: 2px rgba(31, 31, 31, 0.82);
    user-select: none;
  }

  .l26-giant-label {
    max-width: 420px;
    margin-top: var(--space-4);
    font-size: var(--text-base);
    line-height: 1.55;
    color: var(--text-dark-secondary);
  }

  .l26-source {
    display: inline-block;
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-dark);
    text-decoration: none;
    border-bottom: 1px solid rgba(37, 137, 199, 0.35);
    padding-bottom: 2px;
    transition: opacity 0.25s ease;
  }

  .l26-source:hover {
    opacity: 0.7;
  }

  .l26-ficha-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  @media (max-width: 480px) {
    .l26-ficha-grid {
      grid-template-columns: 1fr;
    }
  }

  .l26-dato {
    height: 100%;
    padding: var(--space-5) var(--space-6);
    background: rgba(255, 255, 255, 0.62);
    border: 1px solid rgba(31, 31, 31, 0.08);
    border-radius: var(--radius-lg);
  }

  .l26-dato-k {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dark-muted);
  }

  .l26-dato-v {
    display: block;
    margin-top: var(--space-2);
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 1rem + 0.7vw, 1.45rem);
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--text-dark);
    line-height: 1.05;
    overflow-wrap: break-word;
  }

  /* palabras largas tipo "Superintendencia": un paso menos de escala
     para que nunca desborden la card */
  .l26-dato-v--sm {
    font-size: clamp(0.9rem, 0.8rem + 0.4vw, 1.05rem);
  }

  .l26-dato-sub {
    display: block;
    margin-top: 4px;
    font-size: var(--text-sm);
    color: var(--text-dark-secondary);
  }

  /* ── Deadline callout (coral = plazo que aprieta) ── */
  .l26-deadline {
    margin-top: var(--space-10);
    padding: var(--space-6) var(--space-8);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-3) var(--space-8);
    align-items: center;
    background: var(--data-coral-pale);
    border: 1px solid rgba(251, 110, 96, 0.3);
    border-left: 3px solid var(--data-coral);
    border-radius: var(--radius-lg);
  }

  @media (max-width: 760px) {
    .l26-deadline {
      grid-template-columns: minmax(0, 1fr);
      padding-inline: var(--space-5);
    }
  }

  .l26-deadline-tag {
    grid-column: 1 / -1;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--data-coral);
  }

  .l26-deadline p {
    margin: 0;
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--text-dark-secondary);
    max-width: 60ch;
  }

  .l26-deadline strong {
    color: var(--text-dark);
  }

  .l26-deadline .btn {
    white-space: normal;
  }

  /* ── 02 · Niveles ── */
  .l26-niveles {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  @media (max-width: 880px) {
    .l26-niveles {
      grid-template-columns: 1fr;
    }
  }

  .l26-nivel {
    height: 100%;
    padding: var(--space-8) var(--space-6);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .l26-nivel:hover {
    transform: translateY(-4px);
    border-color: rgba(127, 206, 236, 0.35);
  }

  .l26-nivel-tag {
    display: inline-block;
    padding: 5px 12px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--data-coral);
    background: var(--data-coral-pale);
    border: 1px solid rgba(251, 110, 96, 0.3);
    border-radius: 999px;
  }

  .l26-nivel-tag--regulada {
    color: var(--accent);
    background: rgba(127, 206, 236, 0.12);
    border-color: rgba(127, 206, 236, 0.3);
  }

  .l26-nivel-title {
    margin-top: var(--space-5);
    font-family: var(--font-heading);
    font-size: clamp(1.45rem, 1.2rem + 1vw, 1.9rem);
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--text-primary);
    line-height: 1;
  }

  .l26-nivel-desc {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .l26-niveles-note {
    margin-top: var(--space-10);
    text-align: center;
    font-size: var(--text-base);
    color: var(--text-secondary);
  }

  .l26-niveles-note strong {
    color: var(--text-primary);
  }

  /* el hincapié: la trazabilidad es el puente hacia BloKKit */
  .l26-niveles-note .l26-note-hl {
    font-style: normal;
    font-weight: 600;
    color: var(--accent);
  }

  /* ── 03 · Excepciones ── */
  .l26-exc-list {
    max-width: 880px;
  }

  .l26-exc {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-6);
    align-items: start;
    padding-block: var(--space-5);
    border-bottom: 1px solid rgba(31, 31, 31, 0.1);
  }

  .l26-exc-num {
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 1.4rem + 2vw, 2.8rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(31, 31, 31, 0.45);
    user-select: none;
    min-width: 2.2em;
  }

  .l26-exc-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--text-dark);
  }

  .l26-exc-desc {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-dark-secondary);
    max-width: 62ch;
  }

  .l26-exc-note {
    max-width: 880px;
    margin-top: var(--space-8);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--text-dark-secondary);
  }

  .l26-exc-note strong {
    color: var(--text-dark);
  }

  /* ── 04 · Timeline ── */
  .l26-timeline {
    position: relative;
    max-width: 760px;
    padding-left: var(--space-8);
  }

