---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const pageTitle = "Producto | BloKKit";
const pageDescription = "Conoce el ecosistema BloKKit: Funda Faraday, Dock de Desbloqueo y Plataforma Digital.";

const architecturePieces = [
  {
    icon: "📱",
    tag: "Bloqueo fisico",
    title: "Funda BloKKit",
    description:
      "Malla de polimeros conductivos que bloquea senales 3G, 4G, 5G, WiFi 2.4/5GHz y Bluetooth sin quitar el telefono al usuario.",
    bullets: ["99.9% efectividad de bloqueo", "50.000+ cierres garantizados"]
  },
  {
    icon: "🗝️",
    tag: "Control de apertura",
    title: "Dock de desbloqueo",
    description:
      "Apertura magnetica controlada en segundos, con flujo estandar o Smart Dock para trazabilidad completa por operador.",
    bullets: ["Apertura menor a 3 segundos", "Operacion con responsables autorizados"]
  },
  {
    icon: "📊",
    tag: "Trazabilidad",
    title: "Plataforma de gestion",
    description:
      "Panel con KPIs en tiempo real, soporte por tickets y reportes exportables para operacion institucional y compliance.",
    bullets: ["Dashboard operativo en vivo", "Soporte tecnico integrado"]
  }
];

const rolloutSteps = [
  {
    step: "01",
    title: "Politica operativa",
    description: "Definimos protocolo por recinto, excepciones permitidas y responsables por turno."
  },
  {
    step: "02",
    title: "Despliegue por capas",
    description: "Implementamos funda + dock + plataforma con onboarding para equipos directivos y operativos."
  },
  {
    step: "03",
    title: "Medicion continua",
    description: "Seguimos indicadores de uso, incidencias y cumplimiento para ajustar sin friccion."
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header />

  <main>
    <section class="page-hero section-tone-dark">
      <div class="page-hero-bg">
        <div class="gradient-orb orb-1"></div>
        <div class="gradient-orb orb-2"></div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
        <span class="page-label" data-reveal>Sistema BloKKit</span>
        <h1 class="page-title" data-reveal style="--delay: 100ms;">
          Arquitectura <span class="text-accent">Integral</span><br />
          para operacion sin friccion
        </h1>
        <p class="page-subtitle" data-reveal style="--delay: 200ms;">
          Tres piezas conectadas que convierten una politica institucional en cumplimiento diario,
          medible y escalable.
        </p>
      </div>
    </section>

    <section id="arquitectura" class="architecture page-surface section-tone-slate">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="architecture-head" data-reveal>
          <span class="page-label">Arquitectura BloKKit</span>
          <h2 class="architecture-title">
            tres capas conectadas<br />
            para <span class="text-accent">cumplimiento real</span>
          </h2>
          <p class="section-lead">
            Desde el bloqueo fisico hasta la trazabilidad digital: una operacion continua, auditada y simple de ejecutar.
          </p>
        </div>

        <div class="architecture-grid">
          {architecturePieces.map((piece, index) => (
            <article class={`architecture-card ${index === 1 ? "is-featured" : ""}`} data-reveal style={`--delay: ${index * 110}ms`}>
              <div class="architecture-top">
                <span class="icon-chip" aria-hidden="true">{piece.icon}</span>
                <span class="tag-chip">{piece.tag}</span>
              </div>
              <h3>{piece.title}</h3>
              <p>{piece.description}</p>
              <ul>
                {piece.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="module-section page-surface section-tone-dark" id="funda">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 module-grid">
        <div class="module-content" data-reveal>
          <span class="module-number">01</span>
          <h2 class="module-title">Funda BloKKit</h2>
          <p class="module-description">
            Tecnologia Faraday para bloquear senales sin confiscar dispositivos. El telefono permanece con su dueno,
            pero fuera de red durante el bloque operativo.
          </p>
          <ul class="feature-list">
            <li>Bloqueo activo de celular, WiFi, Bluetooth y NFC</li>
            <li>Compatible con smartphones iOS y Android</li>
            <li>Cierres robustos para uso intensivo diario</li>
            <li>Diseno resistente, lavable y de larga duracion</li>
          </ul>
        </div>

        <div class="module-visual visual-funda" data-reveal style="--delay: 140ms;">
          <img src="/images/blokkit-fundas.png" alt="Fundas BloKKit" loading="lazy" />
        </div>
      </div>
    </section>

    <section class="module-section page-surface section-tone-slate" id="dock">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 module-grid reverse">
        <div class="module-visual visual-dock" data-reveal>
          <img src="/images/dock%20standard.png" alt="Dock BloKKit" loading="lazy" class="dock-photo" />
        </div>

        <div class="module-content" data-reveal style="--delay: 140ms;">
          <span class="module-number">02</span>
          <h2 class="module-title">Dock de Desbloqueo</h2>
          <p class="module-description">
            Estacion magnetica para apertura en segundos. Permite controlar excepciones en tiempo real y mantener
            continuidad operacional sin romper protocolo.
          </p>
          <ul class="feature-list">
            <li>Apertura menor a 3 segundos por dispositivo</li>
            <li>Control de acceso por roles autorizados</li>
            <li>Version estandar o Smart Dock con registro</li>
            <li>Operacion simple sin friccion para terreno</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="module-section page-surface section-tone-dark" id="plataforma">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 module-grid">
        <div class="module-content" data-reveal>
          <span class="module-number">03</span>
          <h2 class="module-title">Plataforma Digital</h2>
          <p class="module-description">
            El centro de gestion para monitorear adopcion, incidencias y cumplimiento por sede, curso, equipo o turno.
            Todo en una sola vista operativa.
          </p>
          <ul class="feature-list">
            <li>KPIs de uso y cumplimiento en tiempo real</li>
            <li>Tickets de soporte con trazabilidad completa</li>
            <li>Gestion de usuarios multinivel y permisos</li>
            <li>Reportes exportables para auditoria interna</li>
          </ul>
        </div>

        <div class="module-visual visual-platform" data-reveal style="--delay: 140ms;">
          <div class="admin-dashboard" aria-hidden="true">
            <aside class="admin-sidebar">
              <span class="sidebar-logo">BK</span>
              <span class="sidebar-item active"></span>
              <span class="sidebar-item"></span>
              <span class="sidebar-item"></span>
              <span class="sidebar-item"></span>
            </aside>
            <div class="admin-main">
              <div class="admin-topbar">
                <span class="topbar-pill">Admin Panel</span>
                <span class="topbar-pill muted">Live</span>
              </div>
              <div class="kpi-row">
                <div class="kpi-box">
                  <strong>94%</strong>
                  <span>Cumplimiento</span>
                </div>
                <div class="kpi-box">
                  <strong>128</strong>
                  <span>Tickets hoy</span>
                </div>
                <div class="kpi-box">
                  <strong>37</strong>
                  <span>Sedes activas</span>
                </div>
              </div>
              <div class="chart-row">
                <div class="line-chart">
                  <span class="line-segment seg-1"></span>
                  <span class="line-segment seg-2"></span>
                  <span class="line-segment seg-3"></span>
                  <span class="line-glow"></span>
                </div>
                <div class="bar-chart">
                  <span class="bar bar-1"></span>
                  <span class="bar bar-2"></span>
                  <span class="bar bar-3"></span>
                  <span class="bar bar-4"></span>
                </div>
              </div>
              <div class="table-mock">
                <span class="table-line"></span>
                <span class="table-line short"></span>
                <span class="table-line"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="product-slate-flow">
      <section class="ops-section page-surface section-tone-slate">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
          <div class="architecture-head" data-reveal>
            <span class="page-label">Implementacion</span>
            <h2 class="architecture-title">
              despliegue en <span class="text-accent">3 pasos</span>
            </h2>
          </div>

          <div class="ops-grid">
            {rolloutSteps.map((step, index) => (
              <article class="ops-card" data-reveal style={`--delay: ${index * 120}ms`}>
                <span class="ops-step">{step.step}</span>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="final-cta section-tone-slate">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
          <div class="final-cta-card text-center" data-reveal>
            <h2 class="final-cta-title">
              listo para activar<br />
              el sistema completo?
            </h2>
            <p class="final-cta-subtitle" data-reveal style="--delay: 100ms;">
              Te mostramos como implementar BloKKit en tu operacion con un plan de despliegue realista y medible.
            </p>
            <div class="final-cta-buttons" data-reveal style="--delay: 200ms;">
              <a href="/contacto" class="btn-primary-large product-cta-primary">Agendar Demo Personalizada</a>
              <a href="/beneficios" class="btn-secondary-large">Ver beneficios por sector</a>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  @keyframes float-y {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes dash-bars {
    0%,
    100% {
      transform: scaleY(0.45);
    }

    50% {
      transform: scaleY(1);
    }
  }

  @keyframes dash-sweep {
    0% {
      transform: translateX(-115%);
    }

    100% {
      transform: translateX(140%);
    }
  }

  @keyframes dash-pulse {
    0%,
    100% {
      opacity: 0.72;
    }

    50% {
      opacity: 1;
    }
  }

  /* Dark style parity with Beneficios */
  .page-hero.section-tone-dark {
    background-color: #080808;
    background-image:
      linear-gradient(rgba(0, 194, 209, 0.052) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 194, 209, 0.052) 1px, transparent 1px),
      radial-gradient(980px 380px at 14% -10%, rgba(0, 194, 209, 0.24) 0%, transparent 62%),
      radial-gradient(880px 340px at 84% 12%, rgba(0, 194, 209, 0.12) 0%, transparent 64%),
      linear-gradient(180deg, #121212 0%, #090909 56%, #060606 100%);
    background-size: 64px 64px, 64px 64px, auto, auto, auto;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .page-hero.section-tone-dark .orb-1 {
    background: radial-gradient(circle, rgba(0, 194, 209, 0.3) 0%, transparent 72%);
    opacity: 0.52;
  }

  .page-hero.section-tone-dark .orb-2 {
    background: radial-gradient(circle, rgba(0, 194, 209, 0.2) 0%, transparent 72%);
    opacity: 0.44;
  }

  .page-hero.section-tone-dark .page-label {
    border-color: rgba(62, 224, 240, 0.36);
    background: rgba(4, 10, 12, 0.7);
    color: #67e8f9;
  }

  .page-hero.section-tone-dark .page-subtitle {
    color: rgba(226, 232, 240, 0.82) !important;
  }

  .architecture,
  .ops-section,
  .final-cta.section-tone-slate {
    background-color: #dce5ef;
    background-image:
      radial-gradient(900px 320px at 18% 18%, rgba(14, 116, 144, 0.12) 0%, transparent 68%),
      radial-gradient(760px 280px at 84% 84%, rgba(14, 116, 144, 0.1) 0%, transparent 72%),
      linear-gradient(180deg, #dbe4ee 0%, #e6edf5 100%);
  }

  .product-slate-flow {
    background-color: #dce5ef;
    background-image:
      radial-gradient(900px 320px at 18% 18%, rgba(14, 116, 144, 0.12) 0%, transparent 68%),
      radial-gradient(760px 280px at 84% 84%, rgba(14, 116, 144, 0.1) 0%, transparent 72%),
      linear-gradient(180deg, #dbe4ee 0%, #e6edf5 100%);
  }

  .product-slate-flow > .section-tone-slate {
    background: transparent !important;
    border-top: 0 !important;
    border-bottom: 0 !important;
    box-shadow: none !important;
  }

  .architecture-head {
    text-align: center;
    margin: 0 auto 2.3rem;
    max-width: 74ch;
  }

  .architecture-title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 0.98;
    margin-bottom: 0.9rem;
    color: #0f172a !important;
  }

  .architecture .section-lead,
  .ops-section .section-lead {
    color: rgba(30, 41, 59, 0.9) !important;
  }

  .architecture .page-label,
  .ops-section .page-label {
    border-color: rgba(14, 116, 144, 0.28);
    background: rgba(224, 242, 254, 0.82);
    color: #0e7490;
  }

  .architecture-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .architecture-card {
    position: relative;
    overflow: hidden;
    border-radius: 1.35rem;
    border: 1px solid rgba(148, 163, 184, 0.34);
    background: linear-gradient(165deg, rgba(255, 255, 255, 0.66) 0%, rgba(248, 250, 252, 0.5) 100%);
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.62);
    padding: 1.2rem;
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.24s ease, border-color 0.24s ease;
  }

  .architecture-card::before {
    content: "";
    position: absolute;
    inset: -40% -20% auto;
    height: 130px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.52) 0%, transparent 72%);
    pointer-events: none;
  }

  .architecture-card.is-featured {
    background: linear-gradient(165deg, rgba(224, 242, 254, 0.74) 0%, rgba(207, 235, 248, 0.58) 100%);
    border-color: rgba(14, 116, 144, 0.34);
  }

  .architecture-card:hover {
    transform: translateY(-6px);
    border-color: rgba(100, 116, 139, 0.42);
    box-shadow: 0 24px 38px rgba(15, 23, 42, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  .architecture-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.85rem;
    gap: 0.7rem;
  }

  .icon-chip {
    width: 3.05rem;
    height: 3.05rem;
    border-radius: 0.92rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(14, 116, 144, 0.24);
    background: rgba(224, 242, 254, 0.78);
    font-size: 1.32rem;
    animation: float-y 4.8s ease-in-out infinite;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    border: 1px solid rgba(14, 116, 144, 0.24);
    background: rgba(224, 242, 254, 0.8);
    color: #0e7490;
    padding: 0.3rem 0.78rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .architecture-card h3 {
    margin: 0 0 0.68rem;
    font-size: clamp(1.4rem, 2.2vw, 1.8rem);
    line-height: 0.98;
    color: #0f172a !important;
  }

  .architecture-card p {
    margin: 0;
    color: rgba(51, 65, 85, 0.9) !important;
    line-height: 1.56;
    padding-bottom: 0.88rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.28);
  }

  .architecture-card ul {
    margin: 0.95rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.5rem;
  }

  .architecture-card li {
    position: relative;
    padding-left: 1rem;
    color: rgba(51, 65, 85, 0.92) !important;
    font-size: 0.95rem;
  }

  .architecture-card li::before {
    content: "";
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #0891b2;
    position: absolute;
    left: 0;
    top: 0.52em;
  }

  .module-section {
    padding: 6rem 0;
  }

  .module-section.section-tone-slate {
    background-color: #dce5ef;
    background-image:
      radial-gradient(900px 320px at 18% 18%, rgba(14, 116, 144, 0.12) 0%, transparent 68%),
      radial-gradient(760px 280px at 84% 84%, rgba(14, 116, 144, 0.1) 0%, transparent 72%),
      linear-gradient(180deg, #dbe4ee 0%, #e6edf5 100%);
    border-top: 1px solid rgba(148, 163, 184, 0.22);
    border-bottom: 1px solid rgba(148, 163, 184, 0.22);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22), inset 0 -1px 0 rgba(255, 255, 255, 0.22);
  }

  .module-section.section-tone-dark {
    position: relative;
    background-color: #090909;
    background-image:
      linear-gradient(rgba(0, 194, 209, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 194, 209, 0.055) 1px, transparent 1px),
      radial-gradient(980px 420px at 14% -12%, rgba(0, 194, 209, 0.24), transparent 60%),
      radial-gradient(820px 340px at 86% 10%, rgba(0, 194, 209, 0.14), transparent 62%),
      linear-gradient(180deg, #121212 0%, #0b0b0b 52%, #070707 100%);
    background-size: 64px 64px, 64px 64px, auto, auto, auto;
    background-position: 0 0, 0 0, center, center, center;
  }

  .module-section.section-tone-dark::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(700px 260px at 16% 8%, rgba(0, 194, 209, 0.12) 0%, transparent 72%),
      radial-gradient(620px 220px at 84% 92%, rgba(0, 194, 209, 0.08) 0%, transparent 74%);
    z-index: 0;
  }

  .module-section.section-tone-dark .max-w-7xl {
    position: relative;
    z-index: 1;
  }

  .module-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2.2rem;
    align-items: center;
  }

  .module-grid.reverse {
    grid-template-columns: 0.95fr 1.05fr;
  }

  .module-number {
    display: inline-block;
    font-family: "Bebas Neue", sans-serif;
    font-size: 3.4rem;
    line-height: 1;
    color: rgba(103, 232, 249, 0.4);
    margin-bottom: 0.55rem;
  }

  .module-title {
    margin: 0 0 0.8rem;
    font-size: clamp(2.1rem, 4vw, 3.2rem);
    line-height: 0.98;
  }

  .module-description {
    margin: 0 0 1.5rem;
    font-size: 1.03rem;
    line-height: 1.68;
    max-width: 58ch;
  }

  .feature-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.7rem;
  }

  .feature-list li {
    position: relative;
    padding: 0.7rem 0.9rem 0.7rem 2.2rem;
    border-radius: 0.9rem;
    border: 1px solid rgba(148, 163, 184, 0.24);
    background: linear-gradient(160deg, rgba(19, 19, 19, 0.62), rgba(11, 11, 11, 0.46));
    color: rgba(226, 232, 240, 0.9);
    transition: transform 0.22s ease, border-color 0.22s ease;
  }

  .feature-list li::before {
    content: "";
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    width: 0.92rem;
    height: 0.92rem;
    border-radius: 999px;
    border: 1px solid rgba(34, 211, 238, 0.5);
    background: rgba(34, 211, 238, 0.22);
    box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.09);
  }

  .feature-list li:hover {
    transform: translateX(5px);
    border-color: rgba(34, 211, 238, 0.34);
  }

  .module-visual {
    position: relative;
    min-height: 320px;
    border-radius: 1.35rem;
    border: 1px solid rgba(148, 163, 184, 0.28);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .module-visual img {
    width: 85%;
    max-width: 460px;
    object-fit: contain;
    filter: drop-shadow(0 22px 34px rgba(2, 6, 23, 0.32));
    animation: float-y 5.5s ease-in-out infinite;
  }

  .visual-funda {
    background:
      radial-gradient(460px 180px at 12% 84%, rgba(0, 194, 209, 0.22), transparent 70%),
      linear-gradient(160deg, rgba(8, 19, 38, 0.72), rgba(4, 8, 20, 0.88));
  }

  .visual-dock {
    background: linear-gradient(165deg, rgba(255, 255, 255, 0.92) 0%, rgba(241, 245, 249, 0.72) 100%);
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.64);
  }

  .visual-dock .dock-photo {
    width: 94%;
    max-width: 680px;
    border-radius: 1rem;
    filter: drop-shadow(0 22px 34px rgba(2, 6, 23, 0.24));
    animation: float-y 5.4s ease-in-out infinite;
  }

  .visual-platform {
    background:
      radial-gradient(420px 170px at 84% 10%, rgba(0, 194, 209, 0.2), transparent 70%),
      linear-gradient(160deg, rgba(8, 19, 38, 0.72), rgba(4, 8, 20, 0.88));
  }

  .admin-dashboard {
    width: 92%;
    min-height: 285px;
    border-radius: 1rem;
    border: 1px solid rgba(34, 211, 238, 0.24);
    background:
      linear-gradient(rgba(34, 211, 238, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 211, 238, 0.04) 1px, transparent 1px),
      linear-gradient(160deg, rgba(4, 14, 30, 0.88), rgba(2, 9, 21, 0.94));
    background-size: 20px 20px, 20px 20px, auto;
    box-shadow: 0 18px 36px rgba(2, 8, 23, 0.38);
    display: grid;
    grid-template-columns: 64px 1fr;
    overflow: hidden;
  }

  .admin-sidebar {
    border-right: 1px solid rgba(34, 211, 238, 0.18);
