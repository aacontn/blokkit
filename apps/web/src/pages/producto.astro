---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import MagneticButton from "../components/ui/MagneticButton.tsx";
import TextSplitReveal from "../components/ui/TextSplitReveal.tsx";

const architecturePieces = [
  { 
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="arch-card__icon-svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
    pill: "Bloqueo físico", 
    title: "Funda BloKKit", 
    desc: "Malla de polímeros conductivos que bloquea señales 3G, 4G, 5G, WiFi 2.4/5GHz y Bluetooth sin quitar el teléfono al usuario.", 
    specs: ["99.9% efectividad de bloqueo", "50.000+ cierres garantizados"] 
  },
  { 
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="arch-card__icon-svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4"/><path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/></svg>`,
    pill: "Control de apertura", 
    title: "Dock de Desbloqueo", 
    desc: "Apertura magnética controlada en segundos, con flujo estándar o Smart Dock para trazabilidad completa por operador.", 
    specs: ["Apertura menor a 3 segundos", "Operación con responsables autorizados"], 
    featured: true 
  },
  { 
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="arch-card__icon-svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>`,
    pill: "Trazabilidad", 
    title: "Plataforma de Gestión", 
    desc: "Panel web con dashboard de KPIs en tiempo real, soporte por tickets y reportes exportables para operación institucional y compliance.", 
    specs: ["Dashboard operativo en vivo", "Soporte técnico integrado"] 
  },
];

const rolloutSteps = [
  { step: "01", title: "Política operativa", desc: "Definimos protocolo por recinto, excepciones permitidas y responsables por turno." },
  { step: "02", title: "Despliegue por capas", desc: "Implementamos funda + dock + plataforma con onboarding para equipos directivos y operativos." },
  { step: "03", title: "Medición continua", desc: "Seguimos indicadores de uso, incidencias y cumplimiento para ajustar sin fricción." },
];
---

<BaseLayout>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero hero--sub hero-mesh-bg" style="padding-bottom: 40px; min-height: auto;">
    <div class="mesh-gradient" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero__content container">
      <span class="label fade-in-up" style="display: inline-block; padding: 6px 16px; background: rgba(127, 206, 236, 0.1); border-radius: var(--radius-full); border: 1px solid rgba(127, 206, 236, 0.4); color: var(--accent); letter-spacing: 0.1em; margin-bottom: var(--space-4); font-size: 0.75rem; font-weight: 700;">Fundas Bloqueadoras de Señal</span>
      <h1 class="heading-1 hero__title" style="text-transform: uppercase;">
        <TextSplitReveal client:load text="ARQUITECTURA" as="span" splitBy="word" delay={0.15} />
        <TextSplitReveal client:load text="INTEGRAL" as="span" className="text-accent" splitBy="word" delay={0.25} /><br/>
        <TextSplitReveal client:load text="PARA OPERACIÓN SIN FRICCIÓN" as="span" splitBy="word" delay={0.35} />
      </h1>
      <ScrollReveal client:load delay={0.4}>
        <p class="hero__subtitle body-lg" style="margin-top: var(--space-6);">
          Tres piezas conectadas que convierten una política institucional en<br/>cumplimiento diario, medible y escalable.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- Architecture cards -->
  <section class="arch section--light-alt section--lg" id="arquitectura" style="position: relative; overflow: hidden; padding-block: var(--space-20);">
    <!-- Grid -->
    <div class="ley__grid-overlay" aria-hidden="true"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <div style="text-align: center; margin-bottom: var(--space-12)">
        <ScrollReveal client:load>
          <TextSplitReveal client:visible text="Tres capas conectadas" className="heading-2" style="margin-top: var(--space-4); margin-bottom: 0; color: #111827; text-transform: uppercase; line-height: 1.1;" splitBy="word" delay={0.1} />
          <TextSplitReveal client:visible text="para cumplimiento real" className="heading-2" style="margin-top: 0; color: var(--accent); text-transform: uppercase; line-height: 1.1;" splitBy="word" delay={0.2} />
          <p class="body-lg" style="max-width: 600px; margin-inline: auto; margin-top: var(--space-4); color: var(--text-dark-secondary); font-size: 0.95rem;">
            Desde el bloqueo físico hasta la trazabilidad digital: una operación continua, auditada y simple de ejecutar.
          </p>
        </ScrollReveal>
      </div>
      
      <div class="arch__grid">
        {architecturePieces.map((card, i) => (
          <ScrollReveal client:visible delay={i * 0.12}>
            <div class={`arch-card ${card.featured ? "arch-card--featured" : ""}`}>
              <div class="arch-card__header">
                <div class="arch-card__icon" set:html={card.icon} />
                <span class="arch-card__badge">{card.pill}</span>
              </div>
              <h3 class="arch-card__title">{card.title}</h3>
              <p class="arch-card__desc">{card.desc}</p>
              <div class="arch-card__divider"></div>
              <ul class="arch-card__list">
                {card.specs.map((s) => <li>{s}</li>)}
              </ul>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Funda BloKKit -->
  <section class="section--lg section--dark" id="funda">
    <!-- Main product module: text + hero image -->
    <div class="container product-module">
      <ScrollReveal client:visible className="product-module__content">
        <span class="product-module__num">01</span>
        <h2 class="heading-2">Funda BloKKit</h2>
        <p class="body-lg" style="color: var(--text-secondary); max-width: 52ch; margin-top: var(--space-3)">
          Malla de polímeros conductivos tipo Faraday que bloquea todas las señales del teléfono sin necesidad de confiscarlo. El dispositivo permanece con su dueño, pero completamente fuera de red durante el bloque operativo.
        </p>
      </ScrollReveal>
      <ScrollReveal client:visible delay={0.2} className="product-module__visual">
        <img src="/images/blokkit-fundas.webp" alt="Fundas BloKKit en tres colores: negro, gris y azul" loading="lazy" width="460" height="400" />
      </ScrollReveal>
    </div>

    <!-- Feature highlight cards -->
    <div class="container" style="margin-top: var(--space-12);">
      <div class="funda-features">
        <ScrollReveal client:visible delay={0.05}>
          <div class="glass-card funda-feature-card">
            <div class="funda-feature-card__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h4 class="funda-feature-card__title">Malla Faraday</h4>
            <p class="funda-feature-card__desc">Bloquea señales 3G, 4G, 5G, WiFi 2.4/5GHz, Bluetooth y NFC con <strong>99.9% de efectividad</strong> comprobada.</p>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.15}>
          <div class="glass-card funda-feature-card funda-feature-card--accent">
            <div class="funda-feature-card__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h4 class="funda-feature-card__title">Cierre Magnético Reforzado</h4>
            <p class="funda-feature-card__desc"><strong>+50.000 cierres garantizados.</strong> Imposible de abrir manualmente — solo se desbloquea con el Dock autorizado.</p>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.25}>
          <div class="glass-card funda-feature-card">
            <div class="funda-feature-card__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m6.8 15-3.5 2"/><path d="m20.7 17-3.5-2"/><path d="M6.8 9 3.3 7"/><path d="m20.7 7-3.5 2"/><circle cx="12" cy="12" r="4"/></svg>
            </div>
            <h4 class="funda-feature-card__title">Diseño Resistente</h4>
            <p class="funda-feature-card__desc">Lavable, resistente al uso intensivo diario. Compatible con cualquier smartphone iOS y Android de hasta 6.9".</p>
          </div>
        </ScrollReveal>
      </div>
    </div>

    <!-- Detail photo gallery -->
    <div class="container" style="margin-top: var(--space-12);">
      <div class="funda-gallery">
        <ScrollReveal client:visible delay={0.05}>
          <div class="funda-gallery__item glass-card">
            <div class="funda-gallery__img">
              <img src="/images/step-01-guarda.png" alt="Teléfono entrando en la funda BloKKit" loading="lazy" width="400" height="400" />
            </div>
            <div class="funda-gallery__caption">
              <span class="funda-gallery__num">01</span>
              <p>Introduce el teléfono en la funda</p>
            </div>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.15}>
          <div class="funda-gallery__item glass-card">
            <div class="funda-gallery__img">
              <img src="/images/step-02-asegura.png" alt="Close-up del cierre magnético reforzado BloKKit" loading="lazy" width="400" height="400" />
            </div>
            <div class="funda-gallery__caption">
              <span class="funda-gallery__num">02</span>
              <p>El cierre magnético se sella automáticamente</p>
            </div>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.25}>
          <div class="funda-gallery__item glass-card">
            <div class="funda-gallery__img">
              <img src="/images/step-03-bloquea.png" alt="Señales bloqueadas por la funda Faraday BloKKit" loading="lazy" width="400" height="400" />
            </div>
            <div class="funda-gallery__caption">
              <span class="funda-gallery__num">03</span>
              <p>Todas las señales quedan bloqueadas</p>
            </div>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- Dock -->
  <section class="section--lg section--light-alt">
    <div class="container product-module product-module--reverse">
      <ScrollReveal client:visible className="product-module__visual">
        <img src="/images/dock-standard.webp" alt="Dock de Desbloqueo BloKKit" loading="lazy" width="600" height="400" />
      </ScrollReveal>
      <ScrollReveal client:visible delay={0.2} className="product-module__content">
        <span class="product-module__num">02</span>
        <h2 class="heading-2">Dock de Desbloqueo</h2>
        <p class="body-lg" style="color: var(--text-secondary); max-width: 52ch; margin-top: var(--space-3)">
          Estación magnética para apertura en segundos. Permite controlar excepciones en tiempo real y mantener continuidad operacional sin romper protocolo.
        </p>
        <ul class="product-features">
          <li>Apertura menor a 3 segundos por dispositivo</li>
          <li>Control de acceso por roles autorizados</li>
          <li>Versión estándar o Smart Dock con registro</li>
          <li>Operación simple sin fricción para terreno</li>
        </ul>
      </ScrollReveal>
    </div>
  </section>

  <!-- Plataforma -->
  <section class="section--lg">
    <div class="container product-module">
      <ScrollReveal client:visible className="product-module__content">
        <span class="product-module__num">03</span>
        <h2 class="heading-2">Plataforma Digital</h2>
        <p class="body-lg" style="color: var(--text-secondary); max-width: 52ch; margin-top: var(--space-3)">
          El centro de gestión para monitorear adopción, incidencias y cumplimiento por sede, curso, equipo o turno. Todo en una sola vista operativa.
        </p>
        <ul class="product-features">
          <li>KPIs de uso y cumplimiento en tiempo real</li>
          <li>Tickets de soporte con trazabilidad completa</li>
          <li>Gestión de usuarios multinivel y permisos</li>
          <li>Reportes exportables para auditoría interna</li>
        </ul>
      </ScrollReveal>
      <ScrollReveal client:visible delay={0.2} className="product-module__visual">
        <div class="platform-mockup" aria-hidden="true">
          <div class="platform-sidebar"><span class="platform-logo">BK</span></div>
          <div class="platform-main">
            <div class="platform-kpis">
              <div class="platform-kpi"><strong>94%</strong><span>Cumplimiento</span></div>
              <div class="platform-kpi"><strong>128</strong><span>Tickets hoy</span></div>
              <div class="platform-kpi"><strong>37</strong><span>Sedes activas</span></div>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Rollout -->
  <section class="section section--light">
    <div class="container">
      <ScrollReveal client:visible>
        <span class="label">Implementación</span>
        <h2 class="heading-2">Despliegue en <span class="text-accent">3 pasos</span></h2>
      </ScrollReveal>
      <div class="grid-3" style="margin-top: var(--space-10)">
        {rolloutSteps.map((step, i) => (
          <ScrollReveal client:visible delay={i * 0.15}>
            <div class="rollout-card">
              <span class="rollout-num">{step.step}</span>
              <h3 class="heading-5" style="margin-top: var(--space-2)">{step.title}</h3>
              <p class="body-sm" style="color: var(--text-secondary); margin-top: var(--space-2)">{step.desc}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section--light-alt section--lg" style="padding-top: 0; padding-bottom: var(--space-24);">
    <div class="container">
      <div class="final-cta__card">
        <div class="final-cta__glow" aria-hidden="true"></div>
        <div class="final-cta__inner">
          <h2 class="heading-2 final-cta__title">¿Listo para activar el sistema completo?</h2>
          <p class="body-lg final-cta__subtitle">
            Te mostramos cómo implementar BloKKit en tu operación con un plan de despliegue realista y medible.
          </p>
          <div class="final-cta__buttons">
            <button type="button" data-cal-link="blokkit/30min" data-cal-namespace="30min" data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}' class="btn btn--primary">Agendar Reunión</button>
            <a href="/beneficios" class="btn btn--ghost">Ver beneficios por sector</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
<style>
  .hero--sub { min-height: 70vh; display: flex; flex-direction: column; justify-content: center; padding-top: 180px; padding-bottom: 80px; position: relative; overflow: hidden; }
  .hero__content { position: relative; z-index: 1; text-align: center; max-width: 900px; display: flex; flex-direction: column; align-items: center; gap: var(--space-5); margin: 0 auto; }
  .hero__subtitle { max-width: 680px; color: var(--text-secondary); }

  /* Grid overlay for arch section matching index.astro */
  .ley__grid-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image: 
      linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    background-position: center top;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 80%);
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 80%);
  }

  .product-module { display: grid; grid-template-columns: 1fr; gap: var(--space-10); align-items: center; }
  @media (min-width: 768px) { 
    .product-module { grid-template-columns: 1fr 1fr; gap: var(--space-16); }
    .product-module--reverse .product-module__visual { order: -1; }
  }

  .product-module__num { font-family: var(--font-heading); font-size: var(--text-5xl); font-weight: 700; color: var(--accent); opacity: 0.15; line-height: 1; margin-bottom: var(--space-2); display: block; }
  .product-module__visual img { width: 100%; max-width: 480px; object-fit: contain; filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.2)); margin: 0 auto; display: block; }

  .product-features { display: flex; flex-direction: column; gap: var(--space-3); margin-top: var(--space-6); }
  .product-features li { position: relative; padding-left: var(--space-6); color: var(--text-secondary); font-size: var(--text-base); }
  .product-features li::before { content: "✓"; position: absolute; left: 0; top: -1px; color: var(--accent); font-weight: 700; font-size: 1.1rem; }

  .platform-mockup { background: var(--bg-dark); border: 1px solid var(--border-medium); border-radius: var(--radius-xl); overflow: hidden; display: flex; height: 320px; box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4); }
  .platform-sidebar { width: 60px; background: rgba(0, 0, 0, 0.3); border-right: 1px solid var(--border-medium); display: flex; flex-direction: column; align-items: center; padding-top: var(--space-4); }
  .platform-logo { font-size: 0.75rem; font-weight: 800; color: var(--accent); }
  .platform-main { flex: 1; padding: var(--space-6); background: radial-gradient(circle at top right, rgba(127, 206, 236, 0.05), transparent 60%); display: flex; align-items: flex-end; }
  .platform-kpis { display: flex; gap: var(--space-4); width: 100%; }
  .platform-kpi { flex: 1; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
  .platform-kpi strong { font-size: 1.5rem; font-family: var(--font-heading); font-weight: 700; color: var(--text-primary); line-height: 1; }
  .platform-kpi span { font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }

  .rollout-card { background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-medium); border-radius: var(--radius-lg); padding: var(--space-6); display: flex; flex-direction: column; transition: transform 0.3s ease; }
  .rollout-card:hover { transform: translateY(-4px); border-color: var(--border-accent); }
  .rollout-num { font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 800; color: var(--accent); line-height: 1; }

  /* Final CTA specific overrides */
  .section--lg .mesh-gradient { opacity: 0.3; }
</style>

<style is:global>
  /* Architecture Grid and Cards (matches home page light section exactly) */
  .arch__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 1024px) {
    .arch__grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  }

  .arch-card { background: #fff; border: 1px solid rgba(0, 0, 0, 0.08); border-radius: var(--radius-lg); padding: var(--space-8) var(--space-6); box-shadow: 0 12px 24px rgba(0, 0, 0, 0.04); display: flex; flex-direction: column; transition: transform 0.3s ease, box-shadow 0.3s ease; height: 100%; }
  .arch-card:hover { transform: translateY(-4px); box-shadow: 0 20px 48px rgba(0, 0, 0, 0.08); }
  
  .arch-card--featured { background: linear-gradient(180deg, rgba(127, 206, 236, 0.06) 0%, rgba(127, 206, 236, 0.15) 100%); border: 1px solid rgba(127, 206, 236, 0.4); box-shadow: 0 16px 32px rgba(127, 206, 236, 0.15); }
  .arch-card__header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-6); gap: var(--space-3); }
  .arch-card__icon { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; border-radius: 12px; background: rgba(0, 0, 0, 0.04); color: var(--accent); flex-shrink: 0; }
  .arch-card--featured .arch-card__icon { background: #fff; border: 1px solid rgba(127, 206, 236, 0.2); }
  .arch-card__icon-svg { width: 20px; height: 20px; stroke: var(--accent); }
  
  .arch-card__badge { font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; padding: 6px 12px; border-radius: var(--radius-full); border: 1px solid rgba(127, 206, 236, 0.3); color: var(--accent-dark); margin-top: 4px; }
  .arch-card__title { font-family: var(--font-heading); font-size: 1.15rem; font-weight: 800; text-transform: uppercase; color: #111827; margin: 0 0 var(--space-3) 0; letter-spacing: -0.01em; }
  .arch-card__desc { font-size: 0.85rem; color: var(--text-dark-secondary); line-height: 1.6; margin: 0; }
  .arch-card__divider { height: 1px; background: rgba(0, 0, 0, 0.08); margin: var(--space-5) 0; width: 100%; }
  .arch-card--featured .arch-card__divider { background: rgba(127, 206, 236, 0.2); }
  
  .arch-card__list { list-style: none; padding: 0; margin: auto 0 0 0; display: flex; flex-direction: column; gap: 12px; }
  .arch-card__list li { font-size: 0.8rem; color: var(--text-dark-secondary); display: flex; align-items: flex-start; gap: 8px; line-height: 1.4; }
  .arch-card__list li::before { content: "•"; color: var(--accent); font-weight: bold; display: block; margin-top: -1px; }

  .product-module { display: grid; grid-template-columns: 1fr; gap: var(--space-10); align-items: center; }
  @media (min-width: 768px) { 
    .product-module { grid-template-columns: 1fr 1fr; gap: var(--space-16); }
    .product-module--reverse .product-module__visual { order: -1; }
  }

  .product-module__num { font-family: var(--font-heading); font-size: var(--text-5xl); font-weight: 700; color: var(--accent); opacity: 0.15; line-height: 1; margin-bottom: var(--space-2); display: block; }
