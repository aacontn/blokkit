---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import FinalCta from "../components/FinalCta.astro";
import PageHero from "../components/PageHero.astro";
import ArchitectureFlow from "../components/ArchitectureFlow.astro";

const rolloutSteps = [
  { step: "01", title: "Política operativa", desc: "Definimos protocolo por recinto, excepciones permitidas y responsables por turno." },
  { step: "02", title: "Despliegue por capas", desc: "Implementamos funda + dock + plataforma con onboarding para equipos directivos y operativos." },
  { step: "03", title: "Medición continua", desc: "Seguimos indicadores de uso, incidencias y cumplimiento para ajustar sin fricción." },
];
---

<BaseLayout>
  <Header slot="header" />

  <!-- Hero -->
  <PageHero
    label="Fundas Bloqueadoras de Señal"
    title="Arquitectura integral"
    accent="para operación sin fricción"
    subtitle="Tres piezas conectadas que convierten una política institucional en cumplimiento diario, medible y escalable."
  />

  <!-- ═══════════ SISTEMA: las tres capas (cream) ═══════════ -->
  <section class="section--lg section--light-alt" id="arquitectura">
    <div class="container">
      <div class="arch-head">
        <ScrollReveal client:visible>
          <span class="label">Sistema BloKKit</span>
          <h2 class="heading-2">
            Tres capas conectadas
            <span class="heading-accent" style="display: block;">para cumplimiento real</span>
          </h2>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.15} className="arch-head__side">
          <p class="body-lg arch-head__lead">
            Desde el bloqueo físico hasta la trazabilidad digital: una operación continua, auditada y simple de ejecutar.
          </p>
          <span class="arch-head__hint">Explora cada capa ↓</span>
        </ScrollReveal>
      </div>
      <ArchitectureFlow tone="light" links={["#funda", "#dock", "#plataforma"]} />
    </div>
  </section>

  <!-- ═══════════ CAPA 01 · FUNDA (dark) ═══════════ -->
  <section class="section--lg section--dark" id="funda">
    <div class="container product-module">
      <ScrollReveal client:visible className="product-module__content">
        <span class="section-number" aria-hidden="true">01</span>
        <span class="label product-module__label">Capa 01 · Bloqueo físico</span>
        <h2 class="heading-2">Funda <span class="heading-accent">BloKKit</span></h2>
        <p class="body-lg product-module__lead">
          Malla de polímeros conductivos tipo Faraday que bloquea todas las señales del teléfono sin necesidad de confiscarlo. El dispositivo permanece con su dueño, pero completamente fuera de red durante el bloque operativo.
        </p>
      </ScrollReveal>
      <ScrollReveal client:visible delay={0.2} className="product-module__visual">
        <img src="/images/blokkit-fundas.webp" alt="Fundas BloKKit en tres colores: negro, gris y azul" loading="lazy" width="460" height="400" />
      </ScrollReveal>
    </div>

    <!-- Feature highlight cards -->
    <div class="container" style="margin-top: var(--space-12);">
      <div class="funda-features">
        <ScrollReveal client:visible delay={0.05}>
          <div class="glass-card funda-feature-card">
            <div class="funda-feature-card__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="funda-feature-card__title">Malla Faraday</h3>
            <p class="funda-feature-card__desc">Bloquea señales 3G, 4G, 5G, WiFi 2.4/5GHz, Bluetooth y NFC con <strong>99.9% de efectividad</strong> comprobada.</p>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.15}>
          <div class="glass-card funda-feature-card funda-feature-card--accent">
            <div class="funda-feature-card__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3 class="funda-feature-card__title">Cierre Magnético Reforzado</h3>
            <p class="funda-feature-card__desc"><strong>+50.000 cierres garantizados.</strong> Imposible de abrir manualmente — solo se desbloquea con el Dock autorizado.</p>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.25}>
          <div class="glass-card funda-feature-card">
            <div class="funda-feature-card__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m6.8 15-3.5 2"/><path d="m20.7 17-3.5-2"/><path d="M6.8 9 3.3 7"/><path d="m20.7 7-3.5 2"/><circle cx="12" cy="12" r="4"/></svg>
            </div>
            <h3 class="funda-feature-card__title">Diseño Resistente</h3>
            <p class="funda-feature-card__desc">Lavable, resistente al uso intensivo diario. Compatible con cualquier smartphone iOS y Android de hasta 6.9".</p>
          </div>
        </ScrollReveal>
      </div>
    </div>

    <!-- Technical specs strip (replaces the old AI-image gallery) -->
    <div class="container" style="margin-top: var(--space-12);">
      <ScrollReveal client:visible delay={0.1}>
        <ul class="funda-specs" aria-label="Especificaciones técnicas">
          <li><strong>Bloqueo</strong> 3G · 4G · 5G · WiFi · BT · NFC</li>
          <li><strong>Efectividad</strong> 99.9%</li>
          <li><strong>Compatibilidad</strong> hasta 6.9"</li>
        </ul>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════ CAPA 02 · DOCK (cream) ═══════════ -->
  <section class="section--lg section--light-alt" id="dock">
    <div class="container product-module product-module--reverse">
      <ScrollReveal client:visible className="product-module__visual">
        <img src="/images/dock-standard.webp" alt="Dock de Desbloqueo BloKKit con imán de liberación central" loading="lazy" width="600" height="400" />
      </ScrollReveal>
      <ScrollReveal client:visible delay={0.2} className="product-module__content">
        <span class="section-number" aria-hidden="true">02</span>
        <span class="label product-module__label">Capa 02 · Control de apertura</span>
        <h2 class="heading-2">Dock de <span class="heading-accent">Desbloqueo</span></h2>
        <p class="body-lg product-module__lead">
          Estación magnética para apertura en segundos. Permite controlar excepciones en tiempo real y mantener continuidad operacional sin romper protocolo.
        </p>
        <ul class="product-features">
          <li>Apertura menor a 3 segundos por dispositivo</li>
          <li>Control de acceso por roles autorizados</li>
          <li>Operación simple sin fricción para terreno</li>
        </ul>
      </ScrollReveal>
    </div>

    <!-- Two dock versions -->
    <div class="container" style="margin-top: var(--space-12);">
      <div class="dock-versions">
        <ScrollReveal client:visible delay={0.05}>
          <div class="dock-version-card">
            <div class="dock-version-card__head">
              <span class="dock-version-card__badge">Dock Estándar</span>
            </div>
            <h3 class="dock-version-card__title">Operación manual simple</h3>
            <ul class="dock-version-card__list">
              <li>Apertura magnética en menos de 3 segundos</li>
              <li>Operado por personal autorizado</li>
              <li>Sin instalación, software ni configuración</li>
            </ul>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.15}>
          <div class="dock-version-card dock-version-card--featured">
            <div class="dock-version-card__head">
              <span class="dock-version-card__badge">Dock Smart</span>
              <span class="dock-version-card__tag">Con registro</span>
            </div>
            <h3 class="dock-version-card__title">Trazabilidad de cada apertura</h3>
            <ul class="dock-version-card__list">
              <li>Registra quién abre, cuándo y dónde</li>
              <li>Conectado a la Plataforma de Gestión</li>
              <li>Historial completo para auditoría</li>
            </ul>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- ═══════════ CAPA 03 · PLATAFORMA (dark) ═══════════ -->
  <section class="section--lg section--dark" id="plataforma">
    <div class="container product-module">
      <ScrollReveal client:visible className="product-module__content">
        <span class="section-number" aria-hidden="true">03</span>
        <span class="label product-module__label">Capa 03 · Trazabilidad</span>
        <h2 class="heading-2">Plataforma <span class="heading-accent">Digital</span></h2>
        <p class="body-lg product-module__lead">
          El centro de gestión para monitorear adopción, incidencias y cumplimiento por sede, curso, equipo o turno. Todo en una sola vista operativa.
        </p>
        <p class="platform-callout">
          <strong>El diferenciador:</strong> cada funda se asigna por QR a una persona. Registro de uso individual — quién la lleva, cuándo se sella y cuándo se libera.
        </p>
        <ul class="product-features product-features--dark">
          <li>Asignación por QR: cada funda vinculada a una persona</li>
          <li>Registro de uso: sellados, aperturas y responsables</li>
          <li>KPIs de cumplimiento en tiempo real por sede o curso</li>
          <li>Reportes exportables para auditoría interna</li>
        </ul>
      </ScrollReveal>
      <ScrollReveal client:visible delay={0.2} className="product-module__visual">
        <div class="platform-mockup" aria-hidden="true">
          <div class="platform-topbar">
            <span class="platform-dot"></span>
            <span class="platform-dot"></span>
            <span class="platform-dot"></span>
            <span class="platform-url">plataforma.blokkit.cl</span>
          </div>
          <div class="platform-body">
            <div class="platform-kpis">
              <div class="platform-kpi"><strong>94%</strong><span>Cumplimiento</span></div>
              <div class="platform-kpi"><strong>1.248</strong><span>Fundas asignadas</span></div>
              <div class="platform-kpi"><strong>12</strong><span>Aperturas excepción</span></div>
            </div>
            <div class="platform-table">
              <div class="platform-table__head">
                <span>Registro de uso · hoy</span>
                <span class="platform-live">● En vivo</span>
              </div>
              <div class="platform-row platform-row--head">
                <span>Funda</span><span>Asignada a</span><span>Ingreso</span><span>Estado</span>
              </div>
              <div class="platform-row">
                <span class="platform-id"><svg viewBox="0 0 12 12" width="10" height="10" fill="currentColor"><path d="M0 0h5v5H0zM7 0h5v5H7zM0 7h5v5H0zM7 7h2v2H7zM10 7h2v2h-2zM7 10h2v2H7zM10 10h2v2h-2z"/></svg>F-0241</span>
                <span>M. Contreras</span><span>08:02</span><span class="platform-chip">Sellada</span>
              </div>
              <div class="platform-row">
                <span class="platform-id"><svg viewBox="0 0 12 12" width="10" height="10" fill="currentColor"><path d="M0 0h5v5H0zM7 0h5v5H7zM0 7h5v5H0zM7 7h2v2H7zM10 7h2v2h-2zM7 10h2v2H7zM10 10h2v2h-2z"/></svg>F-0187</span>
                <span>J. Pérez</span><span>08:05</span><span class="platform-chip">Sellada</span>
              </div>
              <div class="platform-row">
                <span class="platform-id"><svg viewBox="0 0 12 12" width="10" height="10" fill="currentColor"><path d="M0 0h5v5H0zM7 0h5v5H7zM0 7h5v5H0zM7 7h2v2H7zM10 7h2v2h-2zM7 10h2v2H7zM10 10h2v2h-2z"/></svg>F-0093</span>
                <span>A. Rojas</span><span>08:11</span><span class="platform-chip platform-chip--open">Liberada</span>
              </div>
              <div class="platform-row">
                <span class="platform-id"><svg viewBox="0 0 12 12" width="10" height="10" fill="currentColor"><path d="M0 0h5v5H0zM7 0h5v5H7zM0 7h5v5H0zM7 7h2v2H7zM10 7h2v2h-2zM7 10h2v2H7zM10 10h2v2h-2z"/></svg>F-0312</span>
                <span>C. Muñoz</span><span>08:14</span><span class="platform-chip">Sellada</span>
              </div>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════ ROLLOUT (cream) ═══════════ -->
  <section class="section--lg section--light-alt" id="implementacion">
    <div class="container">
      <div class="section-head">
        <ScrollReveal client:visible>
          <span class="label">Implementación</span>
          <h2 class="heading-2">Despliegue en <span class="heading-accent">3 pasos</span></h2>
        </ScrollReveal>
      </div>
      <div class="rollout-grid">
        {rolloutSteps.map((step, i) => (
          <ScrollReveal client:visible delay={i * 0.15}>
            <div class="rollout-card">
              <span class="rollout-num" aria-hidden="true">{step.step}</span>
              <h3 class="heading-5">{step.title}</h3>
              <p class="body-sm">{step.desc}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <FinalCta
    title="¿Listo para activar"
    accent="el sistema completo?"
    subtitle="Te mostramos cómo implementar BloKKit en tu operación con un plan de despliegue realista y medible."
    secondaryText="Ver beneficios por sector"
    secondaryHref="/beneficios"
  />

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Arch overview head: editorial left-aligned, lead at the right ── */
  .arch-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-4);
    align-items: end;
    margin-bottom: var(--space-10);
  }

  @media (min-width: 900px) {
    .arch-head {
      grid-template-columns: minmax(0, 1fr) minmax(0, 400px);
      gap: var(--space-12);
    }
  }

  .arch-head .heading-2 {
    margin: var(--space-3) 0 0;
  }

  .arch-head__lead {
    margin: 0;
    color: var(--text-dark-secondary);
  }

  .arch-head__hint {
    display: inline-block;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-strong);
  }

  /* ── Product module: alternating text + visual ── */
  .product-module {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-10);
    align-items: center;
  }

  @media (min-width: 768px) {
    .product-module {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-16);
    }

    .product-module--reverse :global(.product-module__visual) {
      order: -1;
    }
  }

  :global(.product-module__content) .section-number {
    font-size: clamp(3rem, 6vw, 5.5rem);
    margin-bottom: var(--space-3);
  }

  .product-module__label {
    display: block;
    margin-bottom: var(--space-3);
  }

  .product-module__lead {
    max-width: 52ch;
    margin-top: var(--space-3);
  }

  .section--dark .product-module__lead {
    color: var(--text-secondary);
  }

  :global(.product-module__visual) img {
    width: 100%;
    max-width: 480px;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.2));
    margin: 0 auto;
    display: block;
  }

  /* ── Feature pill rows ── */
  .product-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding: 0;
  }

  .product-features li {
    position: relative;
    padding: var(--space-2) var(--space-4) var(--space-2) var(--space-6);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    color: var(--text-dark-secondary);
    background: rgba(255, 255, 255, 0.55);
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }

  .product-features li::before {
    content: "";
    position: absolute;
    left: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-strong);
  }

  .product-features li:hover {
    transform: translateX(4px);
    border-color: var(--accent-strong);
    background: var(--bg-white);
  }

  .product-features--dark li {
    border-color: var(--border-subtle);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
  }

  .product-features--dark li::before {
    background: var(--accent);
  }

  .product-features--dark li:hover {
    border-color: var(--border-accent);
    background: rgba(255, 255, 255, 0.07);
  }

  /* ── Funda feature cards (glass on dark) ── */
  .funda-features {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .funda-features {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-6);
    }
  }

  .funda-feature-card {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .funda-feature-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-accent);
  }

  .funda-feature-card--accent {
    background: rgba(127, 206, 236, 0.04);
    border-color: rgba(127, 206, 236, 0.3);
  }

  .funda-feature-card__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(127, 206, 236, 0.15) 0%, rgba(127, 206, 236, 0.05) 100%);
    border: 1px solid rgba(127, 206, 236, 0.25);
    color: var(--accent);
    flex-shrink: 0;
  }

  .funda-feature-card__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    margin: 0;
  }

  .funda-feature-card__desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .funda-feature-card__desc strong {
    color: var(--accent);
  }

  /* ── Technical specs strip (mono data bar, deck style) ── */
  .funda-specs {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-8);
    justify-content: center;
    padding: var(--space-5) 0 0;
    margin: 0;
    border-top: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .funda-specs strong {
    color: var(--accent);
    font-weight: 500;
    margin-right: var(--space-2);
  }

  /* ── Dock versions: Estándar vs Smart ── */
  .dock-versions {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-4);
    max-width: 880px;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .dock-versions {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-6);
    }
  }

  .dock-version-card {
    height: 100%;
    padding: var(--space-6);
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .dock-version-card:hover {
    transform: translateY(-4px);
    border-color: rgba(63, 168, 224, 0.4);
    box-shadow: var(--shadow-card-hover);
  }

  .dock-version-card--featured {
    background: linear-gradient(180deg, rgba(127, 206, 236, 0.10) 0%, rgba(255, 255, 255, 1) 55%);
    border: 1px solid rgba(63, 168, 224, 0.4);
  }

  .dock-version-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .dock-version-card__badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-dark);
    padding: 5px 12px;
    border: 1px solid rgba(63, 168, 224, 0.35);
    border-radius: var(--radius-full);
  }

  .dock-version-card__tag {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    background: var(--accent-strong);
    padding: 4px 10px;
    border-radius: var(--radius-full);
  }

  .dock-version-card__title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--text-dark);
    margin: 0 0 var(--space-3);
    line-height: 1.2;
  }

  .dock-version-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .dock-version-card__list li {
    position: relative;
    padding-left: var(--space-4);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--text-dark-secondary);
  }

  .dock-version-card__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-strong);
  }

  /* ── Platform: differentiator callout ── */
  .platform-callout {
    margin: var(--space-4) 0 0;
    padding-left: var(--space-4);
