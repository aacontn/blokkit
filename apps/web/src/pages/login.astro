---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Iniciar Sesión | BloKKit";
const pageDescription = "Accede al portal BloKKit para gestionar operaciones, soporte y cumplimiento institucional.";
const portalUrl = import.meta.env.PUBLIC_PORTAL_URL ?? "http://localhost:5173";

const highlights = [
  {
    title: "Visibilidad operativa",
    detail: "Monitorea adopción por sede y detecta brechas en minutos."
  },
  {
    title: "Respuesta coordinada",
    detail: "Conecta soporte, coordinación académica y dirección en un solo flujo."
  },
  {
    title: "Trazabilidad completa",
    detail: "Registra decisiones, incidentes y evidencia para auditorias."
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="login-page">
    <div class="login-grid" data-reveal>
      <section class="login-brand">
        <div class="brand-top">
          <a href="/" class="brand-home" aria-label="Volver al inicio de BloKKit">
            <img src="/images/Logo-Blokkit-white.png" alt="BloKKit" class="brand-logo" />
          </a>
          <span class="brand-pill">Mi Portal BloKKit</span>
        </div>

        <h1>Control y continuidad, sin fricción.</h1>
        <p class="brand-copy">
          Inicia sesión para revisar cumplimiento, incidentes y reportes de toda tu institución desde un panel unificado.
        </p>

        <ul class="brand-highlights">
          {highlights.map((item) => (
            <li>
              <strong>{item.title}</strong>
              <span>{item.detail}</span>
            </li>
          ))}
        </ul>

        <a href="/producto" class="brand-link">Ver detalles del sistema</a>
      </section>

      <section class="login-panel" data-reveal style="--delay: 120ms;">
        <header class="panel-header">
          <span class="panel-pill">Acceso Seguro</span>
          <h2>Bienvenido de vuelta</h2>
          <p>Usa tu correo institucional para entrar al entorno de gestión.</p>
        </header>

        <form id="login-form" class="login-form" data-portal-url={portalUrl} novalidate>
          <div class="field">
            <label for="email">Correo institucional</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="tu@institución.cl"
              inputmode="email"
              required
            />
          </div>

          <div class="field">
            <label for="password">Contrasena</label>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="current-password"
              placeholder="Ingresa tu contrasena"
              minlength="8"
              required
            />
          </div>

          <div class="form-meta">
            <label class="remember-option">
              <input type="checkbox" id="remember" name="remember" />
              <span>Recordar correo en este equipo</span>
            </label>
            <a class="recover-link" href="/contacto">No puedes ingresar?</a>
          </div>

          <p id="login-feedback" class="login-feedback" role="status" aria-live="polite"></p>

          <button type="submit" class="login-submit">
            <span class="label-default">Entrar al portal</span>
            <span class="label-loading" aria-hidden="true">Ingresando...</span>
          </button>
        </form>

        <footer class="panel-footer">
          <a href="/contacto" class="outline-btn">Solicitar acceso</a>
          <a href="/" class="back-link">Volver al inicio</a>
        </footer>
      </section>
    </div>
  </main>
  <script slot="scripts">
    const rememberedEmailKey = "blokkit.rememberedEmail";
    const lastEmailKey = "blokkit.lastEmail";

    const setupLoginForm = () => {
      const form = document.getElementById("login-form");
      const feedback = document.getElementById("login-feedback");
      const emailInput = document.getElementById("email");
      const passwordInput = document.getElementById("password");
      const rememberInput = document.getElementById("remember");
      const submitButton = form?.querySelector(".login-submit");

      if (!form || !feedback || !emailInput || !passwordInput || !rememberInput || !submitButton) {
        return;
      }

      if (form.dataset.bound === "true") {
        return;
      }
      form.dataset.bound = "true";

      const savedEmail = window.localStorage.getItem(rememberedEmailKey) ?? window.sessionStorage.getItem(lastEmailKey);
      if (savedEmail) {
        emailInput.value = savedEmail;
        if (window.localStorage.getItem(rememberedEmailKey)) {
          rememberInput.checked = true;
        }
      }

      const setState = (message, type, loading) => {
        feedback.textContent = message;
        feedback.dataset.type = type;
        submitButton.classList.toggle("is-loading", loading);
        submitButton.disabled = loading;
      };

      form.addEventListener("submit", (event) => {
        event.preventDefault();

        const email = emailInput.value.trim();
        const password = passwordInput.value;
        const remember = rememberInput.checked;

        if (!email || !password) {
          setState("Completa correo y contrasena para continuar.", "error", false);
          return;
        }

        const emailValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        if (!emailValid) {
          setState("Ingresa un correo institucional valido.", "error", false);
          return;
        }

        if (password.length < 8) {
          setState("La contrasena debe tener al menos 8 caracteres.", "error", false);
          return;
        }

        if (remember) {
          window.localStorage.setItem(rememberedEmailKey, email);
        } else {
          window.localStorage.removeItem(rememberedEmailKey);
          window.sessionStorage.setItem(lastEmailKey, email);
        }

        setState("Validando acceso...", "info", true);

        const portalBase = form.dataset.portalUrl || "http://localhost:5173";
        const redirectUrl = `${portalBase.replace(/\/$/, "")}/?email=${encodeURIComponent(email)}`;

        window.setTimeout(() => {
          window.location.assign(redirectUrl);
        }, 450);
      });
    };

    document.addEventListener("DOMContentLoaded", setupLoginForm);
    document.addEventListener("astro:page-load", setupLoginForm);
  </script>
</BaseLayout>

<style>
  body {
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    color: #d5e6e8;
    background: #070909;
  }

  a {
    text-decoration: none;
  }

  .login-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 3vw, 2rem);
    background:
      radial-gradient(860px 360px at 10% -12%, rgba(62, 224, 240, 0.16), transparent 62%),
      radial-gradient(780px 360px at 100% 12%, rgba(0, 194, 209, 0.12), transparent 60%),
      linear-gradient(160deg, #080a0a 0%, #080909 56%, #060707 100%);
  }

  .login-grid {
    width: min(1080px, 100%);
    border: 1px solid rgba(120, 159, 167, 0.3);
    border-radius: 1.5rem;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    background:
      linear-gradient(180deg, rgba(12, 17, 18, 0.9), rgba(8, 12, 12, 0.96)),
      rgba(8, 12, 12, 0.9);
    box-shadow:
      0 24px 70px rgba(0, 0, 0, 0.5),
      0 1px 0 rgba(255, 255, 255, 0.08) inset;
  }

  .login-brand {
    padding: clamp(1.35rem, 3vw, 2.35rem);
    background:
      radial-gradient(760px 300px at 16% -10%, rgba(62, 224, 240, 0.15), transparent 62%),
      linear-gradient(180deg, rgba(12, 18, 18, 0.92), rgba(8, 12, 12, 0.95));
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }

  .brand-top {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
  }

  .brand-home {
    display: inline-flex;
  }

  .brand-logo {
    height: 2.15rem;
    width: auto;
  }

  .brand-pill,
  .panel-pill {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
    padding: 0.28rem 0.72rem;
    border-radius: 999px;
    border: 1px solid rgba(62, 224, 240, 0.34);
    background: rgba(3, 9, 11, 0.66);
    color: #9bedf7;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .brand-pill {
    margin: 0;
    transform: translateY(1px);
  }

  .login-brand h1 {
    margin: 0;
    font-size: clamp(2.2rem, 5vw, 4.15rem);
    line-height: 0.93;
    max-width: 12ch;
    text-wrap: balance;
  }

  .brand-copy {
    margin: 1rem 0 0;
    color: rgba(221, 235, 237, 0.78);
    font-size: 0.98rem;
    max-width: 48ch;
  }

  .brand-highlights {
    margin: 1.4rem 0 1.5rem;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.84rem;
  }

  .brand-highlights li {
    padding: 0.82rem 0.85rem;
    border-radius: 0.9rem;
    border: 1px solid rgba(62, 224, 240, 0.2);
    background: rgba(4, 12, 13, 0.68);
    display: grid;
    gap: 0.24rem;
  }

  .brand-highlights strong {
    color: #d7fbff;
    font-size: 0.92rem;
    line-height: 1.25;
  }

  .brand-highlights span {
    color: rgba(211, 225, 227, 0.72);
    font-size: 0.84rem;
    line-height: 1.42;
  }

  .brand-link {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    min-height: 2.55rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(62, 224, 240, 0.36);
    color: #c5f9ff;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .brand-link:hover {
    border-color: rgba(62, 224, 240, 0.62);
    transform: translateY(-1px);
  }

  .login-panel {
    padding: clamp(1.3rem, 3vw, 2.15rem);
    background:
      radial-gradient(720px 280px at 84% -8%, rgba(62, 224, 240, 0.12), transparent 64%),
      linear-gradient(180deg, rgba(14, 20, 20, 0.9), rgba(8, 12, 13, 0.96));
  }

  .panel-header {
    margin-bottom: 1.15rem;
  }

  .panel-pill {
    margin-bottom: 0.8rem;
  }

  .panel-header h2 {
    margin: 0;
    font-size: clamp(2rem, 4.1vw, 3rem);
    line-height: 0.95;
  }

  .panel-header p {
    margin: 0.55rem 0 0;
    color: rgba(220, 233, 235, 0.75);
    font-size: 0.95rem;
  }

  .login-form {
    display: grid;
    gap: 0.95rem;
  }

  .field {
    display: grid;
    gap: 0.4rem;
  }

  .field label {
    color: rgba(212, 226, 228, 0.8);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .field input {
    min-height: 2.8rem;
    border-radius: 0.85rem;
    border: 1px solid rgba(62, 224, 240, 0.25);
    padding: 0.7rem 0.9rem;
    background: rgba(3, 10, 11, 0.7);
    color: #f5feff;
    font-size: 0.92rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .field input::placeholder {
    color: rgba(203, 223, 224, 0.4);
  }

  .field input:focus {
    outline: none;
    border-color: rgba(62, 224, 240, 0.6);
    box-shadow: 0 0 0 3px rgba(62, 224, 240, 0.14);
  }

  .form-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
    margin-top: -0.1rem;
  }

  .remember-option {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgba(208, 222, 224, 0.72);
    font-size: 0.81rem;
    cursor: pointer;
  }

  .remember-option input {
    accent-color: #23c7d0;
  }

  .recover-link {
    color: #9af6ff;
    font-size: 0.81rem;
    font-weight: 600;
  }

  .recover-link:hover {
    color: #d5fdff;
  }

  .login-feedback {
    min-height: 1.2rem;
    margin: 0;
    font-size: 0.8rem;
    color: rgba(198, 220, 222, 0.75);
  }

  .login-feedback[data-type="error"] {
    color: #f7b6b6;
  }

  .login-feedback[data-type="info"] {
    color: #9cf7ff;
  }

  .login-submit,
  .outline-btn {
    min-height: 3rem;
    width: 100%;
    border-radius: 999px;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.92rem;
    font-weight: 700;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .login-submit {
    border: 0;
    color: #042226;
    background: linear-gradient(135deg, #5be8f4 0%, #34d1df 50%, #22bdce 100%);
    box-shadow: 0 0 0 1px rgba(118, 236, 244, 0.38) inset, 0 12px 28px rgba(34, 189, 206, 0.35);
    cursor: pointer;
  }

  .login-submit:hover {
    transform: translateY(-1px);
  }

  .login-submit:disabled {
    cursor: progress;
    opacity: 0.94;
  }

  .label-loading {
    display: none;
  }

  .login-submit.is-loading .label-default {
    display: none;
  }

  .login-submit.is-loading .label-loading {
    display: inline;
  }

  .panel-footer {
    margin-top: 1rem;
    display: grid;
    gap: 0.8rem;
  }

  .outline-btn {
    border: 1px solid rgba(62, 224, 240, 0.32);
    color: rgba(232, 247, 249, 0.9);
    background: rgba(5, 12, 13, 0.65);
  }

  .outline-btn:hover {
    border-color: rgba(62, 224, 240, 0.55);
    transform: translateY(-1px);
  }

  .back-link {
    text-align: center;
    font-size: 0.82rem;
    color: rgba(193, 212, 214, 0.72);
  }

  .back-link:hover {
    color: rgba(234, 246, 248, 0.92);
  }

  @media (max-width: 980px) {
    .login-grid {
      grid-template-columns: 1fr;
    }

    .login-brand {
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
  }

  @media (max-width: 640px) {
    .login-page {
      padding: 0.75rem;
    }

    .form-meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
