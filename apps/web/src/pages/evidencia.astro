---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import FinalCta from "../components/FinalCta.astro";
import PageHero from "../components/PageHero.astro";

/* Evidencia verificada — cada cifra lleva su fuente (jun 2026).
   Framing fiel a los papers: LSE = % de una desviación estándar;
   237 notificaciones = mediana del estudio Common Sense. */

const chileStats = [
  { value: "87%", claim: "de los estudiantes entre 9 y 17 años ya tiene celular propio.", source: "Criteria & Claro · 2023" },
  { value: "8,9", claim: "años es la edad promedio del primer dispositivo con internet en Chile.", source: "Criteria & Claro · 2023" },
  { value: "237", claim: "notificaciones al día recibe la mitad de los adolescentes monitoreados — ~23% en horario escolar.", source: "Common Sense Media · 2023 (EE.UU.)", href: "https://www.commonsensemedia.org/research/constant-companion-a-week-in-the-life-of-a-young-persons-smartphone-use" },
  { value: "1 de 4", claim: "menores ha estado involucrado en episodios de ciberacoso; el 52% declara haberlo presenciado.", source: "Superintendencia de Educación · 2023" },
];

const resultados = [
  { value: "+5 días", claim: "de año escolar equivale el efecto de una prohibición bien aplicada sobre los puntajes (+6,41% de una desviación estándar).", source: "Beland & Murphy · LSE 2016", href: "https://doi.org/10.1016/j.labeco.2016.04.004" },
  { value: "×2", claim: "se duplica el beneficio en los alumnos de menor rendimiento (+14,23% de una DE): la medida reduce brechas.", source: "Beland & Murphy · LSE 2016", href: "https://doi.org/10.1016/j.labeco.2016.04.004" },
  { value: "−46%", claim: "de bullying en niñas tras tres años de prohibición efectiva, con baja significativa en consultas por síntomas psicológicos.", source: "Abrahamsson · NHH 2024", href: "https://openaccess.nhh.no/nhh-xmlui/handle/11250/3119200" },
  { value: "75%", claim: "de los colegios secundarios reporta alumnos más concentrados tras un año de prohibición nacional; 59% mejor clima y 28% mejores resultados.", source: "Kohnstamm Instituut · Países Bajos 2025" },
];

const timeline = [
  { year: "2018", items: ["Francia — primera ley nacional: prohibición de maternelle a collège."] },
  { year: "2023", items: ["UNESCO recomienda excluir el smartphone del aula cuando no apoye el aprendizaje: solo 1 de cada 4 países lo prohibía."] },
  { year: "2024", items: ["Países Bajos — directriz nacional en secundaria, extendida a primaria.", "Noruega — recomendación nacional de escuelas sin celular, incluidos recreos."] },
  { year: "2025", items: ["Brasil — Lei 15.100: toda la educación básica, clases y recreos.", "Italia y Finlandia — extienden la restricción por ley a todos los niveles.", "Inglaterra — el 99,8% de las primarias ya restringe el celular en la jornada."] },
  { year: "2026", items: ["Chile — Ley 21.801 vigente desde marzo: parvularia, básica y media.", "UNESCO actualiza el conteo: 114 sistemas educativos con prohibición nacional — el 58% de los países."] },
];

const kpis = [
  {
    category: "Aprendizaje",
    highlight: "Impacto Académico",
    items: ["Mejora en notas por asignatura y curso", "Resultados de evaluaciones parciales", "Aumento en la participación general", "Continuidad académica sin interrupciones"],
  },
  {
    category: "Convivencia",
    highlight: "Impacto Social",
    items: ["Baja en incidentes por uso indebido", "Disminución de casos de ciberacoso", "Reducción de medidas disciplinarias", "Mejores interacciones cara a cara"],
  },
  {
    category: "Operación",
    highlight: "Impacto en Gestión",
    items: ["Uso efectivo y cumplimiento diario", "Registro de aperturas y excepciones", "Tiempos de respuesta del protocolo", "Reducción de decomisos en sala"],
  },
];

const fuentes = [
  { name: "UNESCO — Global Education Monitoring Report (2023 / actualización marzo 2026)", href: "https://www.unesco.org/gem-report/en/articles/phone-bans-schools-are-spreading-worldwide-policy-debate-rages" },
  { name: "Beland & Murphy — \"Ill Communication\", Labour Economics 41 (LSE, 2016)", href: "https://doi.org/10.1016/j.labeco.2016.04.004" },
  { name: "Abrahamsson — \"Smartphone Bans, Student Outcomes and Mental Health\" (NHH, 2024)", href: "https://openaccess.nhh.no/nhh-xmlui/handle/11250/3119200" },
  { name: "Ward, Duke, Gneezy & Bos — \"Brain Drain\" (UT Austin, JACR 2017)", href: "https://www.journals.uchicago.edu/doi/full/10.1086/691462" },
  { name: "Gloria Mark — costo de la interrupción, UC Irvine (2006; Attention Span, 2023)", href: "https://news.gallup.com/businessjournal/23146/too-many-interruptions-work.aspx" },
  { name: "Common Sense Media — \"Constant Companion\" (2023)", href: "https://www.commonsensemedia.org/research/constant-companion-a-week-in-the-life-of-a-young-persons-smartphone-use" },
  { name: "Kohnstamm Instituut — evaluación oficial neerlandesa (2025)", href: "https://www.japantimes.co.jp/news/2025/07/05/world/dutch-survey-phone-ban-focus/" },
  { name: "Children's Commissioner for England — encuesta nacional (2025)", href: "https://www.childrenscommissioner.gov.uk/news-and-blogs/press-notice-most-headteachers-restrict-mobile-phones-in-school-hours-but-major-new-survey-shows-online-harms-still-among-their-biggest-concerns/" },
  { name: "Universidad de Birmingham — SMART Schools, The Lancet Regional Health (2025)" },
  { name: "Ley 21.801 — Biblioteca del Congreso Nacional de Chile", href: "https://www.bcn.cl/leychile/navegar?idNorma=1221284" },
  { name: "Criteria & Claro (2023); Superintendencia de Educación (2023); U. de los Andes & Entel (2024)" },
];
---

<BaseLayout>
  <Header slot="header" />

  <PageHero
    label="Fundamentos de la Solución"
    title="Evidencia internacional"
    accent="aplicada al contexto Chile"
    subtitle="Cada cifra de esta página tiene nombre, año y fuente. Lo que la investigación dice — y lo que exige para que funcione."
  />

  <!-- ═══════════ 01 · EL PROBLEMA ES GLOBAL (cream) ═══════════ -->
  <section class="evd section--light-alt section-ambient section-ambient--light" id="problema-global">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="evd-head">
          <span class="section-number" aria-hidden="true">01</span>
          <div>
            <span class="label">El problema es global</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              El mundo ya decidió
              <span class="heading-accent" style="display: block;">sacar el celular del aula</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <div class="evd-global">
        <ScrollReveal client:visible delay={0.1} className="evd-global-stat">
          <div class="evd-giant-block">
            <span class="evd-giant">58<em>%</em></span>
            <p class="evd-giant-label">de los países del mundo ya prohíbe por ley el celular en la escuela — 114 sistemas educativos.</p>
            <a class="evd-source" href="https://www.unesco.org/gem-report/en/articles/phone-bans-schools-are-spreading-worldwide-policy-debate-rages" target="_blank" rel="noopener">UNESCO · GEM Report, marzo 2026 ↗</a>
            <div class="evd-progress" aria-hidden="true">
              <span class="evd-progress-item"><strong>24%</strong> 2023</span>
              <span class="evd-progress-arrow">→</span>
              <span class="evd-progress-item"><strong>40%</strong> 2024</span>
              <span class="evd-progress-arrow">→</span>
              <span class="evd-progress-item evd-progress-item--now"><strong>58%</strong> 2026</span>
            </div>
          </div>
        </ScrollReveal>

        <div class="evd-global-side">
          <ScrollReveal client:visible delay={0.2}>
            <div class="evd-card">
              <h3 class="evd-h">La sola presencia distrae</h3>
              <p class="body-sm">Con ~800 participantes, el estudio "Brain Drain" demostró que tener el teléfono a la vista —apagado y boca abajo— reduce la capacidad cognitiva disponible: el cerebro gasta recursos en ignorarlo. El mejor desempeño se logró con el teléfono <strong>fuera del alcance</strong>.</p>
              <a class="evd-source" href="https://www.journals.uchicago.edu/doi/full/10.1086/691462" target="_blank" rel="noopener">Ward et al. · UT Austin 2017 ↗</a>
            </div>
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.3}>
            <div class="evd-card">
              <h3 class="evd-h">Cada interrupción cuesta 23 minutos</h3>
              <p class="body-sm">Retomar una tarea interrumpida toma en promedio 23 minutos y 15 segundos. En una jornada fragmentada por notificaciones, la concentración profunda simplemente no ocurre.</p>
              <a class="evd-source" href="https://news.gallup.com/businessjournal/23146/too-many-interruptions-work.aspx" target="_blank" rel="noopener">Gloria Mark · UC Irvine ↗</a>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ 02 · EL ESCENARIO EN CHILE (dark) ═══════════ -->
  <section class="evd section--dark section-ambient" id="chile">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="evd-head">
          <span class="section-number" aria-hidden="true">02</span>
          <div>
            <span class="label">El escenario en Chile</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              Datos que
              <span class="heading-accent">demandan acción</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <div class="evd-stats-grid">
        {chileStats.map((s, i) => (
          <ScrollReveal client:visible delay={i * 0.08}>
            <div class="evd-stat">
              <span class="evd-stat__value">{s.value}</span>
              <p class="evd-stat__claim body-sm">{s.claim}</p>
              {s.href
                ? <a class="evd-source" href={s.href} target="_blank" rel="noopener">{s.source} ↗</a>
                : <span class="evd-source">{s.source}</span>}
            </div>
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal client:visible delay={0.2}>
        <div class="evd-deadline">
          <span class="evd-deadline__tag">Ley 21.801 · Plazo RICE</span>
          <p>
            La ley ya rige desde marzo. Y el plazo operativo corre: <strong>los reglamentos internos deben estar actualizados antes del 30 de junio de 2026</strong>, según las instrucciones de la Superintendencia de Educación.
          </p>
          <a href="/ley-celulares-2026" class="btn btn--primary">Ver el marco legal completo</a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════ 03 · LA PARADOJA DE LA PROHIBICIÓN (cream) ═══════════ -->
  <section class="evd section--light-alt section-ambient section-ambient--light" id="paradoja">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="evd-head">
          <span class="section-number" aria-hidden="true">03</span>
          <div>
            <span class="label">Intención vs. implementación</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              La paradoja:
              <span class="heading-accent" style="display: block;">prohibir en papel no funciona</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <div class="evd-paradox">
        <ScrollReveal client:visible delay={0.1}>
          <div class="evd-card evd-card--paper">
            <span class="evd-card__kicker">Lo que falla</span>
            <h3 class="evd-h">Política sin mecanismo</h3>
            <p class="body-sm">El estudio SMART Schools no encontró diferencias de bienestar ni rendimiento entre colegios con políticas restrictivas y permisivas <strong>cuando la regla existe solo en el papel</strong>: no logra reducir el tiempo real de uso. Los propios autores: "solo prohibir no es suficiente".</p>
            <span class="evd-source">U. de Birmingham · The Lancet Regional Health 2025</span>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible delay={0.2}>
          <div class="evd-card evd-card--works">
            <span class="evd-card__kicker evd-card__kicker--accent">Lo que funciona</span>
            <h3 class="evd-h">Cumplimiento verificable</h3>
            <p class="body-sm">El detalle que casi nadie lee en el estudio de la LSE: la ganancia académica aparece en los colegios donde la prohibición <strong>se aplica de forma estricta</strong>. Donde el ban es laxo, el efecto desaparece. La evidencia positiva — Noruega, Países Bajos, LSE — viene de prohibiciones efectivamente implementadas.</p>
            <a class="evd-source" href="https://doi.org/10.1016/j.labeco.2016.04.004" target="_blank" rel="noopener">Beland & Murphy · LSE 2016 ↗</a>
          </div>
        </ScrollReveal>
      </div>

      <ScrollReveal client:visible delay={0.3}>
        <p class="evd-conclusion">
          <strong>Conclusión:</strong> la evidencia no respalda prohibir — respalda <strong>implementar</strong>. Ese es exactamente el espacio de BloKKit: convertir la regla escrita en una rutina física, visible y verificable.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════ 04 · RESULTADOS DEL CUMPLIMIENTO EFECTIVO (dark) ═══════════ -->
  <section class="evd section--dark section-ambient" id="resultados">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="evd-head">
          <span class="section-number" aria-hidden="true">04</span>
          <div>
            <span class="label">Cumplimiento efectivo</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              Lo que pasa cuando
              <span class="heading-accent">la regla se cumple de verdad</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <div class="evd-stats-grid">
        {resultados.map((s, i) => (
          <ScrollReveal client:visible delay={i * 0.08}>
            <div class="evd-stat evd-stat--result">
              <span class="evd-stat__value">{s.value}</span>
              <p class="evd-stat__claim body-sm">{s.claim}</p>
              {s.href
                ? <a class="evd-source" href={s.href} target="_blank" rel="noopener">{s.source} ↗</a>
                : <span class="evd-source">{s.source}</span>}
            </div>
          </ScrollReveal>
        ))}
      </div>

      <ScrollReveal client:visible delay={0.25}>
        <p class="evd-meta-note">
          El meta-análisis más amplio a la fecha — <strong>63 estudios, 124.166 estudiantes, 28 países</strong> — confirma la asociación negativa significativa entre uso de smartphones en clase y rendimiento académico.
          <span class="evd-source">Meta-análisis global · 2024</span>
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════ 05 · LA OLA INTERNACIONAL (cream) ═══════════ -->
  <section class="evd section--light-alt section-ambient section-ambient--light" id="ola">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="evd-head">
          <span class="section-number" aria-hidden="true">05</span>
          <div>
            <span class="label">Contexto internacional</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              La ola legislativa,
              <span class="heading-accent">año a año</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <ol class="evd-timeline">
        {timeline.map((t, i) => (
          <ScrollReveal client:visible delay={i * 0.08}>
            <li class="evd-tl-row">
              <span class="evd-tl-year">{t.year}</span>
              <ul class="evd-tl-items">
                {t.items.map((item) => <li class="body-sm">{item}</li>)}
              </ul>
            </li>
          </ScrollReveal>
        ))}
      </ol>

      <ScrollReveal client:visible delay={0.3}>
        <p class="evd-culture-note">
          Y fuera del aula, la misma lógica: Dave Chappelle, Bob Dylan y Jack White llevan años haciendo shows libres de celulares con fundas bloqueadas.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- ═══════════ 06 · QUÉ MEDIRÁS CON BLOKKIT (dark) ═══════════ -->
  <section class="evd section--dark section-ambient" id="kpis">
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="evd-head">
          <span class="section-number" aria-hidden="true">06</span>
          <div>
            <span class="label">De la evidencia a tu operación</span>
            <h2 class="heading-2" style="margin-top: var(--space-2)">
              Lo que vas a medir
              <span class="heading-accent">con BloKKit</span>
            </h2>
          </div>
        </div>
      </ScrollReveal>

      <div class="evd-kpis">
        {kpis.map((kpi, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <div class="evd-kpi-card">
              <span class="evd-kpi-pill">{kpi.highlight}</span>
              <h3 class="heading-5" style="margin: var(--space-3) 0 var(--space-4);">{kpi.category}</h3>
              <ul class="evd-kpi-list">
                {kpi.items.map((item) => (
                  <li>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ FUENTES ═══════════ -->
  <section class="evd-fuentes section--light-alt">
    <div class="container">
      <span class="label">Fuentes</span>
      <ol class="evd-fuentes-list">
        {fuentes.map((f) => (
          <li>
            {f.href
              ? <a href={f.href} target="_blank" rel="noopener">{f.name} ↗</a>
              : f.name}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <FinalCta
    title="La evidencia respalda implementar."
    accent="Implementemos."
    subtitle="Agenda una reunión y revisamos cómo se ve un cumplimiento verificable en tu institución, con los KPIs para demostrarlo."
  />

  <Footer slot="footer" />
</BaseLayout>

<style>
  .evd {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-20);
  }

  /* ── Section head: numeral + kicker + title ── */
  .evd-head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .evd-head .section-number {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── Source chip — the credibility unit ── */
  .evd-source {
    display: inline-block;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: 1px dotted transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  a.evd-source:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .section--light-alt .evd-source {
    color: var(--text-dark-muted);
  }

  .section--light-alt a.evd-source:hover {
    color: var(--accent-dark);
    border-bottom-color: var(--accent-dark);
  }

  /* ── Small display heading ── */
  .evd-h {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 1.25;
    color: var(--text-primary);
    margin: 0 0 var(--space-2);
  }

  .section--light-alt .evd-h {
    color: var(--text-dark);
  }

  /* ── 01: global block ── */
  .evd-global {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-8);
    align-items: start;
  }

  @media (min-width: 900px) {
    .evd-global {
      grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
      gap: var(--space-12);
    }
  }

  .evd-giant {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(5rem, 13vw, 10rem);
    line-height: 0.85;
    letter-spacing: -0.02em;
    color: transparent;
    -webkit-text-stroke: 2px var(--border-outline-light);
  }

  .evd-giant em {
    font-style: normal;
    -webkit-text-stroke-color: var(--accent);
  }

  .evd-giant-label {
    margin: var(--space-4) 0 0;
    font-family: var(--font-heading);
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.35;
    color: var(--text-dark);
    max-width: 380px;
  }

  .evd-progress {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-5);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    color: var(--text-dark-muted);
  }

  .evd-progress-item strong {
    color: var(--text-dark);
    font-weight: 500;
    margin-right: 4px;
  }

  .evd-progress-item--now strong {
    color: var(--accent-strong);
  }

  .evd-progress-arrow {
    color: var(--accent-strong);
  }

  .evd-global-side {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* ── Evidence cards ── */
  .evd-card {
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    height: 100%;
  }

  .section--light-alt .evd-card {
    background: var(--bg-white);
    border-color: var(--border-light);
    box-shadow: var(--shadow-card);
  }

  .evd-card p {
    margin: 0;
  }

  .evd-card strong {
    color: inherit;
  }

  /* ── 02 & 04: stat grids ── */
  .evd-stats-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-5);
  }

  @media (min-width: 700px) {
    .evd-stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .evd-stats-grid {
