---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ui/ScrollReveal.tsx";
import TextSplitReveal from "../components/ui/TextSplitReveal.tsx";

const lineaBase = [
  { value: 94, suffix: "%", label: "Penetración de smartphones en escolares chilenos de 14 a 17 años." },
  { value: 8.9, suffix: "", label: "Años es la edad promedio de entrega del primer celular en Chile actualmente." },
  { value: 4, suffix: "+", label: "Horas diarias de uso que superan los escolares chilenos con equipo propio." },
  { value: 81, suffix: "%", label: "Penetración de smartphones en niños de 8 a 12 años en Chile." },
];

const impacto = [
  { 
    title: "Mejoras en 900 escuelas", 
    desc: "Tras implementar bloqueadores de señal, escuelas reportaron un 65% de mejora académica, 74% de mejor conducta y 83% de mayor participación estudiantil.",
    icon: `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`
  },
  { 
    title: "Tiempo docente recuperado", 
    desc: "Docentes reportan hasta diez minutos adicionales por lección para enseñanza efectiva al eliminar la micro-gestión disciplinaria de los teléfonos.",
    icon: `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`
  },
  { 
    title: "Éxito académico sostenido", 
    desc: "Estudios en EE.UU. a más de 37.000 estudiantes muestran una mejora generalizada en calificaciones después de implementar restricciones físicas.",
    icon: `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>`
  },
  { 
    title: "Riesgo de uso en clase comprobado", 
    desc: "Investigaciones confirman que la mera presencia de un celular reduce significativamente la capacidad cognitiva y la memoria de trabajo.",
    icon: `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`
  },
  { 
    title: "Mejores resultados en exámenes", 
    desc: "Escuelas con restricción física efectiva muestran mejores resultados y mayor aprobación en cursos de niveles superiores (11° y 12°).",
    icon: `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
  },
  { 
    title: "Calificación Ofsted sobresaliente", 
    desc: "Secundarias en el Reino Unido con prohibición efectiva de dispositivos tienen mucha más probabilidad de obtener una calificación de excelencia.",
    icon: `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 15l-2 5l9-9l-9-9l2 5l-10 2l10 2z"/></svg>`
  },
];

const kpis = [
  {
    category: "Aprendizaje",
    items: [
      "Mejora en notas por asignatura y curso",
      "Resultados de evaluaciones parciales",
      "Aumento en la participación general",
      "Continuidad académica sin interrupciones"
    ],
    highlight: "Impacto Académico"
  },
  {
    category: "Convivencia",
    items: [
      "Baja en incidentes por uso indebido",
      "Disminución de casos de ciberacoso",
      "Reducción de medidas disciplinarias",
      "Mejores interacciones cara a cara"
    ],
    highlight: "Impacto Social"
  },
  {
    category: "Operación",
    items: [
      "Uso efectivo y cumplimiento diario",
      "Registro de aperturas y excepciones",
      "Tiempos de respuesta del protocolo",
      "Reducción de decomisos en sala"
    ],
    highlight: "Impacto en Gestión"
  }
];

const global = [
  { country: "🇫🇷 Francia", detail: "Prohibición nacional desde 2018, actuando como modelo referente global." },
  { country: "🇳🇱 Países Bajos", detail: "Prohibición general progresiva desde 2024 en todos los niveles educativos." },
  { country: "🇬🇧 Reino Unido", detail: "Guía oficial gubernamental emitida para respaldar la eliminación total de celulares de las aulas." },
  { country: "🇦🇺 Australia", detail: "Leyes estatales (como Victoria y NSW) establecen restricción total obligatoria en educación escolar." },
  { country: "🇺🇸 EE.UU.", detail: "77% de escuelas públicas los prohíben, con rápida adopción de legislaciones estatales en estados clave." },
  { country: "🇨🇱 Chile", detail: "Nueva ley nacional aprueba restricción desde kínder a media con vigencia desde marzo 2026." },
];
---

<BaseLayout>
  <Header slot="header" />

  <section class="hero hero--sub hero-mesh-bg" style="padding-bottom: 40px; min-height: auto;">
    <div class="mesh-gradient" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero__content container">
      <div class="hero__labels fade-in-up" style="margin-bottom: var(--space-4);">
        <span class="label" style="display: inline-block; padding: 6px 16px; background: rgba(127, 206, 236, 0.1); border-radius: var(--radius-full); border: 1px solid rgba(127, 206, 236, 0.4); color: var(--accent); letter-spacing: 0.1em; font-size: 0.75rem; font-weight: 700;">Fundamentos de la Solución</span>
      </div>
      <h1 class="heading-1 hero__title fade-in-up" style="text-transform: uppercase; animation-delay: 0.1s;">
        EVIDENCIA INTERNACIONAL<br/>
        APLICADA AL <span class="text-accent">CONTEXTO CHILE</span>
      </h1>
      <p class="hero__subtitle body-lg fade-in-up" style="margin-top: var(--space-6); animation-delay: 0.2s;">
        Datos duros, tendencias y métricas reales que respaldan la<br/>decisión de implementar ambientes libres de celulares.
      </p>
    </div>
  </section>

  <!-- ═══════════════ LÍNEA BASE (Stats) ═══════════════ -->
  <section class="section--lg section--light-alt" style="position: relative; overflow: hidden; padding-top: var(--space-20);">
    <!-- Grid Overlay -->
    <div class="ley__grid-overlay" aria-hidden="true"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="section-header">
          <span class="label" style="display: inline-block; padding: 6px 16px; background: rgba(127, 206, 236, 0.12); border-radius: var(--radius-full); margin-bottom: var(--space-4);">El Problema</span>
          <h2 class="heading-2" style="margin-top: 0; line-height: 1.1;">Línea base de uso digital escolar</h2>
          <p class="body-lg" style="color: var(--text-dark-secondary); margin-top: var(--space-4); max-width: 60ch;">Cifras sobre la adopción y el peso del uso del celular para las actuales generaciones de escolares en Chile.</p>
        </div>
      </ScrollReveal>

      <div class="grid-4" style="margin-top: var(--space-12);">
        {lineaBase.map((s, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <div class="ev-stat-card">
              <span class="ev-stat-big">
                {s.value}<span class="ev-stat-suffix">{s.suffix}</span>
              </span>
              <p class="body-sm" style="color: var(--text-dark-secondary); margin-top: var(--space-3); line-height: 1.4;">{s.label}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ EVIDENCIA DE IMPACTO ═══════════════ -->
  <section class="section--lg section--dark" style="position: relative; overflow: hidden;">
    <div class="mesh-gradient" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="section-header section-header--center">
          <span class="label">La Solución</span>
          <h2 class="heading-2" style="margin-top: var(--space-3);">Evidencia de impacto académico y conducta</h2>
          <p class="body-lg" style="color: var(--text-secondary); margin-top: var(--space-4); max-width: 650px; margin-inline: auto;">
            Estudios y encuestas en terreno reflejan mejoras tangibles desde que el uso de estuches restrictivos se adoptó en miles de escuelas internacionalmente.
          </p>
        </div>
      </ScrollReveal>

      <div class="grid-3" style="margin-top: var(--space-12);">
        {impacto.map((item, i) => (
          <ScrollReveal client:visible delay={i * 0.08}>
            <div class="glass-card ev-impact-card">
              <div class="ev-impact-icon" set:html={item.icon}></div>
              <h3 class="heading-5" style="margin-top: var(--space-4); margin-bottom: var(--space-2);">{item.title}</h3>
              <p class="body-sm" style="color: var(--text-secondary); line-height: 1.5;">{item.desc}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ IMPACTO ESPERADO (KPIs) ═══════════════ -->
  <section class="section--lg section--light-alt" style="position: relative; overflow: hidden;">
    <!-- Mesh Gradient -->
    <div class="ley__mesh-gradient" aria-hidden="true"></div>
    <div class="ley__grid-overlay" aria-hidden="true"></div>
    
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="section-header">
          <span class="label" style="display: inline-block; padding: 6px 16px; background: rgba(127, 206, 236, 0.12); border-radius: var(--radius-full); margin-bottom: var(--space-4);">Métricas</span>
          <h2 class="heading-2" style="margin-top: 0; line-height: 1.1;">Impacto esperado y KPIs a medir</h2>
          <p class="body-lg" style="color: var(--text-dark-secondary); margin-top: var(--space-4); max-width: 60ch;">Una vez implementado BloKKit, estos son los indicadores clave de desempeño que tu ecosistema educativo podrá observar, medir y documentar progresivamente.</p>
        </div>
      </ScrollReveal>

      <div class="grid-3" style="margin-top: var(--space-12);">
        {kpis.map((kpi, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <div class="ev-kpi-card">
              <div class="ev-kpi-header">
                <span class="ev-kpi-pill">{kpi.highlight}</span>
                <h3 class="heading-4" style="color: var(--text-dark); margin-top: var(--space-3);">{kpi.category}</h3>
              </div>
              <ul class="ev-kpi-list">
                {kpi.items.map(item => (
                  <li>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ TENDENCIA GLOBAL ═══════════════ -->
  <section class="section--lg section--dark" style="position: relative; overflow: hidden;">
    <div class="mesh-gradient" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <ScrollReveal client:visible>
        <div class="section-header section-header--center">
          <span class="label">Contexto Internacional</span>
          <h2 class="heading-2" style="margin-top: var(--space-3);">Tendencia global de restricción</h2>
          <p class="body-lg" style="color: var(--text-secondary); max-width: 650px; margin-inline: auto; margin-top: var(--space-4);">
            El movimiento legislativo es mundial: gobiernos de todos los continentes actúan drásticamente respaldados en la misma evidencia.
          </p>
        </div>
      </ScrollReveal>
      
      <div class="grid-3" style="margin-top: var(--space-12);">
        {global.map((g, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <div class="glass-card" style="padding: var(--space-6); display: flex; flex-direction: column; height: 100%;">
              <h3 class="heading-4" style="margin-bottom: var(--space-3);">{g.country}</h3>
              <p class="body-sm" style="color: var(--text-secondary); line-height: 1.5;">{g.detail}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA FINAL ═══════════════ -->
  <section class="section--light-alt" style="padding-top: var(--space-20); padding-bottom: var(--space-24); position: relative; overflow: hidden;">
    <div class="hero-grid" aria-hidden="true" style="opacity: 0.3;"></div>
    
    <div class="container" style="position: relative; z-index: 1;">
      <div class="final-cta__card">
        <div class="final-cta__glow" aria-hidden="true"></div>
        <div class="final-cta__inner">
          <ScrollReveal client:visible>
            <TextSplitReveal client:visible text="Descubre el impacto de BloKKit en tu institución" className="heading-3 final-cta__title" splitBy="word" delay={0.1} />
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.2}>
            <p class="body-lg final-cta__subtitle">
              Súmate a la tendencia global y lidera el proceso de descontaminación digital. Agenda tu consultoría estratégica inicial, sin compromiso.
            </p>
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.3}>
            <button type="button" class="btn btn--primary" style="margin-top: var(--space-2);" data-cal-link="blokkit/30min" data-cal-namespace="30min" data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'>
              Agendar Reunión
            </button>
          </ScrollReveal>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Hero & Common ── */
  .hero--sub { min-height: 60vh; display: flex; flex-direction: column; justify-content: center; padding-top: 160px; padding-bottom: 60px; position: relative; overflow: hidden; }
  .hero__content { position: relative; z-index: 1; text-align: center; max-width: 900px; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); margin: 0 auto; }
  .hero__subtitle { max-width: 600px; color: var(--text-secondary); }

  .section-header { margin-bottom: var(--space-8); }
  .section-header--center { text-align: center; display: flex; flex-direction: column; align-items: center; }

  /* ── Linea Base Cards ── */
  .ev-stat-card { 
    padding: var(--space-6); 
    background: var(--bg-white); 
    border: 1px solid var(--border-light); 
    border-radius: var(--radius-lg); 
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .ev-stat-card:hover { 
    transform: translateY(-4px); 
    border-color: var(--accent);
    box-shadow: var(--shadow-sm);
  }
  .ev-stat-big { 
    display: block; 
    font-family: var(--font-heading); 
    font-size: 3.5rem; 
    color: var(--accent); 
    line-height: 1; 
    font-weight: 700; 
    letter-spacing: -0.02em; 
  }
  .ev-stat-suffix {
    font-size: 2rem;
    color: var(--accent-dark);
  }

  /* ── Evidencia Impacto ── */
  .ev-impact-card {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .ev-impact-card:hover {
    transform: translateY(-4px);
    border-color: rgba(127, 206, 236, 0.4);
  }
  .ev-impact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(127, 206, 236, 0.1);
    color: var(--accent);
    border-radius: var(--radius-md);
  }

  /* ── KPIs Cards ── */
  .ev-kpi-card {
    padding: var(--space-8);
    background: var(--bg-white); 
    border: 1px solid var(--border-light); 
    border-radius: var(--radius-lg); 
    height: 100%;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .ev-kpi-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
  }
  .ev-kpi-pill {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: rgba(127, 206, 236, 0.1);
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }
  .ev-kpi-list {
    margin-top: var(--space-6);
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .ev-kpi-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--text-dark-secondary);
    font-size: var(--text-sm);
    line-height: 1.4;
  }
  .ev-kpi-list li svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── Background Elements Re-used ── */
  .ley__mesh-gradient {
    position: absolute;
    inset: -20% -20% -20% -20%;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 60% at 20% 30%, rgba(127, 206, 236, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 70% 70% at 80% 70%, rgba(15, 45, 85, 0.05) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 50% 50%, rgba(255, 255, 255, 0.8) 0%, transparent 60%);
    background-size: 130% 130%;
    animation: mesh-drift 15s ease-in-out infinite alternate;
  }
  .ley__grid-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: 
      linear-gradient(to right, rgba(15, 45, 85, 0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(15, 45, 85, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  
  @keyframes mesh-drift {
    0% { background-position: 0% 0%, 100% 100%, 50% 50%; }
    50% { background-position: 10% 20%, 90% 80%, 60% 40%; }
    100% { background-position: 0% 100%, 100% 0%, 40% 60%; }
  }
</style>
